Page { background: linear-gradient(180deg, #6EE7F0 0%, #FFFFFF 100%); }
.page { padding: 16px; }
.hero { padding: 12px 0; }
.hero-card { display:flex; align-items:center; gap:12px; background: #fff; border-radius:16px; padding:12px; box-shadow: 0 8px 24px rgba(41,93,187,0.16); border:1px solid rgba(91,141,239,0.2); }
.avatar { width: 56px; height: 56px; border-radius: 50%; border: 1px solid rgba(91,141,239,0.3); background: #eee; }
.hero-info { display:flex; flex-direction:column; }
.hero-info .name { font-size: 18px; font-weight: 600; color:#111827; }
.hero-info .days { color: #6B7280; font-size: 12px; }
.hero-card .arrow { color:#9CA3AF; margin-left:auto; }

.device-card { display:flex; gap:12px; align-items:center; background:#fff; border-radius:16px; padding:12px; box-shadow:0 8px 24px rgba(41,93,187,0.16); border:1px solid rgba(91,141,239,0.2); }
.ring { width:72px; height:72px; }
.device-info { flex:1; display:flex; flex-direction:column; gap:6px; }
.row { display:flex; justify-content:space-between; align-items:center; }
.device-name { font-size:16px; color:#111827; font-weight:600; }
.device-status, .device-battery { font-size:12px; color:#6B7280; }
.primary { background:#06B6D4; color:#fff; }

.list-card { background:#fff; border-radius:16px; padding:8px 0; margin-top:16px; box-shadow:0 8px 24px rgba(41,93,187,0.16); border:1px solid rgba(91,141,239,0.2); }
.cell { display:flex; justify-content:space-between; align-items:center; padding:14px 16px; border-bottom:1px solid #f0f4ff; }
.cell:last-child { border-bottom:none; }
.cell-title { font-size:14px; color:#111827; }
.cell-arrow { color:#9CA3AF; }