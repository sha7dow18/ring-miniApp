<view class="page">
  <view class="card">
    <view class="row"><text>设备名称</text><text>{{deviceName||'-'}}</text></view>
    <view class="row"><text>设备状态</text><text>{{connected?'已连接':'未连接'}}</text></view>
    <view class="row"><text>序列号</text><text>{{sn||'-'}}</text></view>
    <view class="row"><text>Mac地址</text><text>{{macId||'-'}}</text></view>
    <view class="row"><text>固件版本</text><text>{{version||'-'}}</text></view>
    <view class="row"><text>硬件版本</text><text>{{hwVersion||'-'}}</text></view>
    <view class="row" bindtap="beginPeriodEdit"><text>采样周期</text><view class="value">{{periodLabel}}<text class="arrow">›</text></view></view>
    <view class="btns">
      <button bindtap="gotoBle">前往连接</button>
      <button class="danger" bindtap="unbind">解绑设备</button>
    </view>
  </view>

  <view wx:if="{{showPeriodModal}}" class="modal-mask" bindtap="cancelPeriodEdit">
    <view class="modal" catchtap="">
      <view class="modal-title">选择采样周期</view>
      <view class="opt-list">
        <block wx:for="{{periodOptions}}" wx:key="*this">
          <view class="opt" catchtap="onPeriodPick" data-index="{{index}}">
            <text>{{item}}</text>
            <text class="check">{{periodIndex==index?'✓':''}}</text>
          </view>
        </block>
      </view>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="cancelPeriodEdit">取消</button>
        <button class="btn-ok" bindtap="confirmPeriod">确认</button>
      </view>
    </view>
  </view>
</view>