<view class="page">
  <view class="card">
    <view class="cell" bindtap="goDevice">
      <text class="cell-title">设备设置</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell" bindtap="goTargets">
      <text class="cell-title">目标设置</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell" bindtap="goProfileEdit">
      <text class="cell-title">个人信息修改</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell" bindtap="goSecurity">
      <text class="cell-title">账号安全</text>
      <text class="cell-arrow">›</text>
    </view>
  </view>
  <view class="card">
    <button bindtap="logout">退出登录</button>
  </view>
</view>