.page { padding:16px; }
.card { background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); padding:8px 0; }
.cell { display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-bottom:1px solid #f0f0f0; }
.label { color:#333; }
.value { display:flex; align-items:center; color:#666; }
.arrow { margin-left:8px; color:#999; }
.modal-mask { position:fixed; left:0; right:0; top:0; bottom:0; background:rgba(0,0,0,0.3); display:flex; align-items:flex-end; }
.modal { background:#fff; width:100%; border-top-left-radius:12px; border-top-right-radius:12px; padding:16px; }
.modal-title { font-size:16px; color:#333; margin-bottom:8px; }
.opt-list { margin-top:8px; }
.opt { display:flex; justify-content:space-between; align-items:center; padding:12px; border:1px solid #eee; border-radius:6px; margin-bottom:8px; }
.opt .check { color:#1aad19; }
.modal-actions { display:flex; justify-content:space-between; margin-top:12px; }
.btn-cancel { color:#666; }
.btn-ok { color:#fff; background:#1aad19; }