<view class="page">
  <view class="card">
    <view class="cell" bindtap="beginEdit" data-field="sleepHours"><text class="label">睡眠目标</text><view class="value">{{sleepHours}} 小时<text class="arrow">›</text></view></view>
    <view class="cell" bindtap="beginEdit" data-field="steps"><text class="label">运动目标</text><view class="value">{{steps}} 步<text class="arrow">›</text></view></view>
    <view class="cell" bindtap="beginEdit" data-field="calories"><text class="label">卡路里</text><view class="value">{{calories}} 千卡<text class="arrow">›</text></view></view>
  </view>
  <view wx:if="{{showEditModal}}" class="modal-mask" bindtap="cancelEdit">
    <view class="modal" catchtap="">
      <view class="modal-title">{{editTitle}}</view>
      <view class="opt-list">
        <block wx:for="{{options}}" wx:key="*this">
          <view class="opt" catchtap="onSelectOption" data-index="{{index}}">
            <text>{{item}} {{editUnit}}</text>
            <text class="check">{{selectedIndex==index?'✓':''}}</text>
          </view>
        </block>
      </view>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="cancelEdit">取消</button>
        <button class="btn-ok" bindtap="confirmEdit">确认</button>
      </view>
    </view>
  </view>
</view>