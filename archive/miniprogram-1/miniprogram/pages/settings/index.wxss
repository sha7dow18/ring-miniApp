.page { padding:16px; }
.card { background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); padding:12px; margin-bottom:12px; }
.cell { display:flex; justify-content:space-between; align-items:center; padding:12px 8px; border-bottom:1px solid #f0f0f0; }
.cell:last-child { border-bottom:none; }
.cell-title { font-size:16px; }
.cell-arrow { color:#999; }