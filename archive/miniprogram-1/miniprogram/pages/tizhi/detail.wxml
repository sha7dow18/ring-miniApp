<view class="page">
  <view class="report" wx:if="{{result}}">
    <view class="report-bg">
      <image class="bg-img" wx:if="{{bgUrl}}" src="{{bgUrl}}" mode="aspectFill"></image>
      <view class="mask"></view>
      <view class="blocks">
        <view class="block top">
          <image class="face-photo" src="{{result.processed_images && result.processed_images.face || faceUrl}}" mode="aspectFill"></image>
          <view class="top-text">
            <text class="title-cn">本次体质检测结果为：</text>
            <text class="time">{{createdTimeText}}</text>
            <block wx:for="{{reportTop}}" wx:key="name">
              <view class="top-item"><text class="top-name">{{item.name}}</text><text class="top-percent">{{item.percentDisplay}}%</text></view>
            </block>
          </view>
        </view>
        <view class="block">
          <text class="block-title">体质分析</text>
          <view class="radar-wrap"><radar labels="{{radarLabels}}" values="{{radarValues}}" size="240" lineColor="#ffffff" fillColor="#06B6D4" textColor="#0e7490"></radar></view>
        </view>
        <view class="block features" wx:if="{{tongueCloverLabels && tongueCloverLabels.length}}">
          <text class="block-title">舌象分析</text>
          <view class="clover-wrap"><clover labels="{{tongueCloverLabels}}" values="{{tongueCloverValues}}" size="240" fillColor="#c7772b" textColor="#8a5a1b"></clover></view>
        </view>
        <view class="block features" wx:if="{{faceCloverLabels && faceCloverLabels.length}}">
          <text class="block-title">面象分析</text>
          <view class="clover-wrap"><clover labels="{{faceCloverLabels}}" values="{{faceCloverValues}}" size="240" fillColor="#b06a28" textColor="#8a5a1b"></clover></view>
        </view>
        <view class="block shiliao" wx:if="{{shiliaoList && shiliaoList.length}}">
          <text class="block-title">食疗建议</text>
          <view class="bullet-list">
            <block wx:for="{{shiliaoList}}" wx:key="*this">
              <view class="bullet-item"><text class="bullet-dot">•</text><text class="bullet-text">{{item}}</text></view>
            </block>
          </view>
        </view>
        <view class="block tiaoli">
          <text class="block-title">调理建议</text>
          <text class="block-sub">{{result.tiaoli && result.tiaoli.tizhi_name}}</text>
          <view class="bullet-list">
            <block wx:for="{{tiaoliPoints}}" wx:key="title">
              <view class="bullet-item"><text class="bullet-dot">•</text><text class="bullet-text">{{item.title}}：{{item.text}}</text></view>
            </block>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{!result}}" class="empty">加载失败或记录不存在</view>
</view>