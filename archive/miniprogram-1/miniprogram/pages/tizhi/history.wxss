.page{display:flex;flex-direction:column;padding:16px;background:linear-gradient(180deg,#6EE7F0 0%,#FFFFFF 100%);min-height:100vh;background-size:cover;background-repeat:no-repeat}
.title{font-size:20px;font-weight:600;color:#0e7490}
.list{display:flex;flex-direction:column;gap:10px;margin-top:12px}
.item{background:#fff;border-radius:12px;padding:12px;box-shadow:0 8px 24px rgba(41,93,187,0.12);border:1px solid rgba(6,182,212,0.18)}
.row{display:flex;flex-direction:row;justify-content:space-between;align-items:center}
.name{font-size:16px;color:#111827}
.time{font-size:12px;color:#0e7490}
.summary{font-size:12px;color:#374151;margin-top:6px}
.empty{color:#6B7280;text-align:center;margin-top:24px}