Page { background: linear-gradient(180deg, #6EE7F0 0%, #FFFFFF 100%); }
.page { padding: 16px; }
.swiper { width:100%; height:150px; border-radius:12px; overflow:hidden; margin-bottom:12px; }
.banner { width:100%; height:100%; display:block; }
.title { font-size: 20px; font-weight: 600; }
.subtitle { color: #6B7280; font-size: 12px; }
.card { background: #fff; border-radius: 12px; padding: 12px; margin: 12px 0; box-shadow: 0 8px 24px rgba(41,93,187,0.12); border:1px solid rgba(91,141,239,0.18); }
.primary { background: #06B6D4; color: #fff; }



.entry-grid { display:grid; grid-template-columns: repeat(4, 1fr); gap:12px; margin-top:12px; }
.entry { background:#fff; border-radius:12px; padding:14px; text-align:center; box-shadow:0 8px 24px rgba(41,93,187,0.12); border:1px solid rgba(91,141,239,0.18); }
.entry-title { font-size:14px; color:#111827; }

.entry-card { background:#fff; border-radius:16px; padding:16px; box-shadow:0 8px 24px rgba(41,93,187,0.12); border:1px solid rgba(91,141,239,0.18); margin-top:12px; }
.icon-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:12px; }
.icon-entry { display:flex; flex-direction:column; align-items:center; }
.icon { width:56px; height:56px; border-radius:50%; background:#6EE7F0; box-shadow:0 0 0 2px rgba(255,255,255,0.8) inset; }
.icon-label { margin-top:6px; font-size:14px; color:#111827; }

.tizhi-card { display:flex; flex-direction:row; align-items:center; gap:12px; background:#fff; border-radius:16px; padding:16px; box-shadow:0 8px 24px rgba(41,93,187,0.12); border:1px solid rgba(91,141,239,0.18); margin-top:12px; }
.tizhi-left { width:72px; height:72px; display:flex; align-items:center; justify-content:center; }
.tizhi-icon { width:64px; height:64px; border-radius:16px; background:#6EE7F0; }
.tizhi-right { display:flex; flex-direction:column; gap:6px; flex:1; }
.tizhi-title { font-size:18px; font-weight:600; color:#111827; }
.tizhi-subtitle { font-size:12px; color:#6B7280; }
.tizhi-btn { align-self:flex-start; margin-top:4px; }