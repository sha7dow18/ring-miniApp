<view class="page">
  <!-- 顶部轮播图 -->
  <swiper class="swiper" autoplay="true" circular="true" indicator-dots="true">
    <block wx:for="{{banners}}" wx:key="*this">
      <swiper-item>
        <image class="banner" src="{{item}}" mode="aspectFill"></image>
      </swiper-item>
    </block>
  </swiper>
  <view class="tizhi-card" bindtap="goTizhi">
    <view class="tizhi-left">
      <image class="tizhi-icon" src="{{tizhiIcon}}" mode="aspectFill"></image>
    </view>
    <view class="tizhi-right">
      <view class="tizhi-title">开始辨识</view>
      <text class="tizhi-subtitle">脉率、面部、舌头三步采集后生成报告</text>
      <button class="primary tizhi-btn">进入流程</button>
    </view>
  </view>
  <view class="tizhi-card" bindtap="goTizhiHistory">
    <view class="tizhi-left">
      <image class="tizhi-icon" src="{{tizhiIcon}}" mode="aspectFill"></image>
    </view>
    <view class="tizhi-right">
      <view class="tizhi-title">查看历史</view>
      <text class="tizhi-subtitle">浏览过往体质辨识结果与详情</text>
      <button class="primary tizhi-btn">打开历史</button>
    </view>
  </view>
</view>