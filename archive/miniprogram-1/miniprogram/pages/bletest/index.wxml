<view class="page">
  <view class="card">
    <view class="title">蓝牙协议测试</view>
    <text class="subtitle">按步骤验证初始化、扫描、连接、服务/特征、通知与写入</text>
  </view>

  <view class="card toolbar">
    <button size="mini" bindtap="initBle" disabled="{{inited}}">初始化</button>
    <button size="mini" bindtap="startScan" disabled="{{!inited || scanning}}">开始扫描</button>
    <button size="mini" bindtap="stopScan" disabled="{{!scanning}}">停止扫描</button>
    <button size="mini" bindtap="clearLogs">清空日志</button>
  </view>

  <view class="card" wx:if="{{scanning}}">
    <view class="list-title">扫描中...</view>
  </view>

  <view class="card" wx:if="{{devices.length}}">
    <view class="list-title">发现设备（点击绑定）</view>
    <block wx:for="{{devices}}" wx:key="deviceId">
      <view class="cell" bindtap="connect" data-id="{{item.deviceId}}" data-name="{{item.name}}">
        <view class="cell-left">
          <text class="cell-title">{{item.name || '未知设备'}}</text>
          <text class="cell-desc">{{item.deviceId}}</text>
        </view>
        <view>
          <button size="mini">绑定</button>
        </view>
      </view>
    </block>
  </view>

  <view class="card" wx:if="{{connected}}">
    <view class="list-title">连接信息</view>
    <view class="kv"><text>设备：</text><text>{{deviceName}}</text></view>
    <view class="kv"><text>ID：</text><text>{{deviceId}}</text></view>
    <view class="btns">
      <button size="mini" bindtap="discoverServices">获取服务</button>
      <button size="mini" bindtap="discoverChars">获取特征</button>
      <button size="mini" bindtap="toggleNotify" disabled="{{!serviceId || !notifyCharId}}">{{isNotifying ? '关闭通知' : '开启通知'}}</button>
      <button size="mini" bindtap="disconnect">断开</button>
    </view>
  </view>

  <view class="card" wx:if="{{connected}}">
    <view class="list-title">服务/特征参数</view>
    <view class="form-row">
      <text class="label">Service UUID</text>
      <input class="input" placeholder="例如：0000FFF0-0000-1000-8000-00805F9B34FB" value="{{serviceId}}" bindinput="onInputService" />
    </view>
    <view class="form-row">
      <text class="label">Write Char UUID</text>
      <input class="input" placeholder="写入特征 UUID" value="{{writeCharId}}" bindinput="onInputWriteChar" />
    </view>
    <view class="form-row">
      <text class="label">Notify Char UUID</text>
      <input class="input" placeholder="通知特征 UUID" value="{{notifyCharId}}" bindinput="onInputNotifyChar" />
    </view>
    <view class="form-row">
      <text class="label">Notify Service UUID</text>
      <input class="input" placeholder="通知所在服务 UUID（可与写服务不同）" value="{{notifyServiceId}}" bindinput="onInputNotifyService" />
    </view>
  </view>

  <view class="card" wx:if="{{connected}}">
    <view class="list-title">蓝牙名称设置</view>
    <view class="form-row">
      <text class="label">新名称（≤12字节）</text>
      <input class="input" placeholder="例如：BQ Ring 86B6 或 BQRing86B6" value="{{newBleName}}" bindinput="onInputBleName" />
    </view>
    <view class="btns">
      <button class="primary" size="mini" bindtap="setBleName">设置蓝牙名称</button>
    </view>
    <text class="subtitle">提示：设置成功后设备将断开并以新名称广播</text>
  </view>

  <view class="card" wx:if="{{connected}}">
    <view class="list-title">发送指令（HEX）</view>
    <view class="form-row">
      <input class="input" placeholder="例如：AA5501..." value="{{hexInput}}" bindinput="onInputHex" />
    </view>
    <view class="btns">
      <button class="primary" size="mini" bindtap="sendHex" disabled="{{!serviceId || !writeCharId || !hexInput}}">发送</button>
    </view>
  </view>

  <view class="card" wx:if="{{connected}}">
    <view class="list-title">快捷测试</view>

    <view class="action-section">
      <view class="section-title">系统信息</view>
      <view class="action-grid">
        <button class="btn-primary" bindtap="sendAction" bindlongpress="openEdit" data-key="getVersion">获取版本号</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="getHwVersion">硬件版本</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="readTime">读取时间</button>
        <button class="btn-primary" bindtap="sendAction" bindlongpress="openEdit" data-key="syncTime">同步时间</button>
        <button class="btn-primary" bindtap="sendAction" bindlongpress="openEdit" data-key="getBattery">获取电量</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="getChargeState">充电状态</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="getSN">获取SN码</button>
        <button class="btn-secondary" bindtap="gotoSetSn">设置SN码</button>
      </view>
    </view>

    <view class="action-section">
      <view class="section-title">测量</view>
      <view class="action-grid">
        <button class="btn-primary" bindtap="sendAction" bindlongpress="openEdit" data-key="measureVitals">综合测量</button>
        <button class="btn-primary" bindtap="sendAction" bindlongpress="openEdit" data-key="measureSpO2">测量血氧</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="measureTemp">单独温度</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="readSteps">读取步数</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="getPeriod">获取采集周期</button>
        <button class="btn-warning" bindtap="sendAction" bindlongpress="openEdit" data-key="setPeriod60">设置周期60s</button>
      </view>
      <view class="form-row">
        <text class="label">采集周期(s)</text>
        <input class="input" type="number" value="{{samplePeriod}}" bindinput="onInputPeriod" />
      </view>
    </view>

    <view class="action-section">
      <view class="section-title">数据与维护</view>
      <view class="action-grid">
        <button class="btn-primary" bindtap="sendAction" bindlongpress="openEdit" data-key="syncAll">同步全部数据</button>
        <button class="btn-danger" bindtap="sendAction" bindlongpress="openEdit" data-key="factoryReset">恢复出厂设置</button>
        <button class="btn-warning" bindtap="sendAction" bindlongpress="openEdit" data-key="startPressureCollect">压力采集</button>
        <button class="btn-secondary" bindtap="sendAction" bindlongpress="openEdit" data-key="stopPressureTest">取消压力测试</button>
        <button class="btn-secondary" bindtap="disconnect">断开连接</button>
      </view>
    </view>
    <text class="subtitle">提示：长按任意按钮可编辑对应HEX模板</text>
  </view>

  <view class="card" wx:if="{{connected}}">
    <view class="list-title">关键结果</view>
    <view class="result-grid">
      <view class="result-item"><text class="label">MAC/ID</text><text class="value">{{macId}}</text></view>
      <view class="result-item"><text class="label">SN</text><text class="value">{{sn || '—'}}</text></view>
      <view class="result-item"><text class="label">版本</text><text class="value">{{version || '—'}}</text></view>
      <view class="result-item"><text class="label">时间同步</text><text class="value">{{timeSyncedAt || '未同步'}}</text></view>
      <view class="result-item"><text class="label">电量</text><text class="value">{{batteryPercent || '—'}}</text></view>
      <view class="result-item"><text class="label">心率</text><text class="value">{{heartRate || '—'}}</text></view>
      <view class="result-item"><text class="label">血氧</text><text class="value">{{spo2 || '—'}}</text></view>
      <view class="result-item"><text class="label">测量进度</text><text class="value">{{measureProgress || '—'}}</text></view>
      <view class="result-item"><text class="label">同步进度</text><text class="value">{{syncProgress || '—'}}</text></view>
    </view>
  </view>

  <!-- 编辑命令模板弹层 -->
  <view wx:if="{{editVisible}}" style="position:fixed;left:0;top:0;right:0;bottom:0;background:rgba(0,0,0,0.35);display:flex;align-items:center;justify-content:center;z-index:99;">
    <view class="card" style="width:92%;">
      <view class="title">编辑命令：{{editingKey}}</view>
      <view class="form-row">
        <text class="label">HEX模板</text>
        <textarea class="input" style="min-height:120px;" value="{{editHex}}" bindinput="onEditHexInput" placeholder="例如：A5 01 {YY} {MM} {DD} {hh} {mm} {ss}" />
      </view>
      <view class="subtitle">支持动态占位符：{YY}{MM}{DD}{hh}{mm}{ss}{PERIOD}</view>
      <view class="btns">
        <button class="btn-secondary" bindtap="closeEdit">取消</button>
        <button class="btn-primary" bindtap="saveEdit">保存</button>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="list-title">日志</view>
    <scroll-view scroll-y="true" style="max-height: 260px;">
      <block wx:for="{{logs}}" wx:key="id">
        <view class="log {{item.dir}}">
          <text>{{item.time}} [{{item.dir}}] {{item.msg}}</text>
        </view>
      </block>
    </scroll-view>
    <view class="kv"><text>最近发送：</text><text>{{lastActionName}}</text></view>
    <view class="kv"><text>通知计数：</text><text>{{rxCount}}</text></view>
  </view>
</view>