<view class="home-page">
  <view class="top-brand">
    <view class="hello">{{greetingText}}</view>
    <view class="name">User！</view>
  </view>

  <view class="month-row">
    <view class="arrow" bindtap="onPrevDay" hover-class="hover">‹</view>
    <picker mode="date" value="{{selectedDate}}" bindchange="onPickerChange">
      <view class="month hover-chip" hover-class="hover">{{monthText}}</view>
    </picker>
    <view class="arrow" bindtap="onNextDay" hover-class="hover">›</view>
  </view>

  <scroll-view class="date-scroll" scroll-x="true" scroll-left="{{dateScrollLeft}}" scroll-with-animation show-scrollbar="false" enhanced>
    <view class="date-list">
      <view
        class="date-chip {{selectedDate===item.key?'active':''}} {{item.isToday?'is-today':''}}"
        wx:for="{{dateTabs}}" wx:key="key"
        data-key="{{item.key}}" bindtap="onPickDate" hover-class="chip-hover"
      >
        <text class="day">{{item.day}}</text>
        <text class="week">{{item.week}}</text>
        <view class="today-dot" wx:if="{{item.isToday}}"></view>
      </view>
    </view>
  </scroll-view>

  <view class="empty-card" wx:if="{{!isConnected}}">
    <view class="empty-title">设备还未连接</view>
    <view class="empty-desc">连接后即可查看完整健康摘要与 AI 分析。</view>
    <view class="capsule-btn" bindtap="goConnectDevice">去连接设备</view>
  </view>

  <scroll-view wx:else class="content-scroll" scroll-y="true">
    <view class="card bp-card">
      <view class="bp-head">
        <text class="bp-title">血压</text>
        <text class="bp-tag">月度</text>
      </view>
      <view class="bp-graph">
        <canvas type="2d" id="bpCanvas" class="bp-canvas"></canvas>
      </view>
      <view class="time-row">
        <text wx:for="{{bpTrendTime}}" wx:key="index">{{item}}</text>
      </view>
      <view class="bp-legend">
        <text class="lg red-dot">收缩压 {{metrics.systolic}}</text>
        <text class="lg dark-dot">舒张压 {{metrics.diastolic}}</text>
      </view>
    </view>

    <view class="duo-grid">
      <view class="card duo-card sport-card">
        <view class="sport-head">
          <view class="duo-title">运动</view>
          <image class="sport-ring-image" src="/assets/health/icon_sport_ring.png" mode="aspectFit" />
        </view>
        <view class="sport-row">
          <text class="sport-main">{{metrics.steps}}</text>
          <text class="sport-target">/{{metrics.stepGoal}}步</text>
        </view>
        <view class="sport-row calories-row">
          <text class="sport-main small">{{metrics.calories}}</text>
          <text class="sport-target">/50千卡</text>
        </view>
      </view>
      <view class="card duo-card sleep-card">
        <view class="duo-title">睡眠</view>
        <view class="sleep-gauge">
        <image class="sleep-hero" src="/assets/health/icon_sleep.png" mode="aspectFit" />
      </view>
        <view class="sleep-score">{{metrics.sleepScore}}<text>{{metrics.sleepGrade}}</text></view>
        <view class="sleep-time">{{metrics.sleepDisplay}}</view>
      </view>
    </view>

    <view class="weekly-card card" wx:if="{{weeklyBars.length}}">
      <view class="weekly-head">
        <text class="weekly-title">近 7 日睡眠</text>
        <text class="weekly-hint">评分趋势</text>
      </view>
      <view class="weekly-bars">
        <view class="weekly-col" wx:for="{{weeklyBars}}" wx:key="label">
          <text class="weekly-val">{{item.value}}</text>
          <view class="weekly-bar" style="height: {{item.h}}rpx;"></view>
          <text class="weekly-lbl">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="other-title">其他数据</view>
    <view class="other-list">
      <view class="other-item" wx:for="{{otherRows}}" wx:key="key" data-key="{{item.key}}" bindtap="onMetricTap" hover-class="hover">
        <view class="icon-holder">
          <image class="icon" src="/assets/icons/inv/{{item.iconName}}.svg" mode="aspectFit" aria-label="{{item.label}}"/>
        </view>
        <view class="middle">
          <view class="nm">{{item.label}}</view>
          <view class="vl">{{item.value}}</view>
        </view>
        <view class="spark-wrap">
          <view class="spark">
            <view wx:for="{{item.trend}}" wx:for-item="bar" wx:key="index" class="bar" style="height: {{bar}}rpx;"></view>
          </view>
        </view>
        <view class="jump">›</view>
      </view>
    </view>

    <view class="analysis-row">
      <view class="ana">简要分析：指标整体稳定，继续保持规律作息与低强度运动。</view>
      <view class="action-row">
        <view class="ghost-btn" bindtap="onRefreshMetrics">刷新数据</view>
        <view class="ghost-btn" bindtap="goToAi">去 AI 分析</view>
        <view class="ghost-btn" bindtap="showMetricDetail">查看详情</view>
        <view class="ghost-btn" bindtap="goToDevice">设备中心</view>
      </view>
    </view>

    <view style="height: 120rpx;"></view>
  </scroll-view>
</view>
