<view class="home-page">
  <view class="top-brand">
    <view class="hello">{{greetingText}}</view>
    <view class="name">User！</view>
  </view>

  <view class="month-row">
    <view class="arrow" bindtap="onPrevDay" hover-class="hover">‹</view>
    <picker mode="date" value="{{selectedDate}}" bindchange="onPickerChange">
      <view class="month hover-chip" hover-class="hover">{{monthText}}</view>
    </picker>
    <view class="arrow" bindtap="onNextDay" hover-class="hover">›</view>
  </view>

  <scroll-view class="date-scroll" scroll-x="true" scroll-left="{{dateScrollLeft}}" scroll-with-animation show-scrollbar="false" enhanced>
    <view class="date-list">
      <view
        class="date-chip {{selectedDate===item.key?'active':''}} {{item.isToday?'is-today':''}}"
        wx:for="{{dateTabs}}" wx:key="key"
        data-key="{{item.key}}" bindtap="onPickDate" hover-class="chip-hover"
      >
        <text class="day">{{item.day}}</text>
        <text class="week">{{item.week}}</text>
        <view class="today-dot" wx:if="{{item.isToday}}"></view>
      </view>
    </view>
  </scroll-view>

  <view class="constitution-banner" bindtap="goConstitution" hover-class="banner-hover">
    <view class="cb-left">
      <view class="cb-label">你的体质</view>
      <view class="cb-name">{{constitutionName || '未评估'}}</view>
      <view class="cb-hint">{{constitutionHint}}</view>
    </view>
    <view class="cb-right">
      <view class="cb-cta">{{constitutionName ? '查看报告' : '立即辨识'}} ›</view>
    </view>
  </view>

  <view wx:if="{{!hasBoundChild}}" class="family-cta-banner" bindtap="goFamilyBind" hover-class="banner-hover">
    <view class="fcb-emoji">🤝</view>
    <view class="fcb-body">
      <view class="fcb-title">绑定子女账户</view>
      <view class="fcb-desc">健康简报 / 异常预警 / 补货提醒会自动送到家人手里</view>
    </view>
    <view class="fcb-arrow">›</view>
  </view>

  <view class="empty-card" wx:if="{{!isConnected}}">
    <view class="empty-title">设备还未连接</view>
    <view class="empty-desc">连接后即可查看完整健康摘要与 AI 分析。</view>
    <view class="capsule-btn" bindtap="goConnectDevice">去连接设备</view>
  </view>

  <scroll-view wx:else class="content-scroll" scroll-y="true">
    <view class="card bp-card">
      <view class="bp-head">
        <text class="bp-title">血压</text>
        <text class="bp-tag">月度</text>
      </view>
      <view class="bp-graph">
        <canvas type="2d" id="bpCanvas" class="bp-canvas"></canvas>
      </view>
      <view class="time-row">
        <text wx:for="{{bpTrendTime}}" wx:key="index">{{item}}</text>
      </view>
      <view class="bp-legend">
        <text class="lg red-dot">收缩压 {{metrics.systolic}}</text>
        <text class="lg dark-dot">舒张压 {{metrics.diastolic}}</text>
      </view>
    </view>

    <view class="duo-grid">
      <view class="card duo-card sport-card">
        <view class="duo-head">
          <text class="duo-title">运动</text>
          <text class="duo-pct">{{metrics.stepsPct}}%</text>
        </view>
        <view class="big-metric">
          <text class="big-num">{{metrics.steps}}</text>
          <text class="big-unit">步</text>
        </view>
        <view class="duo-sub">目标 {{metrics.stepGoal}} · {{metrics.calories}} 千卡</view>
        <view class="duo-bar">
          <view class="duo-bar-fill" style="width: {{metrics.stepsPct}}%;"></view>
        </view>
      </view>

      <view class="card duo-card sleep-card">
        <view class="duo-head">
          <text class="duo-title">睡眠</text>
          <text class="duo-grade grade-{{metrics.sleepGradeCls}}">{{metrics.sleepScore}} · {{metrics.sleepGrade}}</text>
        </view>
        <view class="big-metric">
          <text class="big-num">{{metrics.sleepHours}}</text>
          <text class="big-unit">时</text>
          <text class="big-num big-num-sub">{{metrics.sleepMins}}</text>
          <text class="big-unit">分</text>
        </view>
        <view class="duo-sub">{{metrics.sleepRangeText}}</view>
        <view class="duo-bar">
          <view class="duo-bar-fill" style="width: {{metrics.sleepScore}}%;"></view>
        </view>
      </view>
    </view>

    <view class="weekly-card card" wx:if="{{weeklyBars.length}}">
      <view class="weekly-head">
        <text class="weekly-title">近 7 日睡眠</text>
        <text class="weekly-hint">评分趋势</text>
      </view>
      <view class="weekly-bars">
        <view class="weekly-col" wx:for="{{weeklyBars}}" wx:key="label">
          <text class="weekly-val">{{item.value}}</text>
          <view class="weekly-bar" style="height: {{item.h}}rpx;"></view>
          <text class="weekly-lbl">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="section-head">
      <view class="other-title">其他体征</view>
      <view class="other-hint">近 5 次波动</view>
    </view>
    <view class="other-list">
      <view class="other-item" wx:for="{{otherRows}}" wx:key="key" data-key="{{item.key}}" bindtap="onMetricTap" hover-class="hover">
        <view class="icon-holder">
          <image class="icon" src="/assets/icons/inv/{{item.iconName}}.svg" mode="aspectFit" aria-label="{{item.label}}"/>
        </view>
        <view class="middle">
          <view class="nm">{{item.label}}</view>
          <view class="vl">{{item.value}}</view>
        </view>
        <view class="spark-wrap">
          <view class="spark-bars" aria-hidden="true">
            <view class="spark-bar {{bar.isLast ? 'active' : ''}}" wx:for="{{item.sparkBars}}" wx:for-item="bar" wx:for-index="barIndex" wx:key="barIndex" style="height: {{bar.h}}rpx;"></view>
          </view>
        </view>
        <text class="chev">›</text>
      </view>
    </view>

    <view class="section-head huan-head">
      <view class="other-title">环环推荐 · AIGC</view>
      <view class="refresh-chip" bindtap="refreshOneContent" hover-class="hover">
        <text wx:if="{{refreshingContent}}">生成中…</text>
        <text wx:else>换一条 AI 新内容</text>
      </view>
    </view>
    <content-card wx:for="{{contentFeed}}" wx:key="_id" item="{{item}}" bindtap="onContentTap" />

    <view style="height: 120rpx;"></view>
  </scroll-view>
</view>
