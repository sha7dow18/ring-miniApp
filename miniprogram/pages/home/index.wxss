.home-page { padding: var(--sp-4); padding-top: 18rpx; box-sizing: border-box; }

.top-brand { margin-top: var(--sp-2); }
.hello { font-size: var(--fs-sub); color: var(--text-2); font-weight: var(--fw-semibold); }
.name { margin-top: var(--sp-1); font-size: 64rpx; color: var(--text-1); font-weight: var(--fw-bold); line-height: 1.05; }

.hover { opacity: 0.55; }
.month-row {
  margin: var(--sp-3) 0 12rpx;
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
}
.month {
  font-size: var(--fs-h2);
  color: var(--text-1);
  font-weight: var(--fw-bold);
  padding: 8rpx 20rpx;
  border-radius: var(--r-pill);
}
.arrow {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-2);
  font-size: var(--fs-h1);
}

.date-scroll {
  width: 100%;
  height: 136rpx;            /* 留 scale(1.2) 的垂直空间，避免上方被月份行遮 */
  margin-bottom: 10rpx;
  /* 手动滑动时 chip 居中吸附 */
  scroll-snap-type: x mandatory;
}
.date-list { display: flex; white-space: nowrap; padding: 16rpx 0; }
.date-chip {
  width: 84rpx; height: 96rpx;
  border-radius: var(--r-card);
  background: var(--bg-muted);
  margin-right: 14rpx;
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  color: var(--text-2);
  position: relative;
  transform-origin: center center;
  transition:
    transform 0.32s cubic-bezier(0.34, 1.3, 0.64, 1),
    background 0.24s ease,
    color 0.24s ease,
    box-shadow 0.24s ease;
  scroll-snap-align: center;
  flex-shrink: 0;
}
.chip-hover { opacity: 0.7; }
.date-chip.active {
  background: var(--brand);
  color: var(--text-inv);
  box-shadow: 0 14rpx 28rpx rgba(47,74,66,.28);
  transform: scale(1.2);
  z-index: 2;
}
.date-chip.is-today:not(.active) {
  box-shadow: inset 0 0 0 2rpx var(--brand);
  color: var(--text-1);
}
.day { font-size: 30rpx; font-weight: var(--fw-bold); line-height: 1.1; transition: font-size 0.24s ease; }
.week { font-size: 20rpx; margin-top: 4rpx; transition: font-size 0.24s ease; }
.date-chip.active .day { font-size: 34rpx; }
.date-chip.active .week { font-size: 21rpx; }
/* today 标记挪到右上角，不再和"周几"文字打架；选中时 brand 底已经视觉很强，隐藏 dot */
.today-dot {
  position: absolute;
  top: 6rpx; right: 6rpx;
  width: 10rpx; height: 10rpx; border-radius: 50%;
  background: var(--brand);
}
.date-chip.active .today-dot { display: none; }

.content-scroll { min-height: 100vh; padding-bottom: calc(150rpx + env(safe-area-inset-bottom)); }

.empty-card, .other-list {
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
}
.empty-card { padding: var(--sp-5); text-align: center; margin-bottom: var(--sp-3); }
.empty-title { font-size: var(--fs-h2); color: var(--text-1); font-weight: var(--fw-bold); }
.empty-desc { margin: var(--sp-2) 0 var(--sp-3); color: var(--text-2); font-size: var(--fs-sub); }
.capsule-btn {
  display: inline-block;
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-pill);
  padding: var(--sp-3) 34rpx;
  font-size: var(--fs-sub);
}

.bp-card { padding: 20rpx; margin-bottom: 12rpx; }
.bp-head { display: flex; justify-content: space-between; align-items: center; }
.bp-title { font-size: var(--fs-h1); color: var(--text-1); font-weight: var(--fw-bold); }
.bp-tag {
  font-size: 20rpx;
  color: var(--text-2);
  background: var(--bg-muted);
  border-radius: var(--r-pill);
  padding: 4rpx 10rpx;
}
.bp-graph {
  margin-top: 12rpx;
  height: 220rpx;
}
.bp-canvas { width: 100%; height: 220rpx; display: block; }
.time-row { margin-top: var(--sp-2); display: flex; justify-content: space-between; color: var(--text-2); font-size: 19rpx; padding: 0 4rpx; }
.bp-legend { margin-top: 10rpx; display: flex; gap: 20rpx; }
.lg { font-size: 21rpx; color: var(--text-2); }
/* 数据可视化专色：不进入 token 系统 */
.red-dot::before { content: ""; display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%; background: #8a1d30; margin-right: 6rpx; }
.dark-dot::before { content: ""; display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--brand); margin-right: 6rpx; }

/* ═══ 运动 / 睡眠 双卡（重设计） ═══ */
.duo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-bottom: 12rpx; }
.duo-card {
  padding: 22rpx 20rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  display: flex; flex-direction: column; gap: 12rpx;
  min-width: 0;
}
.duo-head { display: flex; align-items: center; justify-content: space-between; gap: 8rpx; }
.duo-title { font-size: 26rpx; color: var(--text-2); font-weight: var(--fw-semibold); }
.duo-pct {
  font-size: 22rpx; color: var(--brand);
  font-weight: var(--fw-bold);
  background: var(--bg-muted); padding: 2rpx 10rpx; border-radius: var(--r-pill);
}
.duo-grade {
  font-size: 22rpx; font-weight: var(--fw-bold);
  padding: 2rpx 10rpx; border-radius: var(--r-pill);
}
.grade-good  { background: #E4FCD6; color: var(--success); }
.grade-ok    { background: var(--bg-muted); color: var(--brand); }
.grade-low   { background: #FCE4D6; color: var(--accent); }

.big-metric {
  display: flex; align-items: baseline; gap: 4rpx;
  color: var(--text-1);
  flex-wrap: nowrap;
}
.big-num { font-size: 56rpx; font-weight: var(--fw-bold); line-height: 1; letter-spacing: -1rpx; }
.big-num-sub { margin-left: 12rpx; font-size: 44rpx; }
.big-unit { font-size: 24rpx; color: var(--text-3); font-weight: var(--fw-semibold); margin-left: 2rpx; }

.duo-sub {
  font-size: var(--fs-caption);
  color: var(--text-2);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 底部进度细条 */
.duo-bar {
  height: 8rpx; border-radius: 4rpx;
  background: var(--bg-muted);
  overflow: hidden;
  margin-top: 4rpx;
}
.duo-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--brand-mid), var(--brand));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.section-head {
  margin: 14rpx 4rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.other-title { color: var(--text-1); font-size: var(--fs-h2); font-weight: var(--fw-bold); }
.other-hint { color: var(--text-2); font-size: var(--fs-caption); }
.other-list { background: transparent; box-shadow: none; padding: 0; margin-bottom: 12rpx; display: flex; flex-direction: column; gap: 14rpx; }

/* 国风 pill — 暖米渐变底 + 深绿实心圆图标 */
.other-item {
  display: flex; align-items: center; gap: 18rpx;
  padding: 14rpx 16rpx 14rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  box-shadow: 0 4rpx 14rpx rgba(139, 103, 50, 0.08);
}

.icon-holder {
  width: 84rpx; height: 84rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 -4rpx 10rpx rgba(0,0,0,0.12);
}
.icon-holder .icon { width: 44rpx; height: 44rpx; }

.middle { flex: 0 0 auto; min-width: 164rpx; }
.nm { color: var(--text-2); font-size: var(--fs-caption); }
.vl { color: var(--text-1); font-size: var(--fs-body); font-weight: var(--fw-bold); margin-top: 2rpx; }

.spark-wrap { flex: 1; display: flex; justify-content: flex-end; align-items: center; }
.spark-bars {
  height: 58rpx;
  min-width: 150rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  gap: 8rpx;
}
.spark-bar {
  width: 12rpx;
  border-radius: 999rpx;
  background: rgba(63, 107, 94, 0.22);
}
.spark-bar.active {
  width: 14rpx;
  background: linear-gradient(180deg, var(--brand-light), var(--brand-dark));
  box-shadow: 0 3rpx 8rpx rgba(42, 74, 62, 0.16);
}

/* iOS 式 chevron，替代原深色实心圆按钮 */
.chev {
  flex-shrink: 0;
  width: 36rpx; text-align: center;
  font-size: 38rpx;
  font-weight: 300;
  color: var(--text-3);
  line-height: 1;
}


/* 近 7 日趋势卡片 */
.weekly-card {
  padding: 20rpx 22rpx;
  margin-top: 12rpx;
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
}
.weekly-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.weekly-title { font-size: 30rpx; color: var(--text-1); font-weight: var(--fw-bold); }
.weekly-hint { font-size: var(--fs-caption); color: var(--text-2); }
.weekly-bars { display: flex; justify-content: space-between; align-items: flex-end; height: 200rpx; padding: 0 8rpx; gap: 8rpx; }
.weekly-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; min-width: 0; }
.weekly-val { font-size: 20rpx; color: var(--text-2); font-weight: var(--fw-semibold); }
.weekly-bar {
  width: 100%;
  max-width: 48rpx;
  min-width: 28rpx;
  background: linear-gradient(180deg, var(--brand-mid), var(--brand-dark));
  border-radius: 14rpx 14rpx 4rpx 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(47,74,66,0.15);
}
.weekly-lbl { font-size: 20rpx; color: var(--text-3); }
