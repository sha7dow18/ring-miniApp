<view class="profile-page">
  <view class="user-card" bindtap="goUserInfo">
    <view class="avatar" wx:if="{{profile.avatarUrl}}"><image src="{{profile.avatarUrl}}" mode="aspectFill" /></view>
    <view class="avatar placeholder" wx:else>头像</view>
    <view class="user-meta">
      <view class="title">个人中心</view>
      <view class="name">{{profile.nickname}}</view>
      <view class="phone">{{profile.phone}}</view>
      <view class="device">{{deviceStatusText}}</view>
    </view>
  </view>

  <view class="menu-group">
    <view class="group-title">家庭</view>
    <view class="menu-card">
      <view class="menu-item" bindtap="goRoleSwitch"><text>切换角色</text><view class="menu-item-right"><text class="menu-hint">{{roleLabel}}</text><text>›</text></view></view>
      <view class="menu-item" bindtap="goFamilyBind"><text>家庭绑定</text><view class="menu-item-right"><text class="menu-hint">{{bindStatusText}}</text><text>›</text></view></view>
    </view>
  </view>

  <view class="menu-group">
    <view class="group-title">健康与 AI</view>
    <view class="menu-card">
      <view class="menu-item" bindtap="goConstitution"><text>我的体质</text><view class="menu-item-right"><text class="menu-hint">{{constitutionName || '未评估'}}</text><text>›</text></view></view>
      <view class="menu-item" bindtap="goSubscription"><text>AI 订阅</text><view class="menu-item-right"><text class="menu-hint">{{planName || '免费'}}</text><text>›</text></view></view>
      <view class="menu-item" bindtap="goConsult"><text>预约问诊</text><text>›</text></view>
      <view class="menu-item" bindtap="goConsultList"><text>我的问诊</text><text>›</text></view>
    </view>
  </view>

  <view class="menu-group">
    <view class="group-title">我的服务</view>
    <view class="menu-card">
      <view class="menu-item" bindtap="goMyDevice"><text>我的设备</text><text>›</text></view>
      <view class="menu-item" bindtap="goOrders"><text>我的订单</text><text>›</text></view>
      <view class="menu-item" bindtap="goReplenish"><text>补货计划</text><text>›</text></view>
    </view>
  </view>

  <view class="menu-group">
    <view class="group-title">设置与支持</view>
    <view class="menu-card">
      <view class="menu-item" bindtap="goUserInfo"><text>我的资料</text><text>›</text></view>
      <view class="menu-item" bindtap="goSettings"><text>设置</text><text>›</text></view>
      <view class="menu-item" bindtap="goAbout"><text>关于我们</text><text>›</text></view>
    </view>
  </view>
</view>
