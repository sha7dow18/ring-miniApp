<view class="profile-page">
  <view class="user-card" bindtap="goUserInfo">
    <view class="avatar" wx:if="{{profile.avatarUrl}}"><image src="{{profile.avatarUrl}}" mode="aspectFill" /></view>
    <view class="avatar placeholder" wx:else>头像</view>
    <view class="user-meta">
      <view class="title">个人中心</view>
      <view class="name">{{profile.nickname}}</view>
      <view class="phone">{{profile.phone}}</view>
      <view class="device">{{deviceStatusText}}</view>
    </view>
  </view>

  <view class="menu-group">
    <view class="group-title">我的服务</view>
    <view class="menu-card">
      <view class="menu-item" bindtap="goMyDevice"><text>我的设备</text><text>›</text></view>
      <view class="menu-item" bindtap="goOrders"><text>我的订单</text><text>›</text></view>
    </view>
  </view>

  <view class="menu-group">
    <view class="group-title">设置与支持</view>
    <view class="menu-card">
      <view class="menu-item" bindtap="goUserInfo"><text>我的资料</text><text>›</text></view>
      <view class="menu-item" bindtap="goSettings"><text>设置</text><text>›</text></view>
      <view class="menu-item" bindtap="goAbout"><text>关于我们</text><text>›</text></view>
    </view>
  </view>
</view>
