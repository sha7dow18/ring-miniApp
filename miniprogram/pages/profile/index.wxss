.profile-page { padding: var(--sp-4); padding-bottom: calc(150rpx + env(safe-area-inset-bottom)); }

.user-card, .menu-card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
}
.user-card {
  display: flex;
  align-items: center;
  padding: var(--sp-4);
  margin-bottom: var(--sp-3);
}
.avatar {
  width: 108rpx; height: 108rpx;
  border-radius: var(--r-pill);
  overflow: hidden;
  margin-right: var(--sp-3);
  background: var(--bg-muted);
}
.avatar image { width: 100%; height: 100%; }
.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-2);
  font-size: var(--fs-caption);
}
.title { color: var(--text-2); font-size: var(--fs-caption); }
.name { margin-top: var(--sp-1); color: var(--text-1); font-size: var(--fs-h2); font-weight: var(--fw-bold); }
.phone, .device { margin-top: 6rpx; color: var(--text-2); font-size: var(--fs-caption); }

.menu-group { margin-bottom: var(--sp-3); }
.group-title { color: var(--text-2); font-size: var(--fs-caption); margin: 0 4rpx var(--sp-2); }
.menu-card { padding: 6rpx 18rpx; }
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--sp-4) 0;
  border-bottom: 1rpx solid var(--divider);
  color: var(--text-1);
  font-size: var(--fs-body);
}
.menu-item:last-child { border-bottom: none; }
.menu-item-right { display: flex; align-items: center; gap: var(--sp-2); }
.menu-hint { color: var(--text-2); font-size: var(--fs-sub); }
