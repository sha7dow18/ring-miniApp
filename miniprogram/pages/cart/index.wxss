.page { min-height: 100vh; padding-bottom: 140rpx; }
.hover { opacity: 0.65; }

/* 空态 */
.empty { padding: 160rpx 40rpx 40rpx; text-align: center; }
.empty-icon { font-size: 140rpx; opacity: 0.4; }
.empty-title { margin-top: var(--sp-5); font-size: var(--fs-h2); color: var(--text-1); font-weight: var(--fw-bold); }
.empty-desc { margin-top: var(--sp-2); font-size: var(--fs-sub); color: var(--text-2); }
.empty-btn {
  display: inline-block;
  margin-top: var(--sp-6);
  padding: 18rpx 60rpx;
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-pill);
  font-size: var(--fs-sub);
  font-weight: var(--fw-semibold);
}

/* 列表 */
.list { padding: var(--sp-4); }
.item {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: 20rpx;
  margin-bottom: var(--sp-3);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--shadow-card);
  position: relative;
}
.thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--r-lg);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.thumb image { width: 90%; height: 90%; }
.meta { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.name {
  font-size: var(--fs-body);
  color: var(--text-1);
  font-weight: var(--fw-semibold);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.desc {
  font-size: var(--fs-caption);
  color: var(--text-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bottom { margin-top: 6rpx; display: flex; align-items: center; justify-content: space-between; }
.price { font-size: 30rpx; color: var(--accent); font-weight: var(--fw-bold); }

/* Stepper */
.stepper {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: var(--bg-page);
  border-radius: var(--r-pill);
  padding: 4rpx;
}
.step-btn {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-card);
  border-radius: 50%;
  font-size: 30rpx;
  color: var(--brand);
  font-weight: var(--fw-bold);
}
.step-qty { font-size: 26rpx; color: var(--text-1); min-width: 40rpx; text-align: center; }

/* 删除 */
.remove {
  position: absolute;
  top: 14rpx; right: 18rpx;
  width: 40rpx; height: 40rpx;
  font-size: var(--fs-sub);
  color: var(--text-3);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部栏 */
.bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: var(--sp-4) 28rpx;
  padding-bottom: calc(var(--sp-4) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.bar-l { display: flex; align-items: baseline; gap: 14rpx; }
.bar-label { font-size: var(--fs-sub); color: var(--text-2); }
.bar-total { font-size: 40rpx; color: var(--accent); font-weight: var(--fw-bold); }
.bar-btn {
  padding: 22rpx 60rpx;
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-pill);
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
}
