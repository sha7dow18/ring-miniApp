<view class="family-bind-page">
  <block wx:if="{{bound}}">
    <view class="family-hero card">
      <view class="fh-label">我的家庭</view>
      <view class="fh-pair">
        <view class="fh-member">
          <view class="fh-avatar" wx:if="{{myAvatarUrl}}"><image src="{{myAvatarUrl}}" mode="aspectFill"/></view>
          <view class="fh-avatar placeholder" wx:else>{{myInitial}}</view>
          <view class="fh-name">{{myNickname || '我'}}</view>
          <view class="fh-role">{{myRoleLabel}}</view>
        </view>
        <view class="fh-link">🤝</view>
        <view class="fh-member">
          <view class="fh-avatar" wx:if="{{counterpartyAvatarUrl}}"><image src="{{counterpartyAvatarUrl}}" mode="aspectFill"/></view>
          <view class="fh-avatar placeholder" wx:else>{{counterpartyInitial}}</view>
          <view class="fh-name">{{counterpartyNickname || '（未设昵称）'}}</view>
          <view class="fh-role">{{counterpartyRoleLabel}}</view>
        </view>
      </view>
      <view class="fh-meta">绑定于 {{boundAtText || '—'}}</view>
    </view>

    <view class="card">
      <view class="card-title">家庭 ID</view>
      <view class="card-desc">{{boundFamilyId}}</view>
      <view class="card-hint" style="margin-top: 16rpx;">后续健康简报、异常预警、补货提醒都会沿着这个家庭传递。</view>
    </view>
  </block>

  <block wx:if="{{!bound && role === 'elder'}}">
    <view class="card">
      <view class="card-title">生成邀请码</view>
      <view class="card-desc">把这 6 位码告诉你的子女，让他们在"家庭绑定"里输入兑换。</view>

      <view wx:if="{{inviteCode}}" class="code-box">
        <text class="code-text">{{inviteCode}}</text>
        <view class="copy-btn" bindtap="copyCode">复制</view>
      </view>

      <view class="action-row">
        <button class="btn btn-primary" bindtap="generateCode" loading="{{generating}}">
          {{inviteCode ? '重新生成' : '生成邀请码'}}
        </button>
      </view>
    </view>
  </block>

  <block wx:if="{{!bound && role === 'child'}}">
    <view class="card">
      <view class="card-title">输入邀请码</view>
      <view class="card-desc">请父母在老人端生成 6 位邀请码后告诉你。</view>

      <input class="code-input" placeholder="请输入 6 位邀请码" maxlength="6"
             value="{{inputCode}}" bindinput="onInput" />

      <view class="action-row">
        <button class="btn btn-primary" bindtap="redeem" loading="{{redeeming}}"
                disabled="{{inputCode.length !== 6}}">
          兑换绑定
        </button>
      </view>

      <view wx:if="{{errorMsg}}" class="error-msg">{{errorMsg}}</view>
    </view>
  </block>

  <view wx:if="{{!bound && !role}}" class="card">
    <view class="state-title">还没选择角色</view>
    <view class="state-hint">请先去「我的 · 切换角色」选择你是老人还是子女。</view>
  </view>
</view>
