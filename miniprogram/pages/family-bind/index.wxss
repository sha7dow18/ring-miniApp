.family-bind-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--sp-4);
}

.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: var(--sp-5) var(--sp-4);
  box-shadow: 0 2rpx 12rpx rgba(30, 20, 10, 0.04);
}

.card-title {
  font-size: var(--fs-h2);
  font-weight: var(--fw-semibold);
  color: var(--text-1);
}
.card-desc {
  margin-top: var(--sp-2);
  font-size: var(--fs-body);
  color: var(--text-2);
  line-height: 1.6;
}

.code-box {
  margin-top: var(--sp-5);
  padding: var(--sp-4);
  background: linear-gradient(135deg, var(--cream-1), var(--cream-2));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.code-text {
  font-size: 64rpx;
  font-weight: var(--fw-bold);
  letter-spacing: 8rpx;
  color: var(--text-1);
  font-family: "SF Mono", "PingFang SC", monospace;
}
.copy-btn {
  padding: var(--sp-2) var(--sp-3);
  background: var(--brand);
  color: var(--text-inv);
  font-size: var(--fs-sub);
  border-radius: 10rpx;
}

.code-input {
  margin-top: var(--sp-5);
  padding: var(--sp-4);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 40rpx;
  letter-spacing: 8rpx;
  text-align: center;
  background: var(--bg-page);
  text-transform: uppercase;
}

.action-row {
  margin-top: var(--sp-4);
}
.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: var(--fs-body);
  font-weight: var(--fw-medium);
}
.btn-primary {
  background: var(--brand);
  color: var(--text-inv);
}
.btn-primary[disabled] {
  background: var(--bg-muted);
  color: var(--text-3);
}

.error-msg {
  margin-top: var(--sp-3);
  font-size: var(--fs-sub);
  color: var(--danger);
  text-align: center;
}

.state-title {
  font-size: var(--fs-h1);
  font-weight: var(--fw-semibold);
  color: var(--text-1);
}
.state-meta {
  margin-top: var(--sp-3);
  font-size: var(--fs-body);
  color: var(--brand);
  font-family: "SF Mono", monospace;
}
.state-hint {
  margin-top: var(--sp-3);
  font-size: var(--fs-body);
  color: var(--text-2);
  line-height: 1.6;
}

.card-hint {
  font-size: var(--fs-caption);
  color: var(--text-3);
  line-height: 1.6;
}

.family-hero {
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: var(--text-inv);
  padding: var(--sp-5) var(--sp-4);
  margin-bottom: var(--sp-3);
}
.fh-label { font-size: var(--fs-caption); opacity: 0.7; letter-spacing: 2rpx; }
.fh-pair {
  margin-top: var(--sp-4);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.fh-member { flex: 1; text-align: center; }
.fh-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin: 0 auto;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
}
.fh-avatar image { width: 100%; height: 100%; }
.fh-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: var(--fw-bold);
  color: var(--text-inv);
  background: rgba(255, 255, 255, 0.18);
}
.fh-name {
  margin-top: var(--sp-2);
  font-size: var(--fs-h2);
  font-weight: var(--fw-semibold);
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-left: auto;
  margin-right: auto;
}
.fh-role {
  margin-top: 4rpx;
  font-size: var(--fs-caption);
  opacity: 0.7;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
  display: inline-block;
  background: rgba(255, 255, 255, 0.15);
}
.fh-link {
  font-size: 56rpx;
  padding: 0 var(--sp-2);
  opacity: 0.85;
}
.fh-meta {
  margin-top: var(--sp-4);
  text-align: center;
  font-size: var(--fs-caption);
  opacity: 0.7;
}
