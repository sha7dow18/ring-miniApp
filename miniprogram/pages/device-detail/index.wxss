.page { padding: var(--sp-4); }
.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: var(--sp-4);
  box-shadow: var(--shadow-card);
}
.title { font-size: 30rpx; font-weight: var(--fw-bold); color: var(--text-1); margin-bottom: var(--sp-3); }
.desc { color: var(--text-2); font-size: var(--fs-sub); }
.row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
  color: var(--text-1);
  font-size: 23rpx;
}
.row:last-child { border-bottom: none; }
