.page { padding: var(--sp-4); }
.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: var(--sp-4);
  box-shadow: var(--shadow-card);
}
.title { font-size: 30rpx; font-weight: var(--fw-bold); color: var(--text-1); margin-bottom: var(--sp-3); }
.desc { color: var(--text-2); font-size: var(--fs-sub); line-height: 1.7; }
.row {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
  color: var(--text-1);
  font-size: 23rpx;
}
.row:last-child { border-bottom: none; }
.btn-row { margin-top: var(--sp-3); display: flex; flex-direction: column; gap: 10rpx; }
.btn {
  text-align: center;
  padding: 18rpx 0;
  border-radius: var(--r-pill);
  font-size: var(--fs-sub);
  background: var(--brand);
  color: var(--text-inv);
}
.btn.danger { background: #F1D9CD; color: var(--accent); }
