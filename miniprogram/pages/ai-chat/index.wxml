<view class="page">
  <!-- ═══ 历史侧边栏 ═══ -->
  <view class="mask {{showHistory ? 'mask-on' : ''}}" bindtap="closeHistory" catchtouchmove="{{true}}"></view>
  <view class="drawer {{showHistory ? 'drawer-open' : ''}}">
    <view class="drawer-head">
      <view class="drawer-title">聊天记录</view>
      <view class="drawer-new" bindtap="newChat" hover-class="hover">
        <text class="drawer-new-ico">+</text>
        <text>新对话</text>
      </view>
    </view>

    <scroll-view class="drawer-list" scroll-y="true" enhanced show-scrollbar="{{false}}">
      <block wx:for="{{sessionGroups}}" wx:for-item="grp" wx:key="key">
        <view class="grp-label">{{grp.label}}</view>
        <view class="sess {{item._id === sessionId ? 'sess-active' : ''}}"
              wx:for="{{grp.items}}" wx:for-item="item" wx:key="_id"
              data-sid="{{item._id}}" data-title="{{item.title}}"
              bindtap="loadOldSession" bindlongpress="onSessionLongPress"
              hover-class="sess-hover">
          <view class="sess-band band-{{item.tagCls}}"></view>
          <view class="sess-body">
            <view class="sess-title">{{item.title || '对话'}}</view>
            <view class="sess-meta">
              <text class="sess-ago">{{item.ago}}</text>
              <text class="sess-dot" wx:if="{{item.count}}">·</text>
              <text class="sess-count" wx:if="{{item.count}}">{{item.count}} 条</text>
            </view>
          </view>
        </view>
      </block>
      <view class="drawer-empty" wx:if="{{!sessionList.length}}">
        <view class="empty-h">还没有对话</view>
        <view class="empty-sub">聊天会自动存档到这里</view>
      </view>
    </scroll-view>

    <view class="drawer-foot">长按对话可删除 · 仅供健康参考</view>
  </view>

  <!-- ═══ 消息区 ═══ -->
  <scroll-view
    class="msgs"
    scroll-y="true"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 空状态 -->
    <view class="empty" wx:if="{{messages.length === 0}}">
      <view class="empty-logo">Aita</view>
      <view class="empty-h">你好，今天聊什么？</view>
      <scroll-view class="chip-scroll" scroll-x="true" show-scrollbar="{{false}}">
        <view class="chip-row">
          <view class="chip" wx:for="{{quickQuestions}}" wx:key="text" data-q="{{item.text}}" bindtap="useQuickQuestion" hover-class="hover">
            <view class="chip-ico">
              <image src="/assets/icons/inv/{{item.iconName}}.svg" mode="aspectFit" aria-label="{{item.text}}"/>
            </view>
            <text class="chip-txt">{{item.text}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 消息流：user = 右对齐 pill 气泡；assistant = 去气泡化 -->
    <block wx:for="{{messages}}" wx:key="id">
      <view wx:if="{{item.role === 'user'}}" class="msg msg-u" id="msg-{{item.id}}">
        <view class="bbl-u">
          <block wx:for="{{item.parts}}" wx:for-item="p" wx:for-index="pi" wx:key="pi">
            <image
              wx:if="{{p.type === 'image'}}"
              src="{{p.url || p.tempPath}}"
              mode="widthFix"
              class="msg-img msg-img-u"
              bindtap="previewImage"
              data-url="{{p.url || p.tempPath}}"
            />
            <text wx:if="{{p.type === 'text' && p.content}}" class="bbl-txt" selectable="true">{{p.content}}</text>
          </block>
        </view>
      </view>
      <view wx:else class="msg msg-a" id="msg-{{item.id}}">
        <block wx:for="{{item.parts}}" wx:for-item="p" wx:for-index="pi" wx:key="pi">
          <image
            wx:if="{{p.type === 'image'}}"
            src="{{p.url || p.tempPath}}"
            mode="widthFix"
            class="msg-img msg-img-a"
            bindtap="previewImage"
            data-url="{{p.url || p.tempPath}}"
          />
          <!-- markdown 渲染：blocks → 嵌套 wx:for；无 blocks（初始空）降级纯文本 -->
          <view wx:elif="{{p.type === 'thinking'}}" class="thinking-step">
            <view class="thinking-step-head">思考中</view>
            <view class="thinking-step-body">{{p.content}}</view>
          </view>
          <view wx:elif="{{p.type === 'tool'}}" class="tool-step tool-{{p.status}}">
            <view class="tool-step-head">
              <view class="tool-step-label">{{p.label || p.name}}</view>
              <view class="tool-step-state">{{p.status === 'completed' ? '已完成' : '执行中'}}</view>
            </view>
            <view class="tool-step-summary">{{p.summary || '工具执行中…'}}</view>
          </view>
          <view wx:elif="{{p.type === 'card' && p.cardType === 'health-summary'}}" class="agent-card health-card">
            <view class="card-head">
              <view class="card-title">{{p.title}}</view>
              <view class="card-sub">{{p.subtitle}}</view>
            </view>
            <view class="health-metrics">
              <view class="health-metric" wx:for="{{p.metrics}}" wx:key="label">
                <view class="health-label">{{item.label}}</view>
                <view class="health-value tone-{{item.tone}}">{{item.value}}</view>
              </view>
            </view>
          </view>
          <view wx:elif="{{p.type === 'card' && p.cardType === 'product-recommend'}}" class="agent-card product-card">
            <view class="card-head">
              <view class="card-title">{{p.title}}</view>
              <view class="card-sub">{{p.subtitle}}</view>
            </view>
            <view class="product-list">
              <view class="product-item" wx:for="{{p.items}}" wx:key="productId" bindtap="onCardAction" data-type="{{item.primaryAction.type}}" data-product-id="{{item.primaryAction.productId}}" hover-class="hover">
                <image class="product-cover" src="{{item.imagePath}}" mode="aspectFill"/>
                <view class="product-body">
                  <view class="product-top">
                    <text class="product-name">{{item.name}}</text>
                    <text class="product-price">￥{{item.price}}</text>
                  </view>
                  <view class="product-meta">
                    <text class="product-category">{{item.categoryText}}</text>
                    <text class="product-reason">{{item.reason}}</text>
                  </view>
                  <view class="product-actions">
                    <view class="product-action action-ghost" bindtap="onCardAction" catchtap="onCardAction" data-type="{{item.primaryAction.type}}" data-product-id="{{item.primaryAction.productId}}">查看详情</view>
                    <view class="product-action action-solid" bindtap="onCardAction" catchtap="onCardAction" data-type="{{item.secondaryAction.type}}" data-product-id="{{item.secondaryAction.productId}}">加入购物车</view>
                  </view>
                </view>
              </view>
              <view class="product-footer-action" bindtap="onCardAction" data-type="{{p.footerAction.type}}" hover-class="hover">去商城查看更多</view>
            </view>
          </view>
          <view wx:elif="{{p.type === 'text' && p.blocks && p.blocks.length}}" class="md">
            <block wx:for="{{p.blocks}}" wx:for-item="blk" wx:for-index="bi" wx:key="bi">
              <view wx:if="{{blk.type === 'p'}}" class="md-p">
                <text wx:for="{{blk.runs}}" wx:for-item="r" wx:for-index="ri" wx:key="ri" class="md-{{r.t}}" selectable="true">{{r.c}}</text>
              </view>
              <view wx:elif="{{blk.type === 'h'}}" class="md-h md-h{{blk.level}}">
                <text wx:for="{{blk.runs}}" wx:for-item="r" wx:for-index="ri" wx:key="ri" class="md-{{r.t}}" selectable="true">{{r.c}}</text>
              </view>
              <view wx:elif="{{blk.type === 'ul'}}" class="md-ul">
                <view class="md-li" wx:for="{{blk.items}}" wx:for-item="it" wx:for-index="ii" wx:key="ii">
                  <text class="md-bullet">•</text>
                  <view class="md-li-body">
                    <text wx:for="{{it.runs}}" wx:for-item="r" wx:for-index="ri" wx:key="ri" class="md-{{r.t}}" selectable="true">{{r.c}}</text>
                  </view>
                </view>
              </view>
              <view wx:elif="{{blk.type === 'ol'}}" class="md-ol">
                <view class="md-li" wx:for="{{blk.items}}" wx:for-item="it" wx:for-index="ii" wx:key="ii">
                  <text class="md-num">{{ii + 1}}.</text>
                  <view class="md-li-body">
                    <text wx:for="{{it.runs}}" wx:for-item="r" wx:for-index="ri" wx:key="ri" class="md-{{r.t}}" selectable="true">{{r.c}}</text>
                  </view>
                </view>
              </view>
              <view wx:elif="{{blk.type === 'hr'}}" class="md-hr"></view>
              <scroll-view wx:elif="{{blk.type === 'table'}}" class="md-table-wrap" scroll-x="true" show-scrollbar="false">
                <view class="md-table">
                  <view class="md-tr md-tr-head">
                    <view class="md-th" wx:for="{{blk.headers}}" wx:for-item="cell" wx:key="raw">
                      <text wx:for="{{cell.runs}}" wx:for-item="r" wx:for-index="ri" wx:key="ri" class="md-{{r.t}}">{{r.c}}</text>
                    </view>
                  </view>
                  <view class="md-tr" wx:for="{{blk.rows}}" wx:for-item="row" wx:for-index="ri" wx:key="ri">
                    <view class="md-td" wx:for="{{row}}" wx:for-item="cell" wx:key="raw">
                      <text wx:for="{{cell.runs}}" wx:for-item="r" wx:for-index="rj" wx:key="rj" class="md-{{r.t}}">{{r.c}}</text>
                    </view>
                  </view>
                </view>
              </scroll-view>
            </block>
          </view>
          <text wx:elif="{{p.type === 'text' && p.content}}" class="ai-txt" selectable="true">{{p.content}}</text>
        </block>
      </view>
    </block>

    <view id="scroll-anchor" style="height:24rpx;"></view>
  </scroll-view>

  <!-- ═══ Composer ═══ -->
  <view class="foot">
    <!-- 附件缩略 chip -->
    <view class="att-row" wx:if="{{attachment || isUploading}}">
      <view class="att-chip" wx:if="{{attachment}}">
        <image class="att-chip-img" src="{{attachment.tempPath}}" mode="aspectFill" bindtap="previewAttachment"/>
        <view class="att-x" bindtap="removeAttachment" hover-class="hover">✕</view>
      </view>
      <text class="att-loading" wx:if="{{isUploading}}">正在上传…</text>
    </view>

    <view class="bar">
      <view class="bar-btn" bindtap="toggleHistory" hover-class="hover" aria-label="历史记录">
        <image src="/assets/icons/menu.svg" mode="aspectFit"/>
      </view>
      <view class="bar-btn" bindtap="chooseImage" hover-class="hover" aria-label="上传图片">
        <image src="/assets/icons/camera.svg" mode="aspectFit"/>
      </view>
      <input
        class="bar-input"
        value="{{inputText}}"
        bindinput="onInput"
        placeholder="{{attachment ? '补充描述…' : '说点什么'}}"
        confirm-type="send"
        bindconfirm="doSend"
        disabled="{{isSending}}"
        adjust-position="{{true}}"
        cursor-spacing="16"
      />
      <view class="bar-send {{canSend ? '' : 'bar-off'}}" bindtap="doSend" hover-class="hover" aria-label="发送">
        <image src="/assets/icons/inv/send.svg" mode="aspectFit"/>
      </view>
    </view>
  </view>
</view>
