<view class="page">
  <!-- ═══ 历史侧边栏 ═══ -->
  <view class="mask" wx:if="{{showHistory}}" bindtap="closeHistory" catchtouchmove="{{true}}"></view>
  <view class="drawer {{showHistory ? 'drawer-open' : ''}}">
    <view class="drawer-head">
      <text class="drawer-title">聊天记录</text>
      <view class="drawer-new" bindtap="newChat" hover-class="hover">+ 新对话</view>
    </view>
    <scroll-view class="drawer-list" scroll-y="true">
      <view class="drawer-item {{item._id === sessionId ? 'drawer-active' : ''}}" wx:for="{{sessionList}}" wx:key="_id" data-sid="{{item._id}}" bindtap="loadOldSession">
        <text class="drawer-tag tag-{{item.tagCls}}" wx:if="{{item.tag}}">{{item.tag}}</text>
        <text class="drawer-item-txt">{{item.title || '对话'}}</text>
      </view>
      <view class="drawer-empty" wx:if="{{!sessionList.length}}">暂无记录</view>
    </scroll-view>
    <view class="drawer-foot">仅供健康参考 · 不替代医疗诊断</view>
  </view>

  <!-- ═══ 消息区 ═══ -->
  <scroll-view
    class="msgs"
    scroll-y="true"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 空状态 -->
    <view class="empty" wx:if="{{messages.length === 0}}">
      <view class="empty-logo">Aita</view>
      <view class="empty-h">你好，今天聊什么？</view>
      <scroll-view class="chip-scroll" scroll-x="true" show-scrollbar="{{false}}">
        <view class="chip-row">
          <view class="chip" wx:for="{{quickQuestions}}" wx:key="text" data-q="{{item.text}}" bindtap="useQuickQuestion" hover-class="hover">
            <view class="chip-ico">
              <image src="/assets/icons/inv/{{item.iconName}}.svg" mode="aspectFit" aria-label="{{item.text}}"/>
            </view>
            <text class="chip-txt">{{item.text}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 气泡 -->
    <block wx:for="{{messages}}" wx:key="id">
      <view class="row {{item.role === 'user' ? 'row-r' : 'row-l'}}" id="msg-{{item.id}}">
        <view class="ava" wx:if="{{item.role !== 'user'}}">A</view>
        <view class="bbl {{item.role === 'user' ? 'bbl-u' : 'bbl-a'}}">
          <block wx:for="{{item.parts}}" wx:for-item="p" wx:for-index="pi" wx:key="pi">
            <image
              wx:if="{{p.type === 'image'}}"
              src="{{p.url || p.tempPath}}"
              mode="widthFix"
              class="bbl-img"
              bindtap="previewImage"
              data-url="{{p.url || p.tempPath}}"
            />
            <text wx:if="{{p.type === 'text' && p.content}}" class="bbl-txt" selectable="true">{{p.content}}</text>
          </block>
        </view>
      </view>
    </block>

    <view id="scroll-anchor" style="height:24rpx;"></view>
  </scroll-view>

  <!-- ═══ Composer ═══ -->
  <view class="foot">
    <!-- 附件预览 -->
    <view class="att" wx:if="{{attachment}}">
      <image class="att-img" src="{{attachment.tempPath}}" mode="widthFix" bindtap="previewAttachment"/>
      <view class="att-x" bindtap="removeAttachment" hover-class="hover">✕</view>
    </view>
    <view class="att-loading" wx:if="{{isUploading}}">正在上传…</view>

    <view class="bar">
      <view class="bar-btn" bindtap="toggleHistory" hover-class="hover" aria-label="历史记录">
        <image src="/assets/icons/menu.svg" mode="aspectFit"/>
      </view>
      <view class="bar-btn" bindtap="chooseImage" hover-class="hover" aria-label="上传图片">
        <image src="/assets/icons/camera.svg" mode="aspectFit"/>
      </view>
      <input
        class="bar-input"
        value="{{inputText}}"
        bindinput="onInput"
        placeholder="{{attachment ? '补充描述…' : '说点什么'}}"
        confirm-type="send"
        bindconfirm="doSend"
        disabled="{{isSending}}"
        adjust-position="{{true}}"
        cursor-spacing="16"
      />
      <view class="bar-send {{canSend ? '' : 'bar-off'}}" bindtap="doSend" hover-class="hover" aria-label="发送">
        <image src="/assets/icons/inv/send.svg" mode="aspectFit"/>
      </view>
    </view>
  </view>
</view>
