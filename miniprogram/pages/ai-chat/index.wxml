<view class="page">
  <!-- ═══ 顶栏 ═══ -->
  <view class="nav">
    <view class="nav-btn" bindtap="toggleHistory" hover-class="hover">
      <text class="nav-ico">☰</text>
    </view>
    <text class="nav-title">AI 健康助手</text>
    <view class="nav-btn" bindtap="newChat" hover-class="hover">
      <text class="nav-ico">✎</text>
    </view>
  </view>

  <!-- ═══ 历史侧边栏 ═══ -->
  <view class="mask" wx:if="{{showHistory}}" bindtap="closeHistory" catchtouchmove="{{true}}"></view>
  <view class="drawer {{showHistory ? 'drawer-open' : ''}}">
    <view class="drawer-head">
      <text class="drawer-title">聊天记录</text>
      <view class="drawer-new" bindtap="newChat" hover-class="hover">+ 新对话</view>
    </view>
    <scroll-view class="drawer-list" scroll-y="true">
      <view class="drawer-item {{item._id === sessionId ? 'drawer-active' : ''}}" wx:for="{{sessionList}}" wx:key="_id" data-sid="{{item._id}}" bindtap="loadOldSession">
        <text class="drawer-tag tag-{{item.tagCls}}" wx:if="{{item.tag}}">{{item.tag}}</text>
        <text class="drawer-item-txt">{{item.title || '对话'}}</text>
      </view>
      <view class="drawer-empty" wx:if="{{!sessionList.length}}">暂无记录</view>
    </scroll-view>
  </view>

  <!-- ═══ 消息区 ═══ -->
  <scroll-view
    class="msgs"
    scroll-y="true"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 空状态欢迎 -->
    <view class="empty" wx:if="{{messages.length === 0}}">
      <view class="empty-logo">Aita</view>
      <view class="empty-h">你好，有什么可以帮你？</view>
      <view class="empty-p">文字问答 · 舌诊照片 · 体质截图</view>
      <view class="cards">
        <view class="card" wx:for="{{quickQuestions}}" wx:key="text" data-q="{{item.text}}" bindtap="useQuickQuestion" hover-class="hover">
          <text class="card-ico">{{item.icon}}</text>
          <text class="card-txt">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 气泡 -->
    <block wx:for="{{messages}}" wx:key="id">
      <view class="row {{item.role === 'user' ? 'row-r' : 'row-l'}}" id="msg-{{item.id}}">
        <!-- AI 头像 -->
        <view class="ava" wx:if="{{item.role !== 'user'}}">A</view>
        <!-- 气泡体 -->
        <view class="bbl {{item.role === 'user' ? 'bbl-u' : 'bbl-a'}}">
          <block wx:for="{{item.parts}}" wx:for-item="p" wx:for-index="pi" wx:key="pi">
            <image
              wx:if="{{p.type === 'image'}}"
              src="{{p.url || p.tempPath}}"
              mode="widthFix"
              class="bbl-img"
              bindtap="previewImage"
              data-url="{{p.url || p.tempPath}}"
            />
            <text wx:if="{{p.type === 'text' && p.content}}" class="bbl-txt" selectable="true">{{p.content}}</text>
          </block>
        </view>
      </view>
    </block>

    <view id="scroll-anchor" style="height:24rpx;"></view>
  </scroll-view>

  <!-- ═══ 底部输入区 ═══ -->
  <view class="foot">
    <!-- 附件预览 -->
    <view class="att" wx:if="{{attachment}}">
      <image class="att-img" src="{{attachment.tempPath}}" mode="widthFix" bindtap="previewAttachment"/>
      <view class="att-x" bindtap="removeAttachment" hover-class="hover">✕</view>
    </view>
    <!-- 上传状态 -->
    <view class="att-loading" wx:if="{{isUploading}}">正在上传...</view>
    <!-- 输入行 -->
    <view class="bar">
      <view class="bar-plus" bindtap="chooseImage" hover-class="hover">
        <text>+</text>
      </view>
      <input
        class="bar-input"
        value="{{inputText}}"
        bindinput="onInput"
        placeholder="{{attachment ? '添加描述...' : '输入问题或上传图片'}}"
        confirm-type="send"
        bindconfirm="doSend"
        disabled="{{isSending}}"
        adjust-position="{{true}}"
        cursor-spacing="16"
      />
      <view class="bar-send {{isSending ? 'bar-off' : ''}}" bindtap="doSend" hover-class="hover">
        <text>发送</text>
      </view>
    </view>
    <view class="bar-tip">仅供健康参考 · 不替代医疗诊断</view>
  </view>
</view>
