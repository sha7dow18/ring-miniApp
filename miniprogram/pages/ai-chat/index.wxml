<view class="chat-page">
  <view class="chat-main">
    <view class="chat-top">
      <view class="chat-title">AI 健康助手</view>
      <view class="chat-tip">支持文字问答和舌诊/体质图片分析。仅供健康参考。</view>
      <view class="clear" bindtap="clearConversation">清空对话</view>
    </view>

    <view class="quick-row">
      <view class="quick-item" wx:for="{{quickQuestions}}" wx:key="*this" data-q="{{item}}" bindtap="useQuickQuestion">{{item}}</view>
    </view>

    <scroll-view class="chat-list" scroll-y="true" scroll-into-view="{{scrollToId}}" scroll-with-animation>
      <block wx:for="{{messageList}}" wx:key="id">
        <view class="msg-row {{item.role === 'user' ? 'right' : 'left'}}" id="msg-{{item.id}}">
          <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'ai-bubble'}}">
            <!-- 图片消息 -->
            <image wx:if="{{item.type === 'image'}}" src="{{item.imagePath || item.imageUrl || item.content}}" mode="widthFix" class="chat-image" bindtap="previewImage" data-src="{{item.imagePath || item.imageUrl || item.content}}"/>
            <!-- 文字消息 -->
            <text wx:else>{{item.content}}</text>
          </view>
        </view>
      </block>
      <view style="height: 30rpx;"></view>
    </scroll-view>

    <view class="input-bar">
      <view class="img-btn" bindtap="chooseImage">
        <text class="img-icon">📷</text>
      </view>
      <input class="text-input" value="{{inputText}}" bindinput="onInput" placeholder="输入问题，或上传舌诊/体质截图" confirm-type="send" bindconfirm="sendText" disabled="{{isSending}}"/>
      <view class="send {{isSending ? 'send-disabled' : ''}}" bindtap="sendText">发送</view>
    </view>
  </view>
</view>
