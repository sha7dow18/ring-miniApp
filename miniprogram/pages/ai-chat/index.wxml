<view class="chat-page">
  <!-- ── 顶栏 ── -->
  <view class="top-bar">
    <view class="top-left" bindtap="toggleHistory" hover-class="tap-dim">
      <text class="icon-history">☰</text>
      <text class="top-label">历史</text>
    </view>
    <text class="top-title">AI 健康助手</text>
    <view class="top-right" bindtap="newChat" hover-class="tap-dim">
      <text class="top-label">新对话</text>
      <text class="icon-new">+</text>
    </view>
  </view>

  <!-- ── 历史侧边栏 ── -->
  <view class="mask" wx:if="{{showHistory}}" bindtap="closeHistory"></view>
  <view class="sidebar {{showHistory ? 'sidebar-show' : ''}}">
    <view class="sidebar-title">聊天记录</view>
    <view class="sidebar-item" wx:for="{{sessionList}}" wx:key="_id" data-sid="{{item._id}}" bindtap="loadOldSession">
      <text class="sidebar-text">{{item.title || '对话'}}</text>
    </view>
    <view class="sidebar-empty" wx:if="{{!sessionList.length}}">暂无历史记录</view>
  </view>

  <!-- ── 消息列表 ── -->
  <scroll-view class="chat-list" scroll-y="true" scroll-into-view="{{scrollToId}}" scroll-with-animation enhanced show-scrollbar="{{false}}">
    <!-- 欢迎区：只在空对话时显示 -->
    <view class="welcome" wx:if="{{messages.length === 0}}">
      <view class="welcome-logo">Aita</view>
      <view class="welcome-title">你好，有什么可以帮你？</view>
      <view class="welcome-sub">支持文字问答、舌诊照片分析、体质截图分析</view>
      <view class="quick-grid">
        <view class="quick-card" wx:for="{{quickQuestions}}" wx:key="text" data-q="{{item.text}}" bindtap="useQuickQuestion">
          <text class="qc-icon">{{item.icon}}</text>
          <text class="qc-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 消息气泡 -->
    <block wx:for="{{messages}}" wx:key="id">
      <view class="msg-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}" id="msg-{{item.id}}">
        <view class="avatar" wx:if="{{item.role !== 'user'}}">A</view>
        <view class="bubble {{item.role === 'user' ? 'b-user' : 'b-ai'}}">
          <!-- 遍历 parts -->
          <block wx:for="{{item.parts}}" wx:for-item="part" wx:key="type">
            <image
              wx:if="{{part.type === 'image'}}"
              src="{{part.url || part.tempPath}}"
              mode="widthFix"
              class="part-img"
              bindtap="previewImage"
              data-url="{{part.url || part.tempPath}}"
            />
            <text wx:if="{{part.type === 'text' && part.content}}" selectable="true" class="part-text">{{part.content}}</text>
          </block>
        </view>
      </view>
    </block>
    <view class="scroll-end" id="scroll-end"></view>
  </scroll-view>

  <!-- ── 底部输入区 ── -->
  <view class="input-area">
    <!-- 附件预览（选图后、发送前） -->
    <view class="att-preview" wx:if="{{attachment}}">
      <image class="att-thumb" src="{{attachment.tempPath}}" mode="widthFix"/>
      <view class="att-info">
        <text class="att-label">已选择图片</text>
        <text class="att-hint">点发送一起提交，或输入文字描述</text>
      </view>
      <view class="att-remove" bindtap="removeAttachment" hover-class="tap-dim">✕</view>
    </view>
    <!-- 上传中提示 -->
    <view class="att-uploading" wx:if="{{isUploading}}">
      <text>正在上传图片...</text>
    </view>
    <!-- 输入行 -->
    <view class="input-row">
      <view class="btn-add" bindtap="chooseImage" hover-class="tap-dim">
        <text>+</text>
      </view>
      <input
        class="msg-input"
        value="{{inputText}}"
        bindinput="onInput"
        placeholder="{{attachment ? '可输入描述，或直接发送' : '输入问题，或上传图片...'}}"
        confirm-type="send"
        bindconfirm="doSend"
        disabled="{{isSending}}"
        cursor-spacing="16"
      />
      <view class="btn-send {{isSending ? 'btn-off' : ''}}" bindtap="doSend" hover-class="tap-dim">
        <text>发送</text>
      </view>
    </view>
    <view class="input-hint">仅供健康参考 · 不替代医疗诊断</view>
  </view>
</view>
