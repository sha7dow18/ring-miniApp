/*
 * AI Chat — 聊天界面（推倒重设）
 * 原生 navigationBar 提供标题，页面内不再写 header
 */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hover { opacity: 0.65; }

/* ═══ 历史抽屉 ═══ */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 100;
}
.drawer {
  position: fixed; top: 0; bottom: 0;
  left: -82vw;
  width: 82vw;
  background: var(--bg-page);
  z-index: 101;
  transition: left 0.28s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 24rpx rgba(0,0,0,0.12);
}
.drawer-open { left: 0; }
.drawer-head {
  padding: 120rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.drawer-title { font-size: var(--fs-h1); font-weight: var(--fw-bold); color: var(--text-1); }
.drawer-new {
  align-self: flex-start;
  font-size: var(--fs-sub);
  color: var(--text-inv);
  font-weight: var(--fw-semibold);
  padding: 14rpx 28rpx;
  background: var(--brand);
  border-radius: var(--r-pill);
}
.drawer-list { flex: 1; padding: 0 28rpx 20rpx; }
.drawer-item {
  padding: var(--sp-4) 18rpx;
  border-radius: var(--r-md);
  margin-bottom: var(--sp-2);
  font-size: var(--fs-body);
  color: var(--text-1);
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-card);
}
.drawer-active { background: var(--bg-muted); }
.drawer-empty { font-size: 26rpx; color: var(--text-3); text-align: center; margin-top: 80rpx; }

/* 会话 tag 徽章 */
.drawer-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--r-pill);
  flex-shrink: 0;
  font-weight: var(--fw-semibold);
  background: var(--bg-muted);
  color: var(--text-2);
}
.drawer-tag.tag-tongue { background: #FCE4D6; color: var(--accent); }
.drawer-tag.tag-sleep { background: #D6E4FC; color: var(--info); }
.drawer-tag.tag-constitution { background: #E4FCD6; color: var(--success); }
.drawer-item-txt { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.drawer-foot {
  padding: 24rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 20rpx;
  color: var(--text-3);
  border-top: 1rpx solid var(--divider);
  letter-spacing: 1rpx;
}

/* ═══ 消息区 ═══ */
.msgs {
  flex: 1;
  padding: 20rpx 28rpx 0;
  box-sizing: border-box;
}

/* ── 空状态（轻量） ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 24rpx;
}
.empty-logo {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  color: var(--text-inv);
  font-size: 30rpx; font-weight: var(--fw-bold);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(42,74,62,0.25);
}
.empty-h {
  margin-top: 24rpx;
  font-size: var(--fs-h1);
  font-weight: var(--fw-bold);
  color: var(--text-1);
}

/* 横滑 chip 建议 */
.chip-scroll {
  margin-top: 36rpx;
  width: 100%;
  white-space: nowrap;
}
.chip-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx;
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 22rpx 12rpx 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 103, 50, 0.08);
}
.chip-ico {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.chip-ico image { width: 30rpx; height: 30rpx; }
.chip-txt { font-size: 26rpx; color: var(--text-1); font-weight: var(--fw-semibold); }

/* ═══ 消息行 ═══ */
.row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: var(--sp-4);
}
.row-l { justify-content: flex-start; }
.row-r { justify-content: flex-end; }

.ava {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  color: var(--text-inv);
  font-size: var(--fs-sub); font-weight: var(--fw-bold);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.bbl {
  max-width: 74%;
  border-radius: var(--r-card);
  padding: 18rpx 22rpx;
}
.bbl-a {
  background: var(--bg-card);
  color: var(--text-1);
  border-top-left-radius: 6rpx;
  border: 1rpx solid var(--divider);
}
.bbl-u {
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  color: var(--text-1);
  border-top-right-radius: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(139, 103, 50, 0.08);
}

.bbl-txt {
  font-size: 30rpx;
  line-height: 1.7;
  word-break: break-word;
  display: block;
}
.bbl-img {
  width: 100%;
  max-width: 400rpx;
  border-radius: var(--r-md);
  margin-bottom: 10rpx;
  display: block;
}
.bbl-u .bbl-img { max-width: 320rpx; }

/* ═══ Composer ═══ */
.foot {
  background: var(--bg-page);
  padding: 14rpx var(--sp-4);
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom) + 100rpx);
  border-top: 1rpx solid var(--divider);
  flex-shrink: 0;
}

.att {
  position: relative;
  margin-bottom: 14rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
}
.att-img { width: 100%; max-height: 360rpx; display: block; }
.att-x {
  position: absolute; top: 14rpx; right: 14rpx;
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: var(--text-inv);
  font-size: 30rpx;
  display: flex; align-items: center; justify-content: center;
}
.att-loading {
  text-align: center;
  font-size: var(--fs-sub); color: var(--text-2);
  padding: 10rpx 0;
}

.bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.bar-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bar-btn image { width: 36rpx; height: 36rpx; }
.bar-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.bar-send {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--brand);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(47,74,66,0.25);
}
.bar-send image { width: 34rpx; height: 34rpx; }
.bar-off { opacity: 0.3; box-shadow: none; }
