/*
 * AI Chat — 聊天界面
 * 所有 token 已迁移到全局 tokens.wxss，本文件只保留聊天特有样式
 */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hover { opacity: 0.65; }

/* ═══ 顶栏 ═══ */
.nav {
  height: 96rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-page);
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}
.nav-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-ico { font-size: 38rpx; color: var(--brand); }
.nav-title { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--text-1); }

/* ═══ 历史抽屉 ═══ */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 100;
}
.drawer {
  position: fixed; top: 0; bottom: 0;
  left: -75vw;
  width: 75vw;
  background: #FAF6F0;
  z-index: 101;
  transition: left 0.28s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  flex-direction: column;
}
.drawer-open { left: 0; }
.drawer-head {
  padding: 100rpx 28rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.drawer-title { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--text-1); }
.drawer-new {
  font-size: var(--fs-sub);
  color: var(--brand);
  font-weight: var(--fw-semibold);
  padding: 10rpx 18rpx;
  border: 2rpx solid var(--brand);
  border-radius: var(--r-pill);
}
.drawer-list { flex: 1; padding: 0 28rpx 40rpx; }
.drawer-item {
  padding: var(--sp-4) 18rpx;
  border-radius: var(--r-md);
  margin-bottom: var(--sp-2);
  font-size: var(--fs-body);
  color: var(--text-1);
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.drawer-active { background: var(--bg-muted); }
.drawer-item:not(.drawer-active) { background: var(--bg-card); }
.drawer-empty { font-size: 26rpx; color: var(--text-3); text-align: center; margin-top: 80rpx; }

/* ── 会话 tag 徽章（状态色保留变体）── */
.drawer-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--r-pill);
  flex-shrink: 0;
  font-weight: var(--fw-semibold);
  background: var(--bg-muted);
  color: var(--text-2);
}
.drawer-tag.tag-tongue { background: #FCE4D6; color: var(--accent); }
.drawer-tag.tag-sleep { background: #D6E4FC; color: var(--info); }
.drawer-tag.tag-constitution { background: #E4FCD6; color: var(--success); }
.drawer-item-txt { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ═══ 消息区 ═══ */
.msgs {
  flex: 1;
  padding: 20rpx 28rpx 0;
  box-sizing: border-box;
}

/* ── 空状态 ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}
.empty-logo {
  width: 104rpx; height: 104rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  color: var(--text-inv);
  font-size: 30rpx; font-weight: var(--fw-bold);
  display: flex; align-items: center; justify-content: center;
}
.empty-h { margin-top: var(--sp-4); font-size: var(--fs-h1); font-weight: var(--fw-bold); color: var(--text-1); }
.empty-p { margin-top: var(--sp-2); font-size: 26rpx; color: var(--text-3); }

/* ── 快捷卡片 ── */
.cards {
  margin-top: 36rpx;
  width: 100%;
  display: flex; flex-wrap: wrap; gap: var(--sp-3);
  padding: 0 4rpx;
  box-sizing: border-box;
}
.card {
  flex: 1 1 44%;
  min-width: 260rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  border-radius: var(--r-lg);
  padding: 22rpx 18rpx;
  display: flex; align-items: center; gap: 14rpx;
}
.card-ico { font-size: var(--fs-h2); flex-shrink: 0; }
.card-txt { font-size: 26rpx; color: var(--text-1); line-height: 1.5; }

/* ═══ 消息行 ═══ */
.row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: var(--sp-4);
}
.row-l { justify-content: flex-start; }
.row-r { justify-content: flex-end; }

/* ── AI 头像（渐变保留 + token 化 stop）── */
.ava {
  width: 64rpx; height: 64rpx;
  border-radius: var(--r-lg);
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  color: var(--text-inv);
  font-size: var(--fs-sub); font-weight: var(--fw-bold);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* ── 气泡 ── */
.bbl {
  max-width: 74%;
  border-radius: var(--r-card);
  padding: 20rpx var(--sp-4);
}
.bbl-a {
  background: var(--bg-card);
  color: var(--text-1);
  border-top-left-radius: 6rpx;
  box-shadow: var(--shadow-card);
}
.bbl-u {
  background: var(--brand);
  color: var(--text-inv);
  border-top-right-radius: 6rpx;
}

/* ── Parts ── */
.bbl-txt {
  font-size: 30rpx;
  line-height: 1.75;
  word-break: break-word;
  display: block;
}
.bbl-img {
  width: 100%;
  max-width: 400rpx;
  border-radius: var(--r-md);
  margin-bottom: 10rpx;
  display: block;
}
.bbl-u .bbl-img { max-width: 320rpx; }

/* ═══ 底部输入区 ═══ */
.foot {
  background: var(--bg-page);
  padding: 12rpx var(--sp-4);
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom) + 100rpx);
  border-top: 1rpx solid var(--border);
  flex-shrink: 0;
}

/* ── 附件预览 ── */
.att {
  position: relative;
  margin-bottom: 14rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
}
.att-img {
  width: 100%;
  max-height: 360rpx;
  display: block;
}
.att-x {
  position: absolute; top: 14rpx; right: 14rpx;
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: var(--text-inv);
  font-size: 30rpx;
  display: flex; align-items: center; justify-content: center;
}
.att-loading {
  text-align: center;
  font-size: var(--fs-sub); color: var(--text-2);
  padding: 10rpx 0;
}

/* ── 输入行 ── */
.bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.bar-plus {
  width: 76rpx; height: 76rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: 40rpx; color: var(--text-2); font-weight: 300;
}
.bar-input {
  flex: 1;
  height: 76rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  border-radius: 38rpx;
  padding: 0 26rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
.bar-send {
  height: 76rpx;
  border-radius: 38rpx;
  background: var(--brand);
  color: var(--text-inv);
  font-size: var(--fs-body); font-weight: var(--fw-semibold);
  padding: 0 30rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bar-off { opacity: 0.35; }
.bar-tip {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-3);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}
