/*
 * AI Chat — 聊天界面（推倒重设）
 * 原生 navigationBar 提供标题，页面内不再写 header
 */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hover { opacity: 0.65; }

/* ═══ 历史抽屉 ═══ */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 100;
}
.drawer {
  position: fixed; top: 0; bottom: 0;
  left: -82vw;
  width: 82vw;
  background: var(--bg-page);
  z-index: 101;
  transition: left 0.28s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 24rpx rgba(0,0,0,0.12);
}
.drawer-open { left: 0; }
.drawer-head {
  padding: 120rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.drawer-title { font-size: var(--fs-h1); font-weight: var(--fw-bold); color: var(--text-1); }
.drawer-new {
  align-self: flex-start;
  font-size: var(--fs-sub);
  color: var(--text-inv);
  font-weight: var(--fw-semibold);
  padding: 14rpx 28rpx;
  background: var(--brand);
  border-radius: var(--r-pill);
}
.drawer-list { flex: 1; padding: 0 28rpx 20rpx; }
.drawer-item {
  padding: var(--sp-4) 18rpx;
  border-radius: var(--r-md);
  margin-bottom: var(--sp-2);
  font-size: var(--fs-body);
  color: var(--text-1);
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-card);
}
.drawer-active { background: var(--bg-muted); }
.drawer-empty { font-size: 26rpx; color: var(--text-3); text-align: center; margin-top: 80rpx; }

/* 会话 tag 徽章 */
.drawer-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--r-pill);
  flex-shrink: 0;
  font-weight: var(--fw-semibold);
  background: var(--bg-muted);
  color: var(--text-2);
}
.drawer-tag.tag-tongue { background: #FCE4D6; color: var(--accent); }
.drawer-tag.tag-sleep { background: #D6E4FC; color: var(--info); }
.drawer-tag.tag-constitution { background: #E4FCD6; color: var(--success); }
.drawer-item-txt { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.drawer-foot {
  padding: 24rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 20rpx;
  color: var(--text-3);
  border-top: 1rpx solid var(--divider);
  letter-spacing: 1rpx;
}

/* ═══ 消息区 ═══ */
.msgs {
  flex: 1;
  padding: 20rpx 28rpx 0;
  box-sizing: border-box;
}

/* ── 空状态（轻量） ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 24rpx;
}
.empty-logo {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  color: var(--text-inv);
  font-size: 30rpx; font-weight: var(--fw-bold);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(42,74,62,0.25);
}
.empty-h {
  margin-top: 24rpx;
  font-size: var(--fs-h1);
  font-weight: var(--fw-bold);
  color: var(--text-1);
}

/* 横滑 chip 建议 */
.chip-scroll {
  margin-top: 36rpx;
  width: 100%;
  white-space: nowrap;
}
.chip-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx;
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 22rpx 12rpx 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 103, 50, 0.08);
}
.chip-ico {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.chip-ico image { width: 30rpx; height: 30rpx; }
.chip-txt { font-size: 26rpx; color: var(--text-1); font-weight: var(--fw-semibold); }

/* ═══ 消息流（ChatGPT 范式：user 气泡；AI 无气泡） ═══ */
.msg { margin-bottom: 32rpx; }

/* 用户：右对齐紧凑 cream pill */
.msg-u { display: flex; justify-content: flex-end; }
.bbl-u {
  max-width: 70%;
  padding: 14rpx 22rpx;
  border-radius: 28rpx;
  border-top-right-radius: 8rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  color: var(--text-1);
  box-shadow: 0 4rpx 12rpx rgba(139, 103, 50, 0.08);
}
.bbl-txt {
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-word;
  display: block;
}

/* AI：无气泡，文本直接在页面 bg 上 */
.msg-a { padding: 0 4rpx; }
.ai-txt {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-1);
  word-break: break-word;
}

/* towxml markdown 渲染区，主题 override 到养生土色系 */
.ai-md { font-size: 30rpx; color: var(--text-1); }
.ai-md .h2w-light { background: transparent !important; color: var(--text-1) !important; }
.ai-md .h2w__p {
  font-size: 30rpx !important;
  line-height: 1.8 !important;
  color: var(--text-1) !important;
  margin: 0 0 16rpx !important;
}
.ai-md .h2w__h1, .ai-md .h2w__h2, .ai-md .h2w__h3 {
  color: var(--text-1) !important;
  font-weight: var(--fw-bold) !important;
  margin: 20rpx 0 12rpx !important;
  border: none !important;
}
.ai-md .h2w__h1 { font-size: 38rpx !important; }
.ai-md .h2w__h2 { font-size: 34rpx !important; }
.ai-md .h2w__h3 { font-size: 30rpx !important; }
.ai-md .h2w__strong { color: var(--brand-dark) !important; font-weight: var(--fw-bold) !important; }
.ai-md .h2w__em { color: var(--text-1) !important; font-style: italic !important; }
.ai-md .h2w__code {
  background: var(--bg-muted) !important;
  color: var(--accent) !important;
  padding: 2rpx 10rpx !important;
  border-radius: 6rpx !important;
  font-size: 28rpx !important;
}
.ai-md .h2w__pre {
  background: var(--bg-muted) !important;
  border-radius: var(--r-md) !important;
  padding: 16rpx !important;
  margin: 12rpx 0 !important;
}
.ai-md .h2w__ul, .ai-md .h2w__ol { padding-left: 36rpx !important; margin: 10rpx 0 !important; }
.ai-md .h2w__li { margin: 6rpx 0 !important; line-height: 1.75 !important; color: var(--text-1) !important; }
.ai-md .h2w__blockquote {
  border-left: 6rpx solid var(--brand) !important;
  background: var(--bg-muted) !important;
  padding: 12rpx 18rpx !important;
  margin: 12rpx 0 !important;
  color: var(--text-2) !important;
}
.ai-md .h2w__a { color: var(--brand) !important; text-decoration: underline; }
.ai-md .h2w__table { margin: 12rpx 0 !important; }
.ai-md .h2w__thead .h2w__tr { background: var(--bg-muted) !important; }
.ai-md .h2w__th, .ai-md .h2w__td { border-color: var(--divider) !important; color: var(--text-1) !important; }

/* 消息内图片 */
.msg-img {
  display: block;
  max-width: 280rpx;
  border-radius: var(--r-md);
  margin-bottom: 10rpx;
}
.msg-img-u { max-width: 260rpx; }

/* ═══ Composer ═══ */
.foot {
  background: var(--bg-page);
  padding: 14rpx var(--sp-4);
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom) + 100rpx);
  border-top: 1rpx solid var(--divider);
  flex-shrink: 0;
}

/* 附件缩略 chip：小方块浮在 composer 上方，非全宽 */
.att-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.att-chip {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--r-md);
  overflow: hidden;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  flex-shrink: 0;
}
.att-chip-img { width: 100%; height: 100%; display: block; }
.att-x {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: var(--text-inv);
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.att-loading {
  font-size: var(--fs-sub); color: var(--text-2);
}

.bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.bar-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bar-btn image { width: 36rpx; height: 36rpx; }
.bar-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.bar-send {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--brand);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(47,74,66,0.25);
}
.bar-send image { width: 34rpx; height: 34rpx; }
.bar-off { opacity: 0.3; box-shadow: none; }
