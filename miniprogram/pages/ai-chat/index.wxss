/*
 * AI Chat — 聊天界面（推倒重设）
 * 原生 navigationBar 提供标题，页面内不再写 header
 */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hover { opacity: 0.65; }

/* ═══ 历史抽屉 ═══ */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}
.mask-on { opacity: 1; pointer-events: auto; }

.drawer {
  position: fixed; top: 0; bottom: 0;
  left: -86vw;
  width: 86vw;
  background: var(--bg-page);
  z-index: 101;
  transition: left 0.28s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 32rpx rgba(0,0,0,0.18);
}
.drawer-open { left: 0; }

.drawer-head {
  padding: 120rpx 32rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-shrink: 0;
}
.drawer-title { font-size: var(--fs-h1); font-weight: var(--fw-bold); color: var(--text-1); line-height: 1; }
.drawer-new {
  display: flex; align-items: center; gap: 6rpx;
  font-size: var(--fs-sub);
  color: var(--text-inv);
  font-weight: var(--fw-semibold);
  padding: 14rpx 24rpx;
  background: var(--brand);
  border-radius: var(--r-pill);
  box-shadow: 0 4rpx 12rpx rgba(47,74,66,0.25);
}
.drawer-new-ico { font-size: 28rpx; font-weight: var(--fw-bold); line-height: 1; }

.drawer-list {
  flex: 1;
  min-height: 0;
  padding: 8rpx 16rpx;
}

/* 分组标签 */
.grp-label {
  padding: 20rpx 16rpx 10rpx;
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  color: var(--text-3);
  letter-spacing: 1rpx;
}

/* 会话行 */
.sess {
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  padding: 16rpx 16rpx 16rpx 0;
  border-radius: var(--r-md);
  margin-bottom: 4rpx;
  background: transparent;
  position: relative;
}
.sess-hover { background: var(--bg-muted); }
.sess-active {
  background: var(--bg-muted);
  box-shadow: inset 0 0 0 1rpx var(--border);
}

.sess-band {
  width: 6rpx;
  border-radius: 0 4rpx 4rpx 0;
  flex-shrink: 0;
  background: var(--text-3);
  align-self: stretch;
}
.band-tongue { background: var(--accent); }
.band-sleep { background: var(--info); }
.band-constitution { background: var(--success); }
.band-default { background: var(--brand); }

.sess-body { flex: 1; min-width: 0; padding: 2rpx 0; }
.sess-title {
  font-size: var(--fs-body);
  color: var(--text-1);
  font-weight: var(--fw-semibold);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sess-meta {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--fs-caption);
  color: var(--text-3);
  line-height: 1;
}
.sess-dot { color: var(--text-3); }
.sess-ago { color: var(--text-2); }

.drawer-empty {
  padding: 120rpx 40rpx;
  text-align: center;
}
.drawer-empty .empty-h {
  font-size: var(--fs-body);
  color: var(--text-2);
  font-weight: var(--fw-semibold);
  margin-bottom: 8rpx;
  margin-top: 0;
}
.drawer-empty .empty-sub {
  font-size: var(--fs-caption);
  color: var(--text-3);
}

.drawer-foot {
  padding: 20rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 20rpx;
  color: var(--text-3);
  border-top: 1rpx solid var(--divider);
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

/* ═══ 消息区 ═══ */
/* min-height:0 必须有 — flex 子项默认 min-height:auto 会撑到内容高度，scroll-view 内部 overflow 永不触发 */
.msgs {
  flex: 1;
  min-height: 0;
  padding: 20rpx 28rpx 0;
  box-sizing: border-box;
}

/* ── 空状态（轻量） ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 24rpx;
}
.empty-logo {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  color: var(--text-inv);
  font-size: 30rpx; font-weight: var(--fw-bold);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(42,74,62,0.25);
}
.empty-h {
  margin-top: 24rpx;
  font-size: var(--fs-h1);
  font-weight: var(--fw-bold);
  color: var(--text-1);
}

/* 横滑 chip 建议 */
.chip-scroll {
  margin-top: 36rpx;
  width: 100%;
  white-space: nowrap;
}
.chip-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx;
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 22rpx 12rpx 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 103, 50, 0.08);
}
.chip-ico {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.chip-ico image { width: 30rpx; height: 30rpx; }
.chip-txt { font-size: 26rpx; color: var(--text-1); font-weight: var(--fw-semibold); }

/* ═══ 消息流（ChatGPT 范式：user 气泡；AI 无气泡） ═══ */
.msg { margin-bottom: 32rpx; }

/* 用户：右对齐紧凑 cream pill */
.msg-u { display: flex; justify-content: flex-end; }
.bbl-u {
  max-width: 70%;
  padding: 14rpx 22rpx;
  border-radius: 28rpx;
  border-top-right-radius: 8rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  color: var(--text-1);
  box-shadow: 0 4rpx 12rpx rgba(139, 103, 50, 0.08);
}
.bbl-txt {
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-word;
  display: block;
}

/* AI：无气泡，文本直接在页面 bg 上 */
.msg-a { padding: 0 4rpx; }
.ai-txt {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--text-1);
  word-break: break-word;
}

/* 自写 markdown 渲染块 */
.md { font-size: 30rpx; color: var(--text-1); line-height: 1.75; }
.md-p { margin: 0 0 16rpx; }
.md-p:last-child { margin-bottom: 0; }
.md-h { font-weight: var(--fw-bold); color: var(--text-1); margin: 20rpx 0 12rpx; line-height: 1.4; }
.md-h1 { font-size: 38rpx; }
.md-h2 { font-size: 34rpx; }
.md-h3 { font-size: 30rpx; }
.md-ul, .md-ol { margin: 10rpx 0; padding: 0; }
.md-li { display: flex; gap: 10rpx; align-items: flex-start; margin: 6rpx 0; padding-left: 8rpx; }
.md-bullet { color: var(--brand); font-weight: var(--fw-bold); min-width: 20rpx; line-height: 1.75; }
.md-num { color: var(--brand); font-weight: var(--fw-semibold); min-width: 44rpx; line-height: 1.75; }
.md-li-body { flex: 1; line-height: 1.75; }
.md-hr {
  height: 2rpx;
  margin: 22rpx 0;
  background: linear-gradient(90deg, rgba(47,74,66,0) 0%, rgba(47,74,66,0.22) 18%, rgba(47,74,66,0.22) 82%, rgba(47,74,66,0) 100%);
}
.md-table-wrap {
  width: 100%;
  margin: 14rpx 0 18rpx;
}
.md-table {
  min-width: 100%;
  border: 1rpx solid rgba(47, 74, 66, 0.12);
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.72);
}
.md-tr {
  display: flex;
}
.md-tr + .md-tr {
  border-top: 1rpx solid rgba(47, 74, 66, 0.1);
}
.md-tr-head {
  background: rgba(47, 74, 66, 0.07);
}
.md-th,
.md-td {
  min-width: 180rpx;
  flex: 1;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  color: var(--text-1);
  line-height: 1.6;
}
.md-th + .md-th,
.md-td + .md-td {
  border-left: 1rpx solid rgba(47, 74, 66, 0.1);
}
.md-th {
  font-weight: var(--fw-bold);
}

/* 行内 run 样式 */
.md-n { /* normal 无样式 */ }
.md-b { font-weight: var(--fw-bold); color: var(--brand-dark); }
.md-c {
  background: var(--bg-muted);
  color: var(--accent);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-family: Menlo, Consolas, monospace;
}

.tool-step {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(47, 74, 66, 0.08);
}

.tool-step-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.tool-step-label {
  font-size: 26rpx;
  color: var(--text-1);
  font-weight: var(--fw-semibold);
}

.tool-step-state {
  font-size: 22rpx;
  color: var(--brand-dark);
  font-weight: var(--fw-semibold);
}

.tool-step-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-2);
  line-height: 1.6;
}

.tool-executing .tool-step-state { color: var(--accent); }
.tool-completed .tool-step-state { color: var(--brand-dark); }

.agent-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96) 0%, rgba(245,241,233,0.96) 100%);
  box-shadow: 0 12rpx 32rpx rgba(42, 74, 62, 0.08);
  border: 1rpx solid rgba(47, 74, 66, 0.08);
}

.card-head { margin-bottom: 18rpx; }
.card-title {
  font-size: 30rpx;
  color: var(--text-1);
  font-weight: var(--fw-bold);
}
.card-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-2);
  line-height: 1.6;
}

.health-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.health-metric {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.75);
}

.health-label {
  font-size: 22rpx;
  color: var(--text-3);
}

.health-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-1);
  font-weight: var(--fw-semibold);
}

.tone-good { color: var(--brand-dark); }
.tone-warn { color: var(--accent); }

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  display: flex;
  gap: 16rpx;
  padding: 14rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.82);
}

.product-cover {
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: var(--bg-card);
}

.product-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.product-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: var(--text-1);
  font-weight: var(--fw-semibold);
  line-height: 1.5;
}

.product-price {
  font-size: 26rpx;
  color: var(--brand-dark);
  font-weight: var(--fw-bold);
}

.product-meta {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}
.product-footer-action {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: var(--fw-semibold);
  color: var(--brand-dark);
  background: rgba(47, 74, 66, 0.08);
}

.product-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: var(--fw-semibold);
  line-height: 1;
}

.action-ghost {
  color: var(--brand-dark);
  background: rgba(47, 74, 66, 0.08);
}

.action-solid {
  color: var(--text-inv);
  background: var(--brand-dark);
}

.product-category {
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(47, 74, 66, 0.08);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: var(--fw-semibold);
}

.product-reason {
  font-size: 24rpx;
  color: var(--text-2);
  line-height: 1.6;
}

/* 消息内图片 */
.msg-img {
  display: block;
  max-width: 280rpx;
  border-radius: var(--r-md);
  margin-bottom: 10rpx;
}
.msg-img-u { max-width: 260rpx; }

/* ═══ Composer ═══ */
.foot {
  background: var(--bg-page);
  padding: 14rpx var(--sp-4);
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom) + 100rpx);
  border-top: 1rpx solid var(--divider);
  flex-shrink: 0;
}

/* 附件缩略 chip：小方块浮在 composer 上方，非全宽 */
.att-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.att-chip {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--r-md);
  overflow: hidden;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  flex-shrink: 0;
}
.att-chip-img { width: 100%; height: 100%; display: block; }
.att-x {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: var(--text-inv);
  font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.att-loading {
  font-size: var(--fs-sub); color: var(--text-2);
}

.bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.bar-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bar-btn image { width: 36rpx; height: 36rpx; }
.bar-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.bar-send {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--brand);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(47,74,66,0.25);
}
.bar-send image { width: 34rpx; height: 34rpx; }
.bar-off { opacity: 0.3; box-shadow: none; }
