/*
 * AI Chat — 微信小程序聊天界面
 *
 * 设计参考：
 *   微信官方设计指南（字号 12-22pt, 点击区域 7-9mm）
 *   Chat UI 间距规范（bubble padding 20/10/15, gap 16px）
 *   AI-Native UI（minimal chrome, streaming text, sticky input）
 *
 * 色板（延续项目主色）：
 *   --bg:       #F4F0EB  页面背景
 *   --surface:  #FFFFFF  卡片/气泡
 *   --border:   #E5DFD4  分割线
 *   --primary:  #3F6B5E  品牌绿（CTA、用户气泡）
 *   --primary-d:#2A4A3E  品牌绿深（头像渐变）
 *   --text-1:   #1A2B24  主文字
 *   --text-2:   #6B7B73  次文字
 *   --text-3:   #A3ADA7  提示文字
 */

/* ═══ 全局 ═══ */
page { background: #F4F0EB; }
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hover { opacity: 0.6; }

/* ═══ 顶栏 — 高度 96rpx，点击区 88rpx（≈9mm） ═══ */
.nav {
  height: 96rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F4F0EB;
  border-bottom: 1rpx solid #E5DFD4;
  flex-shrink: 0;
}
.nav-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-ico { font-size: 38rpx; color: #3F6B5E; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A2B24; }

/* ═══ 历史抽屉 ═══ */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 100;
}
.drawer {
  position: fixed; top: 0; bottom: 0;
  left: -75vw;
  width: 75vw;
  background: #FAF6F0;
  z-index: 101;
  transition: left 0.28s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  flex-direction: column;
}
.drawer-open { left: 0; }
.drawer-head {
  padding: 100rpx 28rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.drawer-title { font-size: 32rpx; font-weight: 700; color: #1A2B24; }
.drawer-new {
  font-size: 24rpx; color: #3F6B5E; font-weight: 600;
  padding: 10rpx 18rpx;
  border: 2rpx solid #3F6B5E;
  border-radius: 999rpx;
}
.drawer-list { flex: 1; padding: 0 28rpx 40rpx; }
.drawer-item {
  padding: 24rpx 18rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: #3D4C45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.drawer-active { background: #EAE3D6; }
.drawer-item:not(.drawer-active) { background: #FFF; }
.drawer-empty { font-size: 26rpx; color: #A3ADA7; text-align: center; margin-top: 80rpx; }

/* ═══ 消息区 ═══ */
.msgs {
  flex: 1;
  padding: 20rpx 28rpx 0;
  box-sizing: border-box;
}

/* ── 空状态 ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}
.empty-logo {
  width: 104rpx; height: 104rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: #F0EAE0;
  font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.empty-h { margin-top: 24rpx; font-size: 36rpx; font-weight: 700; color: #1A2B24; }
.empty-p { margin-top: 10rpx; font-size: 26rpx; color: #A3ADA7; }

/* ── 快捷卡片 ── */
.cards {
  margin-top: 36rpx;
  width: 100%;
  display: flex; flex-wrap: wrap; gap: 16rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
}
.card {
  flex: 1 1 44%;
  min-width: 260rpx;
  background: #FFF;
  border: 2rpx solid #E5DFD4;
  border-radius: 20rpx;
  padding: 22rpx 18rpx;
  display: flex; align-items: center; gap: 14rpx;
}
.card-ico { font-size: 34rpx; flex-shrink: 0; }
.card-txt { font-size: 26rpx; color: #3D4C45; line-height: 1.5; }

/* ═══ 消息行 — 间距 24rpx ═══ */
.row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.row-l { justify-content: flex-start; }
.row-r { justify-content: flex-end; }

/* ── AI 头像 ── */
.ava {
  width: 64rpx; height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: #F0EAE0;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* ── 气泡 ── */
.bbl {
  max-width: 74%;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
}
.bbl-a {
  background: #FFF;
  color: #1A2B24;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.bbl-u {
  background: #3F6B5E;
  color: #F5F0EA;
  border-top-right-radius: 6rpx;
}

/* ── Parts ── */
.bbl-txt {
  font-size: 30rpx;
  line-height: 1.75;
  word-break: break-word;
  display: block;
}
.bbl-img {
  width: 100%;
  max-width: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
  display: block;
}
.bbl-u .bbl-img { max-width: 320rpx; }

/* ═══ 底部输入区 ═══ */
.foot {
  background: #F4F0EB;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom) + 100rpx);
  border-top: 1rpx solid #E5DFD4;
  flex-shrink: 0;
}

/* ── 附件预览 ── */
.att {
  position: relative;
  margin-bottom: 14rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #FFF;
  border: 2rpx solid #E5DFD4;
}
.att-img {
  width: 100%;
  max-height: 360rpx;
  display: block;
}
.att-x {
  position: absolute; top: 14rpx; right: 14rpx;
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #FFF;
  font-size: 30rpx;
  display: flex; align-items: center; justify-content: center;
}
.att-loading {
  text-align: center;
  font-size: 24rpx; color: #6B7B73;
  padding: 10rpx 0;
}

/* ── 输入行 ── */
.bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.bar-plus {
  width: 76rpx; height: 76rpx;
  border-radius: 50%;
  background: #FFF;
  border: 2rpx solid #DDD7CC;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-size: 40rpx; color: #6B7B73; font-weight: 300;
}
.bar-input {
  flex: 1;
  height: 76rpx;
  background: #FFF;
  border: 2rpx solid #DDD7CC;
  border-radius: 38rpx;
  padding: 0 26rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
.bar-send {
  height: 76rpx;
  border-radius: 38rpx;
  background: #3F6B5E;
  color: #F5F0EA;
  font-size: 28rpx; font-weight: 600;
  padding: 0 30rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bar-off { opacity: 0.35; }
.bar-tip {
  text-align: center;
  font-size: 20rpx;
  color: #B5BCB8;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}
