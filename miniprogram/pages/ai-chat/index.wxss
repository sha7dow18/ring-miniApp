/* ═══ 全局 ═══ */
page { background: #F4F0EB; }
.chat-page { height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
.tap-dim { opacity: 0.6; }

/* ═══ 顶栏 ═══ */
.top-bar {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex; align-items: center; justify-content: space-between;
  background: #F4F0EB;
  border-bottom: 2rpx solid #E8E2D8;
  flex-shrink: 0;
}
.top-left, .top-right { display: flex; align-items: center; gap: 8rpx; }
.top-title { font-size: 30rpx; font-weight: 700; color: #1F2D28; }
.top-label { font-size: 24rpx; color: #6B7B73; }
.icon-history { font-size: 32rpx; color: #4A5C54; }
.icon-new { font-size: 32rpx; color: #3F6B5E; font-weight: 700; }

/* ═══ 历史侧边栏 ═══ */
.mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3); z-index: 100;
}
.sidebar {
  position: fixed; top: 0; left: -70vw; bottom: 0;
  width: 70vw;
  background: #FAF6F0;
  z-index: 101;
  transition: left 0.25s ease;
  padding: 120rpx 28rpx 40rpx;
  box-sizing: border-box;
  overflow-y: auto;
}
.sidebar-show { left: 0; }
.sidebar-title { font-size: 30rpx; font-weight: 700; color: #1F2D28; margin-bottom: 24rpx; }
.sidebar-item {
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  background: #FFFFFF;
}
.sidebar-text { font-size: 26rpx; color: #3D4C45; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.sidebar-empty { font-size: 24rpx; color: #AAB0AB; text-align: center; margin-top: 60rpx; }

/* ═══ 消息列表 ═══ */
.chat-list { flex: 1; padding: 16rpx 24rpx 0; box-sizing: border-box; }
.scroll-end { height: 16rpx; }

/* ═══ 欢迎区 ═══ */
.welcome { display: flex; flex-direction: column; align-items: center; padding: 48rpx 0 32rpx; }
.welcome-logo {
  width: 88rpx; height: 88rpx; border-radius: 22rpx;
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: #F0EAE0; font-size: 26rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.welcome-title { margin-top: 20rpx; font-size: 34rpx; font-weight: 700; color: #1F2D28; }
.welcome-sub { margin-top: 8rpx; font-size: 24rpx; color: #8A8E8B; }
.quick-grid { margin-top: 28rpx; width: 100%; display: flex; flex-wrap: wrap; gap: 14rpx; padding: 0 8rpx; box-sizing: border-box; }
.quick-card {
  flex: 1 1 45%; min-width: 260rpx;
  background: #FFF; border: 2rpx solid #E8E2D8; border-radius: 18rpx;
  padding: 18rpx 16rpx; display: flex; align-items: center; gap: 12rpx;
}
.qc-icon { font-size: 30rpx; flex-shrink: 0; }
.qc-text { font-size: 24rpx; color: #3D4C45; line-height: 1.4; }

/* ═══ 消息行 ═══ */
.msg-row { display: flex; align-items: flex-start; gap: 12rpx; margin-bottom: 20rpx; }
.msg-left { justify-content: flex-start; }
.msg-right { justify-content: flex-end; }

/* ═══ AI 头像 ═══ */
.avatar {
  width: 52rpx; height: 52rpx; border-radius: 14rpx;
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: #F0EAE0; font-size: 20rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 4rpx;
}

/* ═══ 气泡 ═══ */
.bubble { max-width: 76%; border-radius: 22rpx; padding: 16rpx 20rpx; }
.b-ai { background: #FFF; color: #2C3E36; border-top-left-radius: 6rpx; }
.b-user { background: #3F6B5E; color: #F5F0EA; border-top-right-radius: 6rpx; }

/* ═══ Parts 渲染 ═══ */
.part-text { font-size: 28rpx; line-height: 1.7; word-break: break-all; display: block; }
.part-img { width: 100%; max-width: 360rpx; border-radius: 14rpx; margin-bottom: 8rpx; display: block; }
.b-user .part-img { max-width: 300rpx; }

/* ═══ 输入区 ═══ */
.input-area {
  background: #F4F0EB;
  padding: 14rpx 24rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom) + 100rpx);
  border-top: 2rpx solid #E8E2D8;
  flex-shrink: 0;
}
.input-row { display: flex; align-items: center; gap: 12rpx; }
.btn-add {
  width: 68rpx; height: 68rpx; border-radius: 50%;
  background: #FFF; border: 2rpx solid #DDD7CC;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 36rpx; color: #6B7B73; font-weight: 300;
}
.msg-input {
  flex: 1; height: 68rpx;
  background: #FFF; border: 2rpx solid #DDD7CC; border-radius: 34rpx;
  padding: 0 22rpx; font-size: 28rpx; box-sizing: border-box;
}
.btn-send {
  height: 68rpx; border-radius: 34rpx;
  background: #3F6B5E; color: #F5F0EA;
  font-size: 26rpx; font-weight: 600;
  padding: 0 26rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.btn-off { opacity: 0.35; }

/* ═══ 附件预览区 ═══ */
.att-preview {
  background: #FFF; border: 2rpx solid #E0D9CE; border-radius: 18rpx;
  padding: 16rpx; margin-bottom: 12rpx;
  position: relative;
}
.att-thumb {
  width: 100%;
  max-height: 400rpx;
  border-radius: 14rpx;
}
.att-info { margin-top: 10rpx; }
.att-label { font-size: 26rpx; color: #2C3E36; font-weight: 600; display: block; }
.att-hint { font-size: 22rpx; color: #8A8E8B; margin-top: 2rpx; display: block; }
.att-remove {
  position: absolute; top: 12rpx; right: 12rpx;
  width: 52rpx; height: 52rpx;
  border-radius: 50%; background: rgba(0,0,0,0.45);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #FFF;
}
.att-uploading {
  text-align: center; font-size: 24rpx; color: #6B7B73;
  padding: 8rpx 0; margin-bottom: 8rpx;
}

.input-hint { text-align: center; font-size: 20rpx; color: #B0B5B1; margin-top: 8rpx; }
