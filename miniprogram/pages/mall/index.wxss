.mall-page {
  min-height: 100vh;
  padding: var(--sp-4);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.hero-text .t1 { font-size: var(--fs-h2); color: var(--text-1); font-weight: var(--fw-bold); line-height: 1.2; }
.hero-text .t2 { font-size: 52rpx; font-weight: var(--fw-bold); line-height: 1.08; color: var(--text-1); }
.hero-text .t3 { margin-top: var(--sp-2); font-size: var(--fs-body); color: var(--text-2); }

.search-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}
.search-box {
  flex: 1;
  height: 76rpx;
  border-radius: var(--r-lg);
  background: var(--bg-card);
  display: flex; align-items: center;
  padding: 0 18rpx;
  box-shadow: var(--shadow-card);
}
.search-input { flex: 1; color: var(--text-1); font-size: var(--fs-body); }
.search-input::placeholder { color: var(--text-3); }
.icon-search {
  width: 30rpx; height: 30rpx;
  border: 4rpx solid var(--text-2);
  border-radius: 50%;
  position: relative;
}
.icon-search::after {
  content: "";
  position: absolute;
  width: 16rpx; height: 4rpx;
  background: var(--text-2);
  border-radius: 4rpx;
  transform: rotate(45deg);
  right: -10rpx; bottom: -6rpx;
}

/* 购物车角标 */
.cart-btn {
  width: 76rpx; height: 76rpx;
  border-radius: var(--r-card);
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  position: relative;
  flex-shrink: 0;
}
.cart-ico { width: 44rpx; height: 44rpx; }
.cart-badge {
  position: absolute;
  top: -10rpx; right: -10rpx;
  min-width: 32rpx; height: 32rpx;
  padding: 0 var(--sp-2);
  background: var(--danger);
  color: var(--text-inv);
  font-size: 20rpx;
  font-weight: var(--fw-bold);
  border-radius: var(--r-pill);
  display: flex; align-items: center; justify-content: center;
}

.banner-wrap {
  margin-top: var(--sp-3);
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: var(--shadow-float);
}
.banner { width: 100%; height: 250rpx; display: block; }

.cat-row { margin: 18rpx 0 14rpx; display: flex; gap: 12rpx; flex-wrap: wrap; }
.cat {
  min-width: 130rpx;
  height: 58rpx;
  border-radius: var(--r-pill);
  background: var(--bg-muted);
  text-align: center;
  line-height: 58rpx;
  font-size: var(--fs-sub);
  color: var(--text-2);
  font-weight: var(--fw-semibold);
  padding: 0 20rpx;
}
.cat.active { background: var(--brand); color: var(--text-inv); }

.goods-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }
.goods-card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
}
.goods-image-wrap {
  height: 230rpx;
  background: var(--bg-muted);
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.goods-image { width: 210rpx; height: 210rpx; }
.goods-image.ph { border-radius: var(--r-md); opacity: 0.78; }

/* 商品图片微调（每款单独） */
.product-image-m1, .product-image-m2, .product-image-m3, .product-image-m4 {
  width: 300rpx; height: 200rpx;
  transform: translateY(8rpx);
}

.goods-body { padding: var(--sp-3) var(--sp-3) 18rpx; display: flex; flex-direction: column; gap: var(--sp-2); }
.goods-name {
  font-size: var(--fs-h2);
  color: var(--text-1);
  font-weight: var(--fw-bold);
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.goods-desc {
  color: var(--text-2);
  font-size: var(--fs-caption);
  line-height: 1.4;
  height: 62rpx;
  overflow: hidden;
}
.goods-tags { display: flex; gap: 6rpx; flex-wrap: wrap; min-height: 34rpx; }
.goods-tag {
  font-size: 18rpx;
  color: var(--text-2);
  background: var(--bg-muted);
  border-radius: var(--r-pill);
  padding: 4rpx 10rpx;
}
.goods-foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; }
.goods-price { font-size: 38rpx; color: var(--accent); font-weight: var(--fw-bold); }
.goods-price text { font-size: var(--fs-caption); color: var(--text-2); margin-left: 4rpx; }
.buy {
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-pill);
  padding: 10rpx 18rpx;
  font-size: var(--fs-caption);
  font-weight: var(--fw-bold);
}

.empty { text-align: center; color: var(--text-2); font-size: var(--fs-sub); padding: 50rpx 0; }

.hover { opacity: 0.65; }
