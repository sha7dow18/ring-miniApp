.mall-page {
  min-height: 100vh;
  padding: var(--sp-4);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.hero-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-2) 100%);
  box-shadow: var(--shadow-card);
}

.hero-kicker {
  font-size: var(--fs-caption);
  color: var(--brand);
  font-weight: var(--fw-semibold);
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: var(--fw-bold);
  line-height: 1.16;
  color: var(--text-1);
}

.hero-sub {
  margin-top: 12rpx;
  font-size: var(--fs-sub);
  line-height: 1.6;
  color: var(--text-2);
}

.hero-meta {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-chip {
  padding: 10rpx 18rpx;
  border-radius: var(--r-pill);
  background: rgba(63, 107, 94, 0.14);
  color: var(--brand-dark);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
}

.hero-chip.soft {
  background: rgba(255, 255, 255, 0.66);
  color: var(--text-2);
}

.sticky-shell {
  position: sticky;
  top: 0;
  z-index: 20;
  margin-top: 18rpx;
  padding: 12rpx 0 14rpx;
  background: var(--bg-page);
}

.search-row {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}

.search-box {
  flex: 1;
  height: 76rpx;
  border-radius: var(--r-lg);
  background: var(--bg-card);
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  box-shadow: var(--shadow-card);
  border: 2rpx solid rgba(63, 107, 94, 0.06);
}

.search-input {
  flex: 1;
  color: var(--text-1);
  font-size: var(--fs-body);
}

.search-input::placeholder { color: var(--text-3); }

.icon-search {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid var(--text-2);
  border-radius: 50%;
  position: relative;
}

.icon-search::after {
  content: "";
  position: absolute;
  width: 16rpx;
  height: 4rpx;
  background: var(--text-2);
  border-radius: 4rpx;
  transform: rotate(45deg);
  right: -10rpx;
  bottom: -6rpx;
}

.cart-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--r-card);
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
  box-shadow: var(--shadow-card);
}

.cart-ico { width: 44rpx; height: 44rpx; }

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 var(--sp-2);
  background: var(--danger);
  color: var(--text-inv);
  font-size: 20rpx;
  font-weight: var(--fw-bold);
  border-radius: var(--r-pill);
  display: flex;
  align-items: center;
  justify-content: center;
}

.results-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.results-title {
  font-size: var(--fs-h2);
  color: var(--text-1);
  font-weight: var(--fw-bold);
}

.results-meta {
  font-size: var(--fs-caption);
  color: var(--text-2);
}

.cat-scroll {
  margin-top: 12rpx;
  width: 100%;
  white-space: nowrap;
}

.cat-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: var(--sp-3);
}

.cat {
  flex-shrink: 0;
  min-width: 130rpx;
  height: 58rpx;
  border-radius: var(--r-pill);
  background: var(--bg-muted);
  text-align: center;
  line-height: 58rpx;
  font-size: var(--fs-sub);
  color: var(--text-2);
  font-weight: var(--fw-semibold);
  padding: 0 20rpx;
}

.cat.active {
  background: var(--brand);
  color: var(--text-inv);
}

.constitution-row {
  margin: var(--sp-4) 0 var(--sp-3);
  padding: var(--sp-4);
  background: linear-gradient(135deg, #EAF1EC, #D6E4DB);
  border-radius: 24rpx;
}
.cr-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--sp-3); }
.cr-title { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--brand-dark); }
.cr-sub { font-size: var(--fs-caption); color: var(--text-2); }
.cr-list { display: flex; gap: var(--sp-3); padding-right: var(--sp-4); }
.cr-card {
  width: 200rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: var(--sp-2);
  box-shadow: 0 2rpx 8rpx rgba(30, 20, 10, 0.04);
  flex-shrink: 0;
}
.cr-img {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.cr-img image { width: 100%; height: 100%; }
.cr-name { margin-top: var(--sp-2); font-size: var(--fs-sub); color: var(--text-1); font-weight: var(--fw-medium); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cr-price { margin-top: var(--sp-1); font-size: var(--fs-body); color: var(--accent); font-weight: var(--fw-semibold); }

.banner-wrap {
  margin-top: 6rpx;
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: var(--shadow-float);
  position: relative;
}

.banner {
  width: 100%;
  height: 220rpx;
  display: block;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 22rpx 24rpx;
  background: linear-gradient(180deg, rgba(26, 43, 36, 0) 0%, rgba(26, 43, 36, 0.48) 100%);
}

.banner-title {
  font-size: var(--fs-h2);
  color: var(--text-inv);
  font-weight: var(--fw-bold);
}

.banner-sub {
  margin-top: 6rpx;
  font-size: var(--fs-caption);
  color: rgba(245, 240, 234, 0.86);
}

.goods-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.goods-card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
}

.goods-image-wrap {
  height: 230rpx;
  background: linear-gradient(180deg, var(--cream-1) 0%, var(--bg-muted) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.goods-image {
  width: 100%;
  height: 100%;
}

.goods-image.ph {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--r-md);
  opacity: 0.78;
}

.goods-body {
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.goods-kicker {
  font-size: 20rpx;
  color: var(--brand);
  font-weight: var(--fw-semibold);
}

.goods-name {
  font-size: 30rpx;
  color: var(--text-1);
  font-weight: var(--fw-bold);
  line-height: 1.28;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: 76rpx;
}

.goods-desc {
  color: var(--text-2);
  font-size: var(--fs-caption);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: 62rpx;
}

.goods-tags {
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
  min-height: 34rpx;
}

.goods-tag {
  font-size: 18rpx;
  color: var(--text-2);
  background: var(--bg-muted);
  border-radius: var(--r-pill);
  padding: 4rpx 10rpx;
}

.goods-foot {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.goods-price {
  font-size: 42rpx;
  color: var(--accent);
  font-weight: var(--fw-bold);
  white-space: nowrap;
}

.goods-price text {
  font-size: var(--fs-caption);
  color: var(--text-2);
  margin-left: 4rpx;
}

.buy {
  flex-shrink: 0;
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-pill);
  padding: 10rpx 18rpx;
  font-size: var(--fs-caption);
  font-weight: var(--fw-bold);
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx 24rpx;
  border-radius: var(--r-card);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.empty-title {
  font-size: var(--fs-sub);
  color: var(--text-1);
  font-weight: var(--fw-semibold);
}

.empty-sub {
  margin-top: 10rpx;
  font-size: var(--fs-caption);
  color: var(--text-2);
  line-height: 1.5;
}

.for-elder-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin: 0 0 16rpx;
  background: linear-gradient(135deg, #FFF6E6 0%, #FFE8C7 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(184, 134, 11, 0.25);
}
.for-elder-banner .fe-emoji { font-size: 44rpx; line-height: 1; }
.for-elder-banner .fe-title { font-size: 28rpx; font-weight: 600; color: #6B4C12; }
.for-elder-banner .fe-sub { font-size: 22rpx; color: #8B6A2B; margin-top: 4rpx; }
