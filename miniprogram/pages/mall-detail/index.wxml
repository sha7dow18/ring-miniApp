<view class="detail-page" wx:if="{{product}}">
  <view wx:if="{{forElder}}" class="for-elder-hint">为父母选购 · 下单寄给老人</view>
  <view class="hero-card" style="{{heroStyle}}">
    <view class="hero-top">
      <view class="hero-kicker">本草轻养</view>
      <view class="hero-chip">{{categoryText}}</view>
    </view>
    <view class="hero-stage">
      <view class="hero-glow"></view>
      <image wx:if="{{product.imageName}}" class="hero-image" src="{{imagePath}}" mode="aspectFit" />
      <view wx:else class="hero-placeholder" style="background: {{product.color}};"></view>
    </view>
  </view>

  <view class="summary-card">
    <view class="summary-kicker">{{categoryText}}</view>
    <view class="summary-title">{{product.name}}</view>
    <view class="summary-row">
      <view class="summary-price">¥{{product.price}}<text>起</text></view>
      <view class="summary-note">云端在售 · 支持单品购买</view>
    </view>
    <view class="summary-desc">{{product.desc}}</view>

    <view class="tag-row">
      <text class="tag" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="detail-card">
    <view class="section-label">调养亮点</view>
    <view class="detail-text">{{detailText}}</view>
  </view>

  <view class="service-card">
    <view class="service-item">
      <view class="service-title">选品方式</view>
      <view class="service-value">围绕 {{categoryText}} 方向做日常轻养推荐</view>
    </view>
    <view class="service-item">
      <view class="service-title">购买支持</view>
      <view class="service-value">支持加入购物车、立即购买与在线咨询</view>
    </view>
  </view>

  <view class="action-bar">
    <view class="btn contact" bindtap="onContact" hover-class="hover">咨询</view>
    <view class="btn cart {{isAdding ? 'off' : ''}}" bindtap="onAddToCart" hover-class="hover">加入购物车</view>
    <view class="btn buy" bindtap="onBuyNow" hover-class="hover">立即购买</view>
  </view>
</view>

<view class="detail-page" wx:else>
  <view class="empty-card">
    <view class="empty-title">商品不存在</view>
    <view class="empty-sub">请返回商城重新选择其他商品。</view>
  </view>
</view>
