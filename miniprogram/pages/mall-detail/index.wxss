.detail-page {
  padding: 26rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.hero-card {
  border-radius: 30rpx;
  padding: 22rpx 22rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.hero-kicker {
  font-size: var(--fs-caption);
  color: var(--brand-dark);
  font-weight: var(--fw-semibold);
  letter-spacing: 1rpx;
}

.hero-chip {
  padding: 8rpx 18rpx;
  border-radius: var(--r-pill);
  background: rgba(255, 255, 255, 0.62);
  color: var(--brand-dark);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
}

.hero-stage {
  margin-top: 18rpx;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-glow {
  position: absolute;
  width: 400rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
  left: 50%;
  top: 52%;
  transform: translate(-50%, -50%);
}

.hero-image {
  position: relative;
  z-index: 2;
  width: 560rpx;
  height: 420rpx;
}

.hero-placeholder {
  position: relative;
  z-index: 2;
  width: 280rpx;
  height: 280rpx;
  border-radius: 30rpx;
  opacity: 0.9;
}

.summary-card,
.detail-card,
.service-card {
  margin-top: 18rpx;
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  padding: 22rpx;
}

.summary-kicker,
.section-label {
  font-size: var(--fs-caption);
  color: var(--brand);
  font-weight: var(--fw-semibold);
}

.summary-title {
  margin-top: 10rpx;
  font-size: 44rpx;
  line-height: 1.2;
  color: var(--text-1);
  font-weight: var(--fw-bold);
}

.summary-row {
  margin-top: 14rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-price {
  font-size: 54rpx;
  color: var(--accent);
  font-weight: var(--fw-bold);
  line-height: 1;
}

.summary-price text {
  margin-left: 6rpx;
  font-size: var(--fs-caption);
  color: var(--text-2);
}

.summary-note {
  font-size: var(--fs-caption);
  color: var(--text-2);
  text-align: right;
  line-height: 1.5;
}

.summary-desc,
.detail-text {
  margin-top: 14rpx;
  color: var(--text-1);
  line-height: 1.8;
  font-size: var(--fs-sub);
}

.tag-row {
  margin-top: 16rpx;
  display: flex;
  gap: var(--sp-2);
  flex-wrap: wrap;
}

.tag {
  padding: var(--sp-2) 12rpx;
  border-radius: var(--r-pill);
  background: var(--bg-muted);
  color: var(--text-2);
  font-size: var(--fs-caption);
}

.service-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-title {
  font-size: var(--fs-caption);
  color: var(--text-2);
}

.service-value {
  margin-top: 6rpx;
  font-size: var(--fs-sub);
  color: var(--text-1);
  line-height: 1.7;
}

.action-bar {
  position: sticky;
  bottom: 20rpx;
  margin-top: 22rpx;
  padding: 14rpx;
  border-radius: 28rpx;
  background: rgba(244, 240, 235, 0.96);
  box-shadow: var(--shadow-float);
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.btn {
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--r-pill);
  font-size: 26rpx;
  font-weight: var(--fw-semibold);
  line-height: 1.4;
}

.btn.contact {
  flex: 0 0 120rpx;
  background: var(--bg-muted);
  color: var(--brand);
}

.btn.cart {
  flex: 1;
  background: var(--bg-card);
  color: var(--brand);
  border: 2rpx solid var(--brand);
}

.btn.buy {
  flex: 1;
  background: var(--brand);
  color: var(--text-inv);
}

.btn.off { opacity: 0.5; }

.hover { opacity: 0.7; }

.empty-card {
  margin-top: 80rpx;
  padding: 40rpx 24rpx;
  border-radius: var(--r-card);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.empty-title {
  font-size: var(--fs-h2);
  color: var(--text-1);
  font-weight: var(--fw-bold);
}

.empty-sub {
  margin-top: 10rpx;
  font-size: var(--fs-caption);
  color: var(--text-2);
  line-height: 1.6;
}

.for-elder-hint {
  margin: 0 0 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FFF6E6 0%, #FFE8C7 100%);
  border: 1rpx solid rgba(184, 134, 11, 0.2);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #6B4C12;
  font-weight: 500;
  text-align: center;
}
