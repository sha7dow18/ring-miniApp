<view class="page" wx:if="{{order}}">
  <!-- 状态 hero -->
  <view class="hero hero-{{order.status}}">
    <image class="hero-ico" src="/assets/icons/status/{{order.status}}.svg" mode="aspectFit" aria-label="{{statusText}}"/>
    <view class="hero-title">{{statusText}}</view>
    <view class="hero-sub" wx:if="{{order.status === 'pending'}}">请尽快完成支付</view>
    <view class="hero-sub" wx:elif="{{order.status === 'paid'}}">感谢购买，等待发货</view>
  </view>

  <!-- 收货信息 -->
  <view class="card" wx:if="{{order.address}}">
    <view class="card-title">收货地址</view>
    <view class="addr-line1">
      <text class="addr-name">{{order.address.name}}</text>
      <text class="addr-phone">{{order.address.phone}}</text>
    </view>
    <view class="addr-detail">{{order.address.detail}}</view>
  </view>

  <!-- 商品列表 -->
  <view class="card">
    <view class="card-title">商品 ({{order.items.length}})</view>
    <view class="item" wx:for="{{order.items}}" wx:key="productId">
      <view class="thumb">
        <image wx:if="{{item.imageName || item.image}}" src="{{item.image || '/assets/mall/' + item.imageName}}" mode="aspectFit" />
      </view>
      <view class="meta">
        <view class="name">{{item.name}}</view>
        <view class="row">
          <text class="price">¥{{item.price}}</text>
          <text class="qty">× {{item.qty}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="card">
    <view class="card-title">订单信息</view>
    <view class="kv"><text class="k">订单号</text><text class="v mono">{{order.orderNo}}</text></view>
    <view class="kv"><text class="k">下单时间</text><text class="v">{{order.createdText}}</text></view>
    <view class="kv" wx:if="{{order.payTime}}"><text class="k">支付时间</text><text class="v">{{order.payTimeText}}</text></view>
    <view class="kv total-kv"><text class="k">实付金额</text><text class="v total">¥{{order.total}}</text></view>
  </view>

  <!-- 操作 -->
  <view class="actions">
    <view class="btn ghost" bindtap="contactSupport" hover-class="hover">联系客服</view>
    <view class="btn ghost" wx:if="{{canCancel}}" bindtap="onCancel" hover-class="hover">取消订单</view>
    <view class="btn primary {{isProcessing ? 'off' : ''}}" wx:if="{{canPay}}" bindtap="onPay" hover-class="hover">立即支付</view>
  </view>
</view>

<view class="page" wx:else>
  <view class="card"><view class="card-title">未找到订单</view></view>
</view>
