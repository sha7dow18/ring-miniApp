.page { padding: var(--sp-4) 28rpx 60rpx; }
.hover { opacity: 0.65; }

/* Hero · 渐变状态头（豁免：保留渐变作强调）*/
.hero {
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  color: var(--text-inv);
  border-radius: var(--r-card);
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(47, 74, 66, 0.2);
}
.hero-pending { background: linear-gradient(135deg, #D6A15B, #A87635); }
.hero-canceled { background: linear-gradient(135deg, #9A9A9A, #6B6B6B); }
.hero-ico { width: 72rpx; height: 72rpx; margin: 0 auto 14rpx; display: block; }
.hero-title { font-size: var(--fs-h1); font-weight: var(--fw-bold); }
.hero-sub { font-size: var(--fs-sub); opacity: 0.85; margin-top: var(--sp-2); }

.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: 28rpx var(--sp-4);
  margin-bottom: var(--sp-3);
  box-shadow: var(--shadow-card);
}
.card-title { font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-bold); margin-bottom: 18rpx; }

.addr-line1 { display: flex; align-items: baseline; gap: 18rpx; }
.addr-name { font-size: 30rpx; color: var(--text-1); font-weight: var(--fw-bold); }
.addr-phone { font-size: var(--fs-sub); color: var(--text-2); }
.addr-detail { margin-top: 10rpx; font-size: 26rpx; color: var(--text-1); line-height: 1.5; }

.item { display: flex; align-items: center; gap: 18rpx; padding: 14rpx 0; border-bottom: 1rpx solid var(--divider); }
.item:last-child { border-bottom: none; }
.thumb {
  width: 110rpx; height: 110rpx;
  border-radius: var(--r-md);
  background: var(--bg-page);
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.thumb image { width: 90%; height: 90%; }
.meta { flex: 1; }
.name { font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-semibold); margin-bottom: 6rpx; }
.row { display: flex; align-items: baseline; justify-content: space-between; }
.price { font-size: var(--fs-body); color: var(--accent); font-weight: var(--fw-bold); }
.qty { font-size: var(--fs-caption); color: var(--text-2); }

.kv {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.kv:last-child { border-bottom: none; }
.k { font-size: 26rpx; color: var(--text-2); }
.v { font-size: 26rpx; color: var(--text-1); }
.mono { font-family: monospace; font-size: var(--fs-sub); }
.total-kv .v.total { font-size: var(--fs-h2); color: var(--accent); font-weight: var(--fw-bold); }

.actions { display: flex; gap: 14rpx; margin-top: var(--sp-4); }
.btn { flex: 1; text-align: center; padding: 22rpx 0; border-radius: var(--r-pill); font-size: 26rpx; font-weight: var(--fw-semibold); }
.btn.ghost { background: var(--bg-card); color: var(--brand); border: 2rpx solid var(--border); }
.btn.primary { background: var(--brand); color: var(--text-inv); }
.btn.off { opacity: 0.5; }
