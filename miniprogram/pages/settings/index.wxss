.page { padding: var(--sp-4); }
.row {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: 22rpx 18rpx;
  margin-bottom: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--text-1);
  font-size: 26rpx;
  box-shadow: var(--shadow-card);
}
.logout {
  margin-top: var(--sp-4);
  text-align: center;
  background: #F1D9CD;
  color: var(--accent);
  border-radius: var(--r-pill);
  padding: 18rpx 0;
  font-size: 25rpx;
  font-weight: var(--fw-semibold);
}
