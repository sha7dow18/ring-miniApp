.page { padding: var(--sp-4); }
.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: var(--sp-4);
  box-shadow: var(--shadow-card);
}
.title { color: var(--text-1); font-size: 30rpx; font-weight: var(--fw-bold); }
.desc { margin-top: var(--sp-2); color: var(--text-2); font-size: var(--fs-sub); line-height: 1.8; }
