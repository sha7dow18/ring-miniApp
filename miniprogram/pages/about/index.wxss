.page { padding: var(--sp-4); }
.title { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--text-1); margin-bottom: var(--sp-3); }
.line {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: 18rpx;
  margin-bottom: 10rpx;
  color: var(--text-1);
  font-size: var(--fs-sub);
  box-shadow: var(--shadow-card);
}
