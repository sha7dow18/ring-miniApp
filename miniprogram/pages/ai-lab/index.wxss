/* 渐变背景底色 */
.dashboard-bg {
  min-height: 100vh;
  background: linear-gradient(135deg, #eef1ec 0%, #e3d2bc 100%);
  position: relative;
  overflow: hidden;
  padding-bottom: 50rpx;
}

/* 人体线稿背景伪元素 (这里用边框模拟，实际开发中请替换为您的 PNG 背景图) */
.body-outline-bg {
  position: absolute;
  right: -50rpx;
  top: 10%;
  width: 300rpx;
  height: 80%;
  border-left: 2px dashed rgba(100, 100, 100, 0.2);
  border-radius: 50%;
  z-index: 0;
}

.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx;
}

/* 顶部入口卡片 */
.intro-card {
  background: linear-gradient(to bottom, #d2dfd6, #f3ebdf);
  border-radius: 30rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 50rpx;
}
.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.card-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}
.start-btn {
  display: inline-flex;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #4b83ce; /* 提取的主题蓝 */
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

/* 标题通用样式 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 检测结果高亮区 */
.highlight-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 40rpx;
}
.main-result {
  display: flex;
  flex-direction: column;
}
.constitution {
  font-size: 56rpx;
  font-weight: 900;
  color: #c96434; /* 提取的主题橙 */
  letter-spacing: 2rpx;
}
.percentage {
  font-size: 40rpx;
  font-weight: bold;
  color: #c96434;
  margin-top: -10rpx;
}
.badge-360 {
  background-color: #b0b8b6;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-left: 30rpx;
  margin-bottom: 10rpx;
}

/* 雷达图占位 */
.radar-placeholder {
  width: 100%;
  height: 350rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
}
.mock-radar-box {
  width: 300rpx;
  height: 300rpx;
  border: 1px dashed #999;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 24rpx;
}

/* 舌面花瓣分析区 (纯CSS绘制) */
.tongue-section {
  margin-top: 20rpx;
}
.petals-container {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  margin: 40rpx auto;
}
.petal {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(144, 150, 120, 0.8);
  border-radius: 50% 50% 0 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-size: 22rpx;
}
.petal-top { top: 0; left: 90rpx; transform: rotate(45deg); }
.petal-top text { transform: rotate(-45deg); }
.petal-left { top: 90rpx; left: 0; transform: rotate(-45deg); }
.petal-left text { transform: rotate(45deg); }
.petal-right { top: 90rpx; right: 0; transform: rotate(135deg); }
.petal-right text { transform: rotate(-135deg); }
.petal-bottom { bottom: 0; left: 90rpx; transform: rotate(-135deg); }
.petal-bottom text { transform: rotate(135deg); }
.petal-center {
  position: absolute;
  top: 135rpx;
  left: 135rpx;
  width: 30rpx;
  height: 30rpx;
  background-color: #fff;
  border-radius: 50%;
}