page{ background:linear-gradient(180deg,#f3ede2 0%,#eee4d6 100%); }
.ai-lab-page{ min-height:100vh; padding:24rpx; padding-bottom:calc(150rpx + env(safe-area-inset-bottom)); }
.hero-card{ background:linear-gradient(145deg,#dfe9de 0%,#efe7d8 62%,#e8dcc7 100%); border-radius:30rpx; padding:32rpx 24rpx; box-shadow:0 8rpx 20rpx rgba(45,56,49,.08); margin-bottom:20rpx; position:relative; overflow:hidden; }
.hero-title{ color:#243730; font-size:42rpx; font-weight:800; }
.hero-desc{ margin-top:10rpx; color:#6f7772; font-size:24rpx; line-height:1.6; max-width:70%; }
.hero-btn{ margin-top:18rpx; display:inline-block; background:#2f4a42; color:#f5eee3; border-radius:999rpx; padding:16rpx 32rpx; font-size:24rpx; font-weight:600; }
.line-art{ position:absolute; right:-24rpx; top:20rpx; width:220rpx; height:220rpx; border:2rpx solid rgba(47,74,66,.18); border-radius:50%; }
.feature-card{ background:#f8f2e8; border-radius:24rpx; padding:24rpx; box-shadow:0 6rpx 16rpx rgba(45,56,49,.06); margin-bottom:14rpx; display:flex; align-items:center; gap:18rpx; }
.f-icon{ font-size:44rpx; flex-shrink:0; }
.f-body{ flex:1; }
.f-title{ color:#1f2d28; font-size:28rpx; font-weight:700; }
.f-desc{ color:#767f79; font-size:22rpx; margin-top:4rpx; }
.f-arrow{ color:#9fa5a0; font-size:36rpx; flex-shrink:0; }
