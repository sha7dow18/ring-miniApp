<view class="ai-lab-page">
  <view class="hero-card">
    <view class="hero-title">AI 健康助手</view>
    <view class="hero-desc">舌诊分析、体质评估、健康问诊，一个对话搞定。</view>
    <view class="hero-btn" bindtap="goChat">开始对话</view>
    <view class="line-art"></view>
  </view>

  <view class="feature-card" wx:for="{{features}}" wx:key="title" data-action="{{item.action}}" bindtap="onFeatureTap">
    <view class="f-icon">{{item.icon}}</view>
    <view class="f-body">
      <view class="f-title">{{item.title}}</view>
      <view class="f-desc">{{item.desc}}</view>
    </view>
    <view class="f-arrow">›</view>
  </view>
</view>
