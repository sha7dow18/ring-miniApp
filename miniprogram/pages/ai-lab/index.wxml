<view class="ai-lab-page">
  <view class="hero-card">
    <view class="hero-title">AI体质辨识测试</view>
    <view class="hero-desc">结合舌象与近期指标，为你生成更生动的体质倾向报告。</view>
    <view class="hero-btn" bindtap="chooseTonguePhoto">点击进入测试</view>
    <view class="line-art"></view>
  </view>

  <view class="gate-card" wx:if="{{!isConnected}}">
    <view class="gate-title">请先连接设备</view>
    <view class="gate-desc">完成连接后即可使用完整 AI 分析能力。</view>
    <view class="capsule" bindtap="goConnectDevice">去连接设备</view>
  </view>

  <scroll-view wx:else class="content-scroll" scroll-y="true">
    <view class="result-card" wx:if="{{latestTongueResult}}">
      <view class="result-title">上次检测结果</view>
      <view class="result-name">{{latestTongueResult.riskTip}}</view>
      <view class="result-percent">倾向值 80%</view>
    </view>

    <view class="feature-card">
      <view class="f-title">舌诊分析</view>
      <view class="f-desc">拍照或从相册选择舌象图，快速生成结果。</view>
      <view class="tongue-preview" wx:if="{{selectedImage}}"><image src="{{selectedImage}}" mode="aspectFill" class="tongue-img" /></view>
      <view class="empty-preview" wx:else>尚未选择图片</view>
      <view class="btn-row">
        <view class="capsule" bindtap="chooseTonguePhoto">拍照 / 相册</view>
        <view class="capsule dark" bindtap="startTongueAnalyze">开始分析</view>
      </view>
    </view>

    <view class="feature-card" wx:if="{{latestTongueResult}}">
      <view class="f-title">分析摘要</view>
      <view class="kv"><text>舌质</text><text>{{latestTongueResult.tongueBody}}</text></view>
      <view class="kv"><text>舌苔</text><text>{{latestTongueResult.tongueCoating}}</text></view>
      <view class="kv"><text>建议</text><text>{{latestTongueResult.suggestion}}</text></view>

      <view class="vis-title">图像可视化分析</view>
      <view class="vis-shot-row">
        <view class="shot" wx:for="{{visionShots}}" wx:key="id">
          <view class="shot-dot"></view>
          <view class="shot-t">{{item.label}}</view>
          <view class="shot-d">{{item.desc}}</view>
        </view>
      </view>

      <view class="bar-row" wx:for="{{visionBars}}" wx:key="name">
        <text class="bar-name">{{item.name}}</text>
        <view class="bar-bg"><view class="bar-fill" style="width: {{item.width}};"></view></view>
        <text class="bar-score">{{item.score}}</text>
      </view>
    </view>

    <view class="feature-card">
      <view class="f-title">AI 问诊</view>
      <view class="f-desc">围绕睡眠、压力、心率等问题进行多轮对话。</view>
      <view class="preset-row">
        <view class="preset" wx:for="{{presets}}" wx:key="*this" data-q="{{item}}" bindtap="usePreset">{{item}}</view>
      </view>
      <view class="capsule" bindtap="goChatPage">进入问诊</view>
    </view>

    <view style="height: 120rpx;"></view>
  </scroll-view>
</view>
