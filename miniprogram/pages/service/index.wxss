.service-page {
  min-height: 100vh;
  padding: var(--sp-4);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.status-card, .panel-card, .actions-card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: 26rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: var(--sp-3);
}

.status-title { font-size: 40rpx; font-weight: var(--fw-bold); color: var(--text-1); }
.status-desc { margin-top: 10rpx; color: var(--text-2); font-size: var(--fs-sub); line-height: 1.6; }
.status-tag {
  margin-top: var(--sp-3);
  display: inline-block;
  border-radius: var(--r-pill);
  padding: var(--sp-2) var(--sp-3);
  background: var(--bg-muted);
  color: var(--text-2);
  font-size: var(--fs-caption);
}

.panel-title { font-size: 30rpx; color: var(--text-1); font-weight: var(--fw-bold); margin-bottom: 14rpx; }

.searching-state, .connecting-state, .empty-state {
  min-height: 170rpx;
  border-radius: var(--r-lg);
  background: var(--bg-muted);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: var(--sp-2);
}
.searching-text, .empty-text { color: var(--text-1); font-size: var(--fs-body); font-weight: var(--fw-bold); }
.searching-sub, .empty-sub { color: var(--text-2); font-size: 23rpx; }

.device-list { display: flex; flex-direction: column; gap: 10rpx; }
.device-item { background: var(--bg-muted); border-radius: var(--r-lg); padding: var(--sp-3); }
.device-head, .device-meta-row { display: flex; justify-content: space-between; align-items: center; }
.device-name { color: var(--text-1); font-size: var(--fs-body); font-weight: var(--fw-bold); }
.device-rssi, .device-meta { color: var(--text-2); font-size: var(--fs-caption); }
.device-action { color: var(--brand); font-size: 23rpx; font-weight: var(--fw-bold); }

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.info-row:last-child { border-bottom: none; }
.info-row .k { color: var(--text-2); font-size: 23rpx; }
.info-row .v { color: var(--text-1); font-size: var(--fs-sub); font-weight: var(--fw-bold); }

.action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10rpx; }
.capsule-btn {
  text-align: center;
  border-radius: var(--r-pill);
  padding: 15rpx 0;
  background: var(--bg-muted);
  color: var(--brand);
  font-size: 23rpx;
}
.capsule-btn.dark { background: var(--brand); color: var(--text-inv); }
.capsule-btn.danger { background: #F1D9CD; color: var(--accent); }
