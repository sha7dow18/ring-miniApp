<view class="service-page">
  <view class="status-card stage-{{pageStage}}">
    <view class="status-title">{{statusTitle}}</view>
    <view class="status-desc">{{statusDesc}}</view>
    <view class="status-tag">{{syncHint}}</view>
  </view>

  <view class="panel-card" wx:if="{{pageStage !== 'connected'}}">
    <view class="panel-title">设备连接中心</view>

    <view class="searching-state" wx:if="{{pageStage === 'searching'}}">
      <text class="searching-text">正在搜索设备...</text>
      <text class="searching-sub">请保持页面停留</text>
    </view>

    <view class="connecting-state" wx:elif="{{pageStage === 'connecting'}}">
      <text class="searching-text">正在连接设备...</text>
      <text class="searching-sub">预计 1~2 秒完成连接</text>
    </view>

    <view class="empty-state" wx:elif="{{!deviceList.length}}">
      <text class="empty-text">当前没有可连接设备</text>
      <text class="empty-sub">点击下方按钮开始搜索</text>
    </view>

    <view class="device-list" wx:else>
      <view class="device-item" wx:for="{{deviceList}}" wx:key="deviceId" bindtap="onConnectDevice" data-id="{{item.deviceId}}">
        <view class="device-head"><text class="device-name">{{item.deviceName}}</text><text class="device-rssi">RSSI {{item.rssi}}</text></view>
        <view class="device-meta-row"><text class="device-meta">电量 {{item.battery}}%</text><text class="device-action">点击连接</text></view>
      </view>
    </view>
  </view>

  <view class="panel-card" wx:if="{{pageStage === 'connected' && connectedDevice}}">
    <view class="panel-title">当前设备</view>
    <view class="info-row"><text class="k">设备名称</text><text class="v">{{connectedDevice.deviceName}}</text></view>
    <view class="info-row"><text class="k">电量</text><text class="v">{{connectedDevice.battery}}%</text></view>
    <view class="info-row"><text class="k">状态</text><text class="v">已连接</text></view>
    <view class="info-row"><text class="k">最近同步</text><text class="v">{{connectedDevice.lastSyncTime}}</text></view>
  </view>

  <view class="actions-card">
    <view class="panel-title">设备操作</view>
    <view class="capsule-btn dark" bindtap="onSearchDevices" wx:if="{{pageStage !== 'connected'}}">搜索设备</view>

    <view wx:if="{{pageStage === 'connected'}}" class="action-grid">
      <view class="capsule-btn" bindtap="onReconnectSearch">重新搜索</view>
      <view class="capsule-btn" bindtap="onSyncMockDevice">同步设备</view>
      <view class="capsule-btn" bindtap="onRefreshBattery">刷新电量</view>
      <view class="capsule-btn" bindtap="onViewDeviceDetail">设备详情</view>
      <view class="capsule-btn danger" bindtap="onDisconnectDevice">断开连接</view>
    </view>
  </view>
</view>
