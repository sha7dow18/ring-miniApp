.fam-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--sp-3);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.empty-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: var(--sp-6) var(--sp-4);
  text-align: center;
  margin-top: var(--sp-5);
}
.empty-emoji { font-size: 120rpx; line-height: 1; }
.empty-title { margin-top: var(--sp-3); font-size: var(--fs-h2); color: var(--text-1); font-weight: var(--fw-bold); }
.empty-desc { margin-top: var(--sp-2); font-size: var(--fs-body); color: var(--text-2); line-height: 1.6; }
.empty-cta {
  display: inline-block;
  margin-top: var(--sp-4);
  padding: var(--sp-2) var(--sp-5);
  background: var(--brand);
  color: var(--text-inv);
  border-radius: 100rpx;
}

.hero-card {
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: var(--text-inv);
  padding: var(--sp-5) var(--sp-4);
  border-radius: 24rpx;
  margin-bottom: var(--sp-3);
}
.hero-label { font-size: var(--fs-caption); opacity: 0.7; letter-spacing: 2rpx; }
.hero-headline { margin-top: var(--sp-2); font-size: 44rpx; font-weight: var(--fw-bold); line-height: 1.3; }
.hero-headline.placeholder { opacity: 0.8; }
.hero-meta { margin-top: var(--sp-3); font-size: var(--fs-sub); opacity: 0.85; }
.hero-meta .badge { color: #FFB26B; margin-left: var(--sp-2); }

.metric-row {
  display: flex;
  gap: var(--sp-2);
  margin-bottom: var(--sp-4);
}
.m-cell {
  flex: 1;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: var(--sp-3) var(--sp-2);
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(30, 20, 10, 0.04);
}
.m-num { font-size: 48rpx; font-weight: var(--fw-bold); color: var(--text-1); }
.m-num.alarm { color: var(--accent); }
.m-label { margin-top: var(--sp-1); font-size: var(--fs-caption); color: var(--text-2); }

.section-title {
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  color: var(--text-1);
  padding: 0 var(--sp-2);
  margin: var(--sp-4) 0 var(--sp-2);
}

.inbox-card.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: var(--sp-3);
  display: flex;
  gap: var(--sp-3);
  align-items: flex-start;
  margin-bottom: var(--sp-2);
  box-shadow: 0 2rpx 8rpx rgba(30, 20, 10, 0.04);
}
.inbox-card.read { opacity: 0.7; }
.ix-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}
.ix-body { flex: 1; }
.ix-title { font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-medium); }
.ix-desc { margin-top: var(--sp-1); font-size: var(--fs-sub); color: var(--text-2); line-height: 1.5; }
.ix-time { margin-top: var(--sp-1); font-size: var(--fs-caption); color: var(--text-3); }
.ix-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  margin-top: 8rpx;
}
.inbox-empty { text-align: center; color: var(--text-3); padding: var(--sp-5); }

.shop-cta {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-4);
  margin: var(--sp-4) 0 var(--sp-3);
  border-radius: 20rpx;
  background: linear-gradient(135deg, #8B3A1A, #A0522D);
  color: var(--text-inv);
  box-shadow: 0 4rpx 16rpx rgba(139, 58, 26, 0.2);
}
.shop-cta-left { flex: 1; }
.shop-cta-title { font-size: var(--fs-h2); font-weight: var(--fw-bold); }
.shop-cta-desc { margin-top: 4rpx; font-size: var(--fs-sub); opacity: 0.9; }
.shop-cta-arrow {
  background: rgba(255, 255, 255, 0.2);
  padding: var(--sp-2) var(--sp-3);
  border-radius: 100rpx;
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
}

.quick-actions {
  display: flex;
  gap: var(--sp-3);
  margin-top: var(--sp-4);
}
.qa-btn {
  flex: 1;
  padding: var(--sp-4);
  background: var(--bg-card);
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(30, 20, 10, 0.04);
}
.qa-emoji { font-size: 56rpx; line-height: 1; }
.qa-text { margin-top: var(--sp-2); font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-medium); }

.tab-bar-space { height: 160rpx; }
