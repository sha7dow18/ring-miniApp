<view class="replenish-page">
  <view class="hero">
    <view class="hero-title">{{headerTitle}}</view>
    <view class="hero-desc">{{headerDesc}}</view>
  </view>

  <view class="section" wx:if="{{due.length}}">
    <view class="section-title">⏰ 待补货 ({{due.length}})</view>
    <view class="plan-card card" wx:for="{{due}}" wx:key="_id">
      <view class="plan-head">
        <view class="plan-name">{{item.productName || item.productId}}</view>
        <view class="plan-due overdue">已到期 · {{item.dueText}}</view>
      </view>
      <view class="plan-meta">上次下单：{{item.lastOrderText}} · 消耗周期 {{item.cycleDays}} 天</view>
      <view class="plan-actions">
        <button class="btn btn-primary" data-id="{{item._id}}" data-pid="{{item.productId}}" bindtap="reorderOne">一键代购</button>
        <button class="btn btn-ghost" data-id="{{item._id}}" bindtap="rejectOne">不再提醒</button>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{upcoming.length}}">
    <view class="section-title">即将补货 ({{upcoming.length}})</view>
    <view class="plan-card card" wx:for="{{upcoming}}" wx:key="_id">
      <view class="plan-head">
        <view class="plan-name">{{item.productName || item.productId}}</view>
        <view class="plan-due">还剩 {{item.daysLeft}} 天</view>
      </view>
      <view class="plan-meta">上次下单：{{item.lastOrderText}} · 消耗周期 {{item.cycleDays}} 天</view>
    </view>
  </view>

  <view wx:if="{{!due.length && !upcoming.length && !loading}}" class="empty">
    <view class="empty-emoji">📦</view>
    <view class="empty-title">暂无补货计划</view>
    <view class="empty-desc">下一次购买完成后，这里会自动排期。</view>
    <view class="empty-cta" bindtap="goMall">去商城逛逛</view>
  </view>

  <view wx:if="{{role === 'child'}}" class="tab-bar-space"></view>
</view>

<tab-bar wx:if="{{role === 'child'}}" selected="1" />
