.replenish-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--sp-3);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.hero {
  padding: var(--sp-4);
  background: linear-gradient(135deg, var(--cream-1), var(--cream-2));
  border-radius: 24rpx;
  margin-bottom: var(--sp-3);
}
.hero-title { font-size: var(--fs-h1); font-weight: var(--fw-bold); color: var(--text-1); }
.hero-desc { margin-top: var(--sp-2); font-size: var(--fs-body); color: var(--text-2); line-height: 1.6; }

.section { margin-bottom: var(--sp-4); }
.section-title { font-size: var(--fs-h2); font-weight: var(--fw-semibold); color: var(--text-1); margin: var(--sp-3) var(--sp-2) var(--sp-2); }

.plan-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: var(--sp-4);
  margin-bottom: var(--sp-2);
  box-shadow: 0 2rpx 8rpx rgba(30, 20, 10, 0.04);
}
.plan-head { display: flex; justify-content: space-between; align-items: baseline; }
.plan-name { font-size: var(--fs-h2); font-weight: var(--fw-semibold); color: var(--text-1); }
.plan-due { font-size: var(--fs-sub); color: var(--text-2); }
.plan-due.overdue { color: var(--accent); font-weight: var(--fw-semibold); }
.plan-meta { margin-top: var(--sp-2); font-size: var(--fs-caption); color: var(--text-3); }
.plan-actions { margin-top: var(--sp-3); display: flex; gap: var(--sp-2); }

.btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  font-size: var(--fs-body);
  font-weight: var(--fw-medium);
}
.btn-primary { background: var(--brand); color: var(--text-inv); }
.btn-ghost { background: var(--bg-card); color: var(--text-2); border: 2rpx solid var(--border); }

.empty { padding: var(--sp-6) var(--sp-4); text-align: center; }
.empty-emoji { font-size: 120rpx; line-height: 1; }
.empty-title { margin-top: var(--sp-3); font-size: var(--fs-h2); color: var(--text-1); }
.empty-desc { margin-top: var(--sp-2); font-size: var(--fs-body); color: var(--text-2); }
.empty-cta {
  display: inline-block;
  margin-top: var(--sp-4);
  padding: var(--sp-2) var(--sp-5);
  background: var(--brand);
  color: var(--text-inv);
  border-radius: 100rpx;
  font-size: var(--fs-sub);
}

.tab-bar-space { height: 160rpx; }
