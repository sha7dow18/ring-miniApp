.user-info-page { padding: var(--sp-4); padding-bottom: 60rpx; }

.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.avatar-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  margin-bottom: 14rpx;
  border: none;
  line-height: normal;
  text-align: left;
}
.avatar-card::after { border: none; }
.hover { opacity: 0.65; }

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--r-pill);
  overflow: hidden;
  margin-right: 14rpx;
  background: var(--bg-muted);
}
.avatar image { width: 100%; height: 100%; }
.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-2);
  font-size: var(--fs-caption);
}

.hint { color: var(--text-2); font-size: var(--fs-sub); }

.row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--divider);
  padding: var(--sp-3) 0;
}
.row:last-child { border-bottom: none; }

.row text { width: 150rpx; color: var(--text-2); font-size: var(--fs-sub); }
.row input { flex: 1; height: 60rpx; font-size: var(--fs-sub); }

.textarea-row { align-items: flex-start; }
.textarea-row textarea { flex: 1; min-height: 100rpx; font-size: var(--fs-sub); }

.save-btn {
  margin-top: var(--sp-3);
  text-align: center;
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-md);
  padding: 20rpx 0;
  font-size: var(--fs-body);
  border: none;
  line-height: 1.4;
}
.save-btn::after { border: none; }
.save-btn-off { opacity: 0.5; }
