<view class="page">
  <scroll-view class="tabs" scroll-x="true" show-scrollbar="false">
    <view class="tab-list">
      <view wx:for="{{tabs}}" wx:key="id" class="tab {{activeTab===item.id?'active':''}}" data-id="{{item.id}}" bindtap="switchTab">{{item.name}}</view>
    </view>
  </scroll-view>

  <view class="order-card" wx:for="{{shownOrders}}" wx:key="id" data-id="{{item.id}}" bindtap="showDetail">
    <view class="card-header">
      <view class="order-info">
        <text class="order-id">{{item.id}}</text>
        <text class="status">{{item.statusText}}</text>
      </view>
      <view class="delete-btn" bindtap="deleteOrder" data-id="{{item.id}}">删除</view>
    </view>

    <view class="product-name">{{item.productName}}</view>
    <view class="product-meta">
      <text class="price">¥{{item.price}}</text>
      <text class="qty">×{{item.quantity}}</text>
    </view>

    <view class="card-footer">
      <text class="date">{{item.createdAt}}</text>
      <text class="detail-link">查看详情 ›</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!shownOrders.length}}">该状态下暂无订单</view>
</view>
