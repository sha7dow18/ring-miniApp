<view class="page">
  <scroll-view class="tabs" scroll-x="true" show-scrollbar="false">
    <view class="tab-list">
      <view wx:for="{{tabs}}" wx:key="id" class="tab {{activeTab===item.id?'active':''}}" data-id="{{item.id}}" bindtap="switchTab">{{item.name}}</view>
    </view>
  </scroll-view>

  <view class="list" wx:if="{{shownOrders.length}}">
    <view class="order-card" wx:for="{{shownOrders}}" wx:key="_id" data-id="{{item._id}}" bindtap="showDetail" hover-class="hover">
      <view class="card-header">
        <text class="order-no">订单号 {{item.orderNo}}</text>
        <text class="status status-{{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="product-name">{{item.firstItemName}} <text class="multi" wx:if="{{item.items.length > 1}}">等 {{item.items.length}} 件商品</text></view>

      <view class="card-footer">
        <text class="date">{{item.createdText}}</text>
        <view class="total-wrap">
          <text class="count">共 {{item.itemCount}} 件</text>
          <text class="total">¥{{item.total}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:elif="{{!isLoading}}">
    <view class="empty-icon">📦</view>
    <view class="empty-title">暂无订单</view>
    <view class="empty-btn" bindtap="goMall" hover-class="hover">去逛逛</view>
  </view>
</view>
