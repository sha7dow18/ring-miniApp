.page { padding: var(--sp-4) var(--sp-4) 40rpx; }
.hover { opacity: 0.7; }

.tabs { height: 74rpx; margin-bottom: var(--sp-3); }
.tab-list { display: flex; white-space: nowrap; padding: 0 4rpx; }
.tab {
  padding: 14rpx 28rpx;
  border-radius: var(--r-pill);
  background: var(--bg-muted);
  margin-right: 12rpx;
  color: var(--text-2);
  font-size: var(--fs-sub);
  font-weight: var(--fw-medium);
}
.tab.active {
  background: var(--brand);
  color: var(--text-inv);
  font-weight: var(--fw-bold);
}

.list { display: flex; flex-direction: column; gap: var(--sp-3); }

.order-card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: var(--sp-4);
  box-shadow: var(--shadow-card);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}
.order-no { font-size: var(--fs-caption); color: var(--text-2); font-family: monospace; }

/* 订单状态 pill 5 色（状态变体保留）*/
.status {
  font-size: var(--fs-caption);
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  font-weight: var(--fw-semibold);
}
.status-pending { background: #FFF4E0; color: var(--warning); }
.status-paid { background: #E4FCD6; color: var(--success); }
.status-shipping { background: #D6E4FC; color: var(--info); }
.status-done { background: var(--bg-muted); color: var(--text-2); }
.status-canceled { background: #F4E0E0; color: var(--accent); }

.product-name { font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-bold); margin-bottom: var(--sp-3); }
.multi { font-size: var(--fs-caption); color: var(--text-2); font-weight: var(--fw-regular); }

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.date { font-size: var(--fs-caption); color: var(--text-3); }
.total-wrap { display: flex; align-items: baseline; gap: 12rpx; }
.count { font-size: var(--fs-caption); color: var(--text-2); }
.total { font-size: var(--fs-h2); color: var(--accent); font-weight: var(--fw-bold); }

.empty { text-align: center; padding: 180rpx 40rpx 60rpx; }
.empty-illust { width: 260rpx; height: 260rpx; display: block; margin: 0 auto; }
.empty-title {
  margin-top: var(--sp-5);
  font-size: 30rpx;
  color: var(--text-1);
  font-weight: var(--fw-semibold);
}
.empty-btn {
  display: inline-block;
  margin-top: var(--sp-5);
  padding: 18rpx 60rpx;
  background: var(--brand);
  color: var(--text-inv);
  border-radius: var(--r-pill);
  font-size: var(--fs-sub);
  font-weight: var(--fw-semibold);
}
