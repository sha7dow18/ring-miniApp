.constitution-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--sp-3);
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: var(--sp-5) var(--sp-4);
  margin-bottom: var(--sp-3);
  box-shadow: 0 2rpx 12rpx rgba(30, 20, 10, 0.04);
}
.hero {
  background: linear-gradient(135deg, var(--cream-1), var(--cream-2));
  text-align: center;
}
.hero .emoji { font-size: 96rpx; line-height: 1; }
.hero-title { margin-top: var(--sp-3); font-size: var(--fs-h1); font-weight: var(--fw-semibold); color: var(--text-1); }
.hero-desc { margin-top: var(--sp-3); font-size: var(--fs-body); color: var(--text-2); line-height: 1.7; }

.assessing .emoji { animation: spin 2s linear infinite; }
@keyframes spin { 0% { transform: rotate(0); } 100% { transform: rotate(360deg); } }

.card-title { font-size: var(--fs-h2); font-weight: var(--fw-semibold); color: var(--text-1); }
.card-desc { margin-top: var(--sp-2); font-size: var(--fs-sub); color: var(--text-2); line-height: 1.6; }

.q-group { margin-top: var(--sp-4); }
.q-label { font-size: var(--fs-body); color: var(--text-1); margin-bottom: var(--sp-2); }
.q-options { display: flex; gap: var(--sp-2); }
.q-opt {
  flex: 1;
  text-align: center;
  padding: var(--sp-3) 0;
  border-radius: 12rpx;
  background: var(--bg-page);
  border: 2rpx solid var(--border);
  font-size: var(--fs-sub);
  color: var(--text-2);
}
.q-opt.active {
  background: var(--brand);
  color: var(--text-inv);
  border-color: var(--brand);
}

.action-row { margin-top: var(--sp-4); }
.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: var(--fs-body);
  font-weight: var(--fw-medium);
}
.btn-primary { background: var(--brand); color: var(--text-inv); }
.btn-ghost { background: var(--bg-card); color: var(--brand); border: 2rpx solid var(--brand); }

.result-hero .result-tag { font-size: var(--fs-sub); color: var(--text-2); letter-spacing: 2rpx; }
.result-hero .result-name { margin-top: var(--sp-2); font-size: 64rpx; font-weight: var(--fw-bold); color: var(--brand-dark); }
.result-hero .result-score { margin-top: var(--sp-2); font-size: var(--fs-h2); color: var(--accent); font-weight: var(--fw-medium); }
.result-hero .result-summary { margin-top: var(--sp-3); font-size: var(--fs-body); color: var(--text-1); line-height: 1.6; }

.label-list { margin-top: var(--sp-3); }
.label-row {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-3) 0;
  border-bottom: 1rpx solid var(--divider);
}
.label-row:last-child { border-bottom: none; }
.label-name { width: 140rpx; font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-medium); }
.label-bar {
  flex: 1;
  height: 14rpx;
  background: var(--bg-muted);
  border-radius: 7rpx;
  overflow: hidden;
}
.label-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--brand-light), var(--brand));
  border-radius: 7rpx;
  transition: width 400ms ease;
}
.label-score { width: 80rpx; text-align: right; font-size: var(--fs-body); color: var(--text-1); font-weight: var(--fw-semibold); }

.report { margin-top: var(--sp-3); font-size: var(--fs-body); color: var(--text-1); line-height: 1.9; white-space: pre-wrap; }
.report-meta { margin-top: var(--sp-3); font-size: var(--fs-caption); color: var(--text-3); text-align: right; }
