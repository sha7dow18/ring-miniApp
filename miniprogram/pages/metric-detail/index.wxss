.page { min-height: 100vh; padding: var(--sp-4); box-sizing: border-box; }

.hero-card {
  border-radius: var(--r-card);
  padding: 40rpx 32rpx 36rpx;
  background: linear-gradient(135deg, var(--cream-1) 0%, var(--cream-3) 100%);
  box-shadow: 0 6rpx 20rpx rgba(139, 103, 50, 0.10);
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
  margin-bottom: 20rpx;
}
.hero-icon {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--brand-light) 0%, var(--brand-dark) 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow: inset 0 -6rpx 14rpx rgba(0,0,0,0.14);
}
.hero-icon .icon { width: 64rpx; height: 64rpx; }
.hero-label { color: var(--text-2); font-size: var(--fs-body); font-weight: var(--fw-semibold); }
.hero-value { display: flex; align-items: baseline; gap: 10rpx; }
.hero-value .num { font-size: 90rpx; font-weight: var(--fw-bold); color: var(--text-1); line-height: 1; }
.hero-value .unit { font-size: var(--fs-h2); color: var(--text-2); font-weight: var(--fw-semibold); }
.hero-range { color: var(--text-2); font-size: var(--fs-caption); }

.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  padding: var(--sp-4);
  margin-bottom: 16rpx;
}
.card-title { font-size: var(--fs-h2); color: var(--text-1); font-weight: var(--fw-bold); margin-bottom: 20rpx; }

.trend-bars { display: flex; align-items: flex-end; justify-content: space-between; height: 300rpx; gap: 12rpx; }
.trend-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.trend-val { font-size: var(--fs-caption); color: var(--text-2); }
.trend-bar {
  width: 28rpx; border-radius: 14rpx 14rpx 4rpx 4rpx;
  background: linear-gradient(180deg, var(--brand-mid), var(--brand-dark));
}
.trend-lbl { font-size: 20rpx; color: var(--text-3); }
.trend-empty { padding: 40rpx 0; text-align: center; color: var(--text-3); }

.hint-text { color: var(--text-2); font-size: var(--fs-sub); line-height: 1.7; }
