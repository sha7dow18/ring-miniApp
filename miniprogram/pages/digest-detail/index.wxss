.dd-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--sp-3);
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.hero {
  padding: var(--sp-5) var(--sp-4);
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  color: var(--text-inv);
  border-radius: 24rpx;
  margin-bottom: var(--sp-3);
}
.hero .week { font-size: var(--fs-caption); opacity: 0.7; letter-spacing: 2rpx; }
.hero .headline { margin-top: var(--sp-2); font-size: 48rpx; font-weight: var(--fw-bold); line-height: 1.3; }
.tone {
  display: inline-block;
  margin-top: var(--sp-3);
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: var(--fs-caption);
  background: rgba(255, 255, 255, 0.15);
}

.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: var(--sp-4);
  margin-bottom: var(--sp-3);
  box-shadow: 0 2rpx 8rpx rgba(30, 20, 10, 0.04);
}

.summary .row {
  display: flex;
  justify-content: space-between;
  padding: var(--sp-2) 0;
  border-bottom: 1rpx solid var(--divider);
  font-size: var(--fs-body);
  color: var(--text-2);
}
.summary .row:last-child { border-bottom: none; }
.summary .val { color: var(--text-1); font-weight: var(--fw-semibold); }
.summary .val.alarm { color: var(--accent); }

.section-title { font-size: var(--fs-h2); color: var(--text-1); font-weight: var(--fw-semibold); margin-bottom: var(--sp-3); }
.section-title.alarm { color: var(--accent); }
.item {
  padding: var(--sp-2) 0;
  font-size: var(--fs-body);
  color: var(--text-1);
  line-height: 1.7;
  border-bottom: 1rpx solid var(--divider);
}
.item:last-child { border-bottom: none; }

.meta { text-align: right; font-size: var(--fs-caption); color: var(--text-3); padding: var(--sp-2); }

.empty { padding: var(--sp-6); text-align: center; }
.empty-emoji { font-size: 120rpx; line-height: 1; }
.empty-text { margin-top: var(--sp-3); font-size: var(--fs-body); color: var(--text-2); }
