.page { padding: 40rpx 28rpx 60rpx; }

/* Hero（豁免：保留渐变作强调点缀）*/
.hero { text-align: center; padding: 30rpx 0 40rpx; }
.hero-icon {
  width: 120rpx; height: 120rpx;
  border-radius: var(--r-card);
  background: linear-gradient(135deg, var(--brand), var(--brand-dark));
  margin: 0 auto 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 10rpx 28rpx rgba(63, 107, 94, 0.25);
}
.hero-title { font-size: 38rpx; font-weight: var(--fw-bold); color: var(--text-1); }
.hero-sub { font-size: var(--fs-sub); color: var(--text-2); margin-top: var(--sp-2); }

/* Card */
.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: var(--sp-2) 0;
  box-shadow: var(--shadow-card);
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid var(--divider);
}
.row:last-child { border-bottom: none; }
.row-l { display: flex; align-items: center; gap: 18rpx; flex: 1; min-width: 0; }
.row-ico { font-size: 38rpx; flex-shrink: 0; }
.row-meta { display: flex; flex-direction: column; min-width: 0; }
.row-label { font-size: var(--fs-caption); color: var(--text-2); }
.row-value {
  font-size: 30rpx; color: var(--text-1);
  font-weight: var(--fw-semibold);
  margin-top: var(--sp-1);
  word-break: break-all;
}
.row-action {
  background: var(--bg-muted);
  color: var(--brand);
  font-size: var(--fs-sub);
  font-weight: var(--fw-semibold);
  padding: 12rpx var(--sp-4);
  border-radius: var(--r-pill);
  flex-shrink: 0;
  margin-left: var(--sp-3);
}
.row-hover { opacity: 0.65; }

/* Section */
.section-title {
  font-size: 26rpx;
  color: var(--text-2);
  font-weight: var(--fw-semibold);
  padding: 40rpx var(--sp-2) var(--sp-3);
  letter-spacing: 2rpx;
}

/* FAQ */
.faq-card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}
.faq-item {
  padding: 0 28rpx;
  border-bottom: 1rpx solid var(--divider);
}
.faq-item:last-child { border-bottom: none; }
.faq-hover { background: #FAF6F0; }
.faq-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}
.faq-q {
  font-size: var(--fs-body);
  color: var(--text-1);
  font-weight: var(--fw-semibold);
  flex: 1;
  padding-right: 20rpx;
}
.faq-arrow {
  font-size: var(--fs-h1); color: var(--text-3);
  transition: transform 0.2s;
  display: inline-block;
}
.faq-arrow-open { transform: rotate(90deg); color: var(--brand); }
.faq-body {
  font-size: 26rpx; color: var(--text-2);
  line-height: 1.7;
  padding: 0 0 28rpx;
}

/* Foot */
.foot {
  margin-top: 40rpx;
  padding: 0 var(--sp-3);
  font-size: var(--fs-caption);
  color: var(--text-3);
  text-align: center;
  line-height: 1.7;
}
