page { background: #F4F0EB; }
.page { padding: 40rpx 28rpx 60rpx; }

/* Hero */
.hero {
  text-align: center;
  padding: 30rpx 0 40rpx;
}
.hero-icon {
  width: 120rpx; height: 120rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #3F6B5E, #2A4A3E);
  margin: 0 auto 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 10rpx 28rpx rgba(63, 107, 94, 0.25);
}
.hero-title { font-size: 38rpx; font-weight: 700; color: #1A2B24; }
.hero-sub { font-size: 24rpx; color: #8A9390; margin-top: 8rpx; }

/* Card */
.card {
  background: #FFF;
  border-radius: 28rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F1EADD;
}
.row:last-child { border-bottom: none; }
.row-l { display: flex; align-items: center; gap: 18rpx; flex: 1; min-width: 0; }
.row-ico { font-size: 38rpx; flex-shrink: 0; }
.row-meta { display: flex; flex-direction: column; min-width: 0; }
.row-label { font-size: 22rpx; color: #8A9390; }
.row-value {
  font-size: 30rpx; color: #1A2B24;
  font-weight: 600;
  margin-top: 4rpx;
  word-break: break-all;
}
.row-action {
  background: #EAE3D6;
  color: #3F6B5E;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.row-hover { opacity: 0.6; }

/* Section */
.section-title {
  font-size: 26rpx;
  color: #6B7B73;
  font-weight: 600;
  padding: 40rpx 8rpx 16rpx;
  letter-spacing: 2rpx;
}

/* FAQ */
.faq-card {
  background: #FFF;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.faq-item {
  padding: 0 28rpx;
  border-bottom: 1rpx solid #F1EADD;
}
.faq-item:last-child { border-bottom: none; }
.faq-hover { background: #FAF6F0; }
.faq-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}
.faq-q { font-size: 28rpx; color: #1A2B24; font-weight: 600; flex: 1; padding-right: 20rpx; }
.faq-arrow {
  font-size: 36rpx; color: #A3ADA7;
  transition: transform 0.2s;
  display: inline-block;
}
.faq-arrow-open { transform: rotate(90deg); color: #3F6B5E; }
.faq-body {
  font-size: 26rpx; color: #5A6A63;
  line-height: 1.7;
  padding: 0 0 28rpx;
}

/* Foot */
.foot {
  margin-top: 40rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
  color: #A3ADA7;
  text-align: center;
  line-height: 1.7;
}
