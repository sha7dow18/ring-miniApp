<view class="page">
  <view class="hero">
    <view class="hero-icon">
      <image class="hero-icon-img" src="/assets/icons/inv/message-circle.svg" mode="aspectFit" aria-label="客服"/>
    </view>
    <view class="hero-title">在线客服</view>
    <view class="hero-sub">{{support.hours}}</view>
  </view>

  <view class="card">
    <view class="row" bindlongpress="copyWechat">
      <view class="row-l">
        <image class="row-ico" src="/assets/icons/smartphone.svg" mode="aspectFit" aria-label="微信号"/>
        <view class="row-meta">
          <text class="row-label">客服微信</text>
          <text class="row-value selectable" user-select="{{true}}">{{support.wechat}}</text>
        </view>
      </view>
      <view class="row-action" bindtap="copyWechat" hover-class="row-hover">复制</view>
    </view>
    <view class="row" bindlongpress="copyEmail">
      <view class="row-l">
        <image class="row-ico" src="/assets/icons/mail.svg" mode="aspectFit" aria-label="邮箱"/>
        <view class="row-meta">
          <text class="row-label">客服邮箱</text>
          <text class="row-value selectable" user-select="{{true}}">{{support.email}}</text>
        </view>
      </view>
      <view class="row-action" bindtap="copyEmail" hover-class="row-hover">复制</view>
    </view>
  </view>

  <view class="section-title">常见问题</view>
  <view class="faq-card">
    <view
      class="faq-item"
      wx:for="{{faqList}}"
      wx:key="q"
      data-idx="{{index}}"
      bindtap="toggleFaq"
      hover-class="faq-hover"
    >
      <view class="faq-head">
        <text class="faq-q">{{item.q}}</text>
        <text class="faq-arrow {{expandedIndex === index ? 'faq-arrow-open' : ''}}">›</text>
      </view>
      <view class="faq-body" wx:if="{{expandedIndex === index}}">
        <text>{{item.a}}</text>
      </view>
    </view>
  </view>

  <view class="foot">
    若问题紧急，请拨打紧急服务热线或直接联系购买渠道的售后服务。
  </view>
</view>
