/*
 * Design Tokens · 养生土色系
 * 所有值通过 CSS 变量暴露，全局唯一事实源。
 * 新增 token 或改值只改本文件。
 */

page {
  /* ═══ 色彩 ═══ */
  /* 品牌 */
  --brand:         #3F6B5E;   /* 唯一主色 */
  --brand-dark:    #2A4A3E;   /* 仅用于渐变 stop / 按下态 */

  /* 背景 */
  --bg-page:       #F4F0EB;   /* 页面底色（唯一） */
  --bg-card:       #FFFFFF;   /* 卡片底 */
  --bg-muted:      #EAE3D6;   /* 次级卡片 / tabBar / tag 底 */

  /* 线 */
  --border:        #E5DFD4;
  --divider:       #F1EADD;

  /* 文字 */
  --text-1:        #1A2B24;   /* 主 */
  --text-2:        #6B7B73;   /* 次 */
  --text-3:        #A3ADA7;   /* 提示 */
  --text-inv:      #F5F0EA;   /* 深底浅字 */

  /* 强调 / 功能 */
  --accent:        #8B3A1A;   /* 价格 / 强调，养生棕红 */
  --success:       #3A6B1A;
  --warning:       #8B5A1A;
  --danger:        #B94A4A;
  --info:          #1A3B8B;

  /* ═══ 字号（rpx） ═══ */
  --fs-display:    44rpx;
  --fs-h1:         36rpx;
  --fs-h2:         32rpx;
  --fs-body:       28rpx;
  --fs-sub:        24rpx;
  --fs-caption:    22rpx;

  /* ═══ 字重 ═══ */
  --fw-regular:    400;
  --fw-medium:     500;
  --fw-semibold:   600;
  --fw-bold:       700;

  /* ═══ 间距（rpx） ═══ */
  --sp-1:          4rpx;
  --sp-2:          8rpx;
  --sp-3:          16rpx;
  --sp-4:          24rpx;
  --sp-5:          32rpx;
  --sp-6:          48rpx;

  /* ═══ 圆角（rpx） ═══ */
  --r-sm:          4rpx;
  --r-md:          12rpx;
  --r-lg:          18rpx;
  --r-card:        24rpx;
  --r-pill:        999rpx;

  /* ═══ 阴影 ═══ */
  --shadow-card:   0 4rpx 14rpx rgba(0,0,0,0.04);
  --shadow-float:  0 8rpx 24rpx rgba(0,0,0,0.08);
  --shadow-press:  inset 0 2rpx 4rpx rgba(0,0,0,0.06);
}
