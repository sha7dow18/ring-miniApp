/*
 * Common utility classes — 所有页面共用
 * 修改前请先想：是不是应该改 token 而不是 common？
 */

/* ═══ 卡片 ═══ */
.card {
  background: var(--bg-card);
  border-radius: var(--r-card);
  padding: var(--sp-4);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--sp-3);
}
/* ═══ 胶囊标签 pill ═══ */
.pill {
  display: inline-block;
  padding: var(--sp-1) var(--sp-3);
  border-radius: var(--r-pill);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  background: var(--bg-muted);
  color: var(--text-2);
  line-height: 1.4;
}
.pill-brand { background: var(--brand); color: var(--text-inv); }
.pill-accent { background: var(--accent); color: var(--text-inv); }
.pill-success { background: #E4FCD6; color: var(--success); }
.pill-warning { background: #FFF4E0; color: var(--warning); }
.pill-danger { background: #F4E0E0; color: var(--danger); }
.pill-info { background: #D6E4FC; color: var(--info); }

/* ═══ 列表项 row ═══ */
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1rpx solid var(--divider);
  background: var(--bg-card);
}
.row:last-child { border-bottom: none; }

/* ═══ 交互态 ═══ */
.hover { opacity: 0.65; }

/* ═══ 安全区 ═══ */
.safe-bottom {
  padding-bottom: calc(var(--sp-4) + env(safe-area-inset-bottom));
}

/* ═══ 字号快捷类 ═══ */
.display { font-size: var(--fs-display); font-weight: var(--fw-bold); line-height: 1.2; }
.h1 { font-size: var(--fs-h1); font-weight: var(--fw-bold); line-height: 1.3; }
.h2 { font-size: var(--fs-h2); font-weight: var(--fw-semibold); line-height: 1.3; }
.body { font-size: var(--fs-body); line-height: 1.5; }
.sub { font-size: var(--fs-sub); line-height: 1.5; }
.caption { font-size: var(--fs-caption); line-height: 1.4; }

/* ═══ 字色快捷类 ═══ */
.txt-1 { color: var(--text-1); }
.txt-2 { color: var(--text-2); }
.txt-3 { color: var(--text-3); }
.txt-inv { color: var(--text-inv); }
.txt-accent { color: var(--accent); }
.txt-brand { color: var(--brand); }

/* ═══ flex ═══ */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
