.tab-bar-container {
  position: fixed;
  left: var(--sp-3); right: var(--sp-3);
  bottom: 10rpx;
  height: 104rpx;
  border-radius: var(--r-card);
  background: var(--bg-card);
  display: flex;
  box-shadow: var(--shadow-float);
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
  overflow: visible;
}
.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
}
.icon-box {
  width: 48rpx; height: 48rpx;
  margin-bottom: 6rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.tab-icon { width: 100%; height: 100%; object-fit: contain; }
.tab-text { font-size: var(--fs-caption); color: var(--text-2); }
.tab-bar-item.selected .tab-text { color: var(--brand); font-weight: var(--fw-bold); }
.tab-bar-item.selected .tab-icon { transform: scale(1.08); }

/* 中间 AI tab 凸起胶囊（豁免：保留渐变 + stop 用 token）*/
.tab-bar-item:nth-child(3) .icon-box {
  width: 98rpx; height: 98rpx;
  position: absolute;
  top: -34rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 50%;
  background: var(--brand);
  box-shadow: 0 10rpx 22rpx rgba(50, 77, 67, .32);
}
.tab-bar-item:nth-child(3) .tab-icon { width: 54rpx; height: 54rpx; }
.tab-bar-item:nth-child(3) .tab-text { margin-top: 56rpx; }
.tab-bar-item:nth-child(3).selected .tab-text { color: var(--brand); }
