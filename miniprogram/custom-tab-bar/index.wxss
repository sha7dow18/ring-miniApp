/* 标准贴底 tabBar — 满宽、纯色、自动安全区 */
.tab-bar-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-top: 1rpx solid var(--border);
  display: flex;
  align-items: stretch;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-bar-item {
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  position: relative;
}

.icon-box {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tab-icon {
  width: 100%;
  height: 100%;
}

.tab-text {
  font-size: 20rpx;
  color: var(--text-2);
  line-height: 1;
  white-space: nowrap;
}
.tab-bar-item.selected .tab-text {
  color: var(--brand);
  font-weight: var(--fw-semibold);
}

/* AI 中间 tab · 凸起胶囊作为强调 */
.tab-bar-item:nth-child(3) .icon-box {
  position: absolute;
  top: -30rpx;
  left: 50%;
  width: 90rpx;
  height: 90rpx;
  transform: translateX(-50%);
  background: var(--brand);
  border-radius: 50%;
  border: 4rpx solid var(--bg-page);
  box-shadow: 0 8rpx 16rpx rgba(47, 74, 66, 0.3);
}
.tab-bar-item:nth-child(3) .tab-icon {
  width: 44rpx;
  height: 44rpx;
}
.tab-bar-item:nth-child(3) .tab-text {
  margin-top: 60rpx;
}
.tab-bar-item:nth-child(3).selected .tab-text {
  color: var(--brand);
}
