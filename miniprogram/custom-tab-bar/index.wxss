.tab-bar-container{ position:fixed; left:16rpx; right:16rpx; bottom:10rpx; height:104rpx; border-radius:30rpx; background:#f7f2e8; display:flex; box-shadow:0 8rpx 24rpx rgba(46,58,51,.16); z-index:999; padding-bottom:env(safe-area-inset-bottom); overflow:visible; }
.tab-bar-item{ flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; position:relative; }
.icon-box{ width:48rpx; height:48rpx; margin-bottom:6rpx; display:flex; justify-content:center; align-items:center; }
.tab-icon{ width:100%; height:100%; object-fit:contain; }
.tab-text{ font-size:22rpx; color:#7a807a; }
.tab-bar-item.selected .tab-text{ color:#3f5e54; font-weight:700; }
.tab-bar-item.selected .tab-icon{ transform:scale(1.08); }
.tab-bar-item:nth-child(3) .icon-box{ width:98rpx; height:98rpx; position:absolute; top:-34rpx; left:50%; transform:translateX(-50%); border-radius:50%; background:#3f5e54; box-shadow:0 10rpx 22rpx rgba(50,77,67,.32); }
.tab-bar-item:nth-child(3) .tab-icon{ width:54rpx; height:54rpx; }
.tab-bar-item:nth-child(3) .tab-text{ margin-top:56rpx; }
.tab-bar-item:nth-child(3).selected .tab-text{ color:#2f4a42; }
