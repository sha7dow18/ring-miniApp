.tab-bar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx; /* 严格锁定导航栏物理高度，防止被撑开 */
  background: white;
  display: flex;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
  overflow: visible; /* 关键：允许内部巨大的图标超出容器边界显示 */
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  transition: all 0.2s linear; /* 增加过渡动画，让放大更平滑 */
}

/* 图标容器，用于定位 */
.icon-box {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 6rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 强制图片按比例缩放，绝不拉伸，统一尺寸 */
.tab-icon {
  width: 100%;
  height: 100%;
  object-fit: contain; /* 核心属性：保证无论原图多大，都等比缩放塞进 54rpx 的盒子里 */
  transition: transform 0.2s cubic-bezier(0.25, 0.1, 0.25, 1); /* 让放大的动画更Q弹平滑 */
}

.tab-text {
  font-size: 22rpx;
  color: #7d7e80; /* 默认灰色 */
}

/* ==============================
   高亮样式实现：颜色 + 放大
   ============================== */
.tab-bar-item.selected .tab-text {
  color: #07c160; /* 提取app.json中的选中绿色 */
  font-weight: bold;
}

.tab-bar-item.selected .tab-icon {
  /* 核心核心：选中时图标放大 1.1 倍 (可根据需要调整为 1.15 或 1.2) */
  transform: scale(1.15); 
}

.tab-bar-item:nth-child(3) {
  position: relative; /* 为内部绝对定位提供基准 */
}

.tab-bar-item:nth-child(3) .icon-box {
  width: 100rpx;   /* 维持巨大的视觉尺寸 */
  height: 100rpx;
  position: absolute; /* 核心：脱离 Flexbox 布局流，不再参与高度计算 */
  top: -30rpx;      /* 向上偏移，使其“浮”在导航栏上方 */
  left: 50%;
  transform: translateX(-50%); /* 水平居中 */
  background: #fff; /* 如果需要，可以给图标加个白色圆底背景 */
  border-radius: 50%;
  box-shadow: 0 -4rpx 10rpx rgba(0,0,0,0.05); /* 给凸起部分加点阴影更有立体感 */
}

/* 3. 修正 AI 图标选中后的缩放，确保不触发布局抖动 */
.tab-bar-item:nth-child(3).selected .tab-icon {
  transform: scale(1.1); /* 仅在当前位置微调缩放，不影响容器高度 */
}