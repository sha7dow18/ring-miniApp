.cc-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: var(--sp-4);
  box-shadow: 0 2rpx 12rpx rgba(30, 20, 10, 0.04);
  margin-bottom: var(--sp-3);
}
.cc-card.type-greeting {
  background: linear-gradient(135deg, #FFF5E1, #FFEFC8);
}
.cc-card.type-seeding {
  background: linear-gradient(135deg, #F4EDE0, #E8DFC9);
}
.cc-card.type-video_script {
  background: linear-gradient(135deg, #ECEFF1, #D9DFE2);
}

.cc-head { display: flex; align-items: center; gap: var(--sp-2); margin-bottom: var(--sp-2); }
.cc-emoji {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.cc-meta { flex: 1; }
.cc-type { font-size: var(--fs-caption); color: var(--brand); font-weight: var(--fw-semibold); letter-spacing: 1rpx; }
.cc-author { font-size: var(--fs-caption); color: var(--text-3); margin-top: 2rpx; }

.cc-title { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--text-1); line-height: 1.4; }
.cc-body { margin-top: var(--sp-2); font-size: var(--fs-body); color: var(--text-2); line-height: 1.6; }
.cc-foot { margin-top: var(--sp-3); }
.cc-chip {
  display: inline-block;
  padding: var(--sp-1) var(--sp-3);
  background: var(--brand);
  color: var(--text-inv);
  font-size: var(--fs-caption);
  border-radius: 100rpx;
}
