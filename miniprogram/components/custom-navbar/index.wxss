.navbar {
  width: 100%;
  box-sizing: border-box;
  background: #f6f4ef;
}

.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.left,
.right {
  width: 88rpx;
  display: flex;
  align-items: center;
}

.left {
  font-size: 40rpx;
  color: #222222;
}

.right {
  justify-content: flex-end;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #222222;
  border-radius: 50%;
}

.title {
  font-size: 28rpx;
  color: #222222;
  font-weight: 600;
}
