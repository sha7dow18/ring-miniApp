page {
  background: #d1ca9d;
}

.constitution-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 24rpx 220rpx;
  background: linear-gradient(180deg, #f6f2e9 0%, #d2c391 100%);
}

.nav-bar {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-left {
  width: 88rpx;
  font-size: 44rpx;
  color: #222222;
  display: flex;
  align-items: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
}

.nav-right {
  width: 160rpx;
  display: flex;
  justify-content: flex-end;
}

.nav-capsule {
  width: 144rpx;
  height: 52rpx;
  border-radius: 30rpx;
  background: rgba(88, 85, 79, 0.18);
  border: 2rpx solid rgba(80, 76, 70, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 14rpx;
  box-sizing: border-box;
}

.nav-dot-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.nav-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #111111;
}

.nav-divider {
  width: 2rpx;
  height: 26rpx;
  background: rgba(0, 0, 0, 0.12);
}

.nav-circle {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 4rpx solid #111111;
}

.main-card {
  background: #f5efdf;
  border-radius: 40rpx;
  padding: 24rpx 22rpx 48rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  min-height: 1280rpx;
}

.test-entry {
  width: 100%;
  border-radius: 80rpx 80rpx 92rpx 92rpx;
  padding: 72rpx 38rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #87998e 0%, #e4dac5 100%);
}

.test-title {
  font-size: 64rpx;
  line-height: 1.08;
  font-weight: 900;
  color: #111111;
}

.test-subtitle {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #64625b;
}

.test-btn {
  margin-top: 34rpx;
  width: 360rpx;
  height: 86rpx;
  border-radius: 43rpx;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
}

.test-btn-arrow {
  font-size: 40rpx;
  line-height: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #181818;
}

.result-section-title {
  margin-top: 28rpx;
  margin-bottom: 12rpx;
}

.result-visual {
  position: relative;
  height: 560rpx;
  overflow: visible;
}

.result-text-block {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 5;
}

.result-type {
  font-size: 84rpx;
  line-height: 1;
  font-weight: 900;
  color: #d86a00;
  letter-spacing: -2rpx;
}

.result-percent {
  margin-top: 14rpx;
  padding-left: 184rpx;
  font-size: 66rpx;
  line-height: 1;
  font-weight: 900;
  color: #d86a00;
}

.result-arc {
  position: absolute;
  left: 400rpx;
  top: 90rpx;
  width: 530rpx;
  height: 206rpx;
  z-index: 2;
}

.result-body {
  position: absolute;
  right: -620rpx;
  top: -52rpx;
  width: 1200rpx;
  height: 1200rpx;
  z-index: 4;
  opacity: 0.98;
}

.tag-pill {
  position: absolute;
  width: 172rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
  z-index: 3;
}

.tag-pill-light {
  left: 430rpx;
  top: 146rpx;
  background: #bcc8c5;
}

.radar-wrap {
  position: absolute;
  left: 146rpx;
  top: 204rpx;
  width: 278rpx;
  height: 260rpx;
  z-index: 4;
}

.radar-chart {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto;
}

.radar-line {
  position: absolute;
  background: rgba(122, 117, 105, 0.45);
}

.radar-line-h {
  left: 26rpx;
  top: 108rpx;
  width: 168rpx;
  height: 2rpx;
}

.radar-line-v {
  left: 108rpx;
  top: 26rpx;
  width: 2rpx;
  height: 168rpx;
}

.radar-line-d1 {
  left: 34rpx;
  top: 34rpx;
  width: 148rpx;
  height: 2rpx;
  transform: rotate(35deg);
  transform-origin: center;
}

.radar-line-d2 {
  left: 34rpx;
  top: 34rpx;
  width: 148rpx;
  height: 2rpx;
  transform: rotate(-35deg);
  transform-origin: center;
}

.radar-shape {
  position: absolute;
  left: 58rpx;
  top: 42rpx;
  width: 0;
  height: 0;
  border-left: 56rpx solid transparent;
  border-right: 34rpx solid transparent;
  border-bottom: 92rpx solid rgba(212, 122, 26, 0.58);
  transform: rotate(18deg);
}

.radar-label {
  position: absolute;
  font-size: 16rpx;
  color: #59544b;
  white-space: nowrap;
}

.radar-label-top {
  left: 62rpx;
  top: -12rpx;
}

.radar-label-left {
  left: -28rpx;
  top: 88rpx;
}

.radar-label-right {
  right: -28rpx;
  top: 88rpx;
}

.radar-label-bottom {
  left: 78rpx;
  bottom: -16rpx;
}

.tongue-section-title {
  margin-top: 12rpx;
  margin-bottom: 26rpx;
}

.tongue-analysis {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.tongue-item {
  position: absolute;
  z-index: 2;
}

.tongue-item-top {
  left: 50%;
  top: 0;
  width: 140rpx;
  height: 174rpx;
  transform: translateX(-50%);
}

.tongue-item-left {
  left: 72rpx;
  top: 150rpx;
  width: 176rpx;
  height: 120rpx;
  transform: rotate(-34deg);
}

.tongue-item-right {
  right: 74rpx;
  top: 150rpx;
  width: 176rpx;
  height: 120rpx;
  transform: rotate(34deg);
}

.tongue-item-bottom {
  left: 50%;
  bottom: 0;
  width: 144rpx;
  height: 176rpx;
  transform: translateX(-50%) rotate(180deg);
}

.tongue-image {
  width: 100%;
  height: 100%;
  display: block;
}
