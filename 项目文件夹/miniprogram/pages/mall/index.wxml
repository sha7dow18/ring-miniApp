<view class="mall-container">
  
  <swiper class="banner-swiper" autoplay="true" circular="true" interval="3000" indicator-dots="true" indicator-active-color="#000">
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="goToProduct" data-id="{{item.id}}">
      <view class="banner-box" style="background-color: {{item.color}};">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" style="position:absolute;left:0;top:0;width:100%;height:100%;border-radius:20rpx;" />
        <text class="banner-text">{{item.name}}</text>
        <text class="banner-sub">点击模拟购买验证</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="toolbar-section">
    <view class="search-box" bindtap="onSearch">
      <van-icon name="search" size="16px" color="#999" />
      <text class="search-placeholder">搜索对症调理好物</text>
    </view>
    <view class="sort-box">
      <text class="sort-item active">综合</text>
      <text class="sort-item">销量</text>
      <view class="sort-item">价格 <van-icon name="arrow-down" size="10px" /></view>
    </view>
  </view>

  <scroll-view class="category-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="id" 
        class="capsule-item {{activeCategory === item.id ? 'active' : ''}}"
        bindtap="onSwitchCategory"
        data-id="{{item.id}}">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="product-grid">
    <view class="product-card" wx:for="{{filteredProducts}}" wx:key="id" bindtap="goToProduct" data-id="{{item.id}}">
      <view class="p-img-box" style="background-color: {{item.color}};">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" style="width:100%;height:100%;border-radius:16rpx;" />
      </view>
      <view class="p-info">
        <text class="p-title">{{item.name}}</text>
        <view class="p-bottom">
          <view class="p-price"><text class="symbol">¥</text>{{item.price}}</view>
          <view class="cart-btn"><van-icon name="cart-o" size="18px" color="#333" /></view>
        </view>
      </view>
    </view>
  </view>

</view>