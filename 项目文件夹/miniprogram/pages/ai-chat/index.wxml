<view class="chat-page">
  <view class="gate-card" wx:if="{{!isConnected}}">
    <view class="gate-title">连接设备后即可开始咨询</view>
    <view class="gate-desc">完成设备连接后，可结合你的近期数据给出更贴合的建议。</view>
    <view class="capsule" bindtap="goConnectDevice">去连接设备</view>
  </view>

  <view wx:else class="chat-main">
    <view class="chat-top">
      <view class="chat-title">AI 健康咨询</view>
      <view class="chat-tip">仅用于健康管理参考，不替代专业医疗诊断。</view>
      <view class="clear" bindtap="clearConversation">清空对话</view>
    </view>

    <view class="quick-row">
      <view class="quick-item" wx:for="{{quickQuestions}}" wx:key="*this" data-q="{{item}}" bindtap="useQuickQuestion">{{item}}</view>
    </view>

    <scroll-view class="chat-list" scroll-y="true" scroll-into-view="{{scrollToId}}" scroll-with-animation>
      <block wx:for="{{messageList}}" wx:key="id">
        <view class="msg-row {{item.role === 'user' ? 'right' : 'left'}}" id="msg-{{item.id}}">
          <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'ai-bubble'}}"><text>{{item.content}}</text></view>
        </view>
      </block>
      <view style="height: 30rpx;"></view>
    </scroll-view>

    <view class="input-bar">
      <input class="text-input" value="{{inputText}}" bindinput="onInput" placeholder="请输入你的问题" confirm-type="send" bindconfirm="sendText"/>
      <view class="send" bindtap="sendText">发送</view>
    </view>
  </view>
</view>
