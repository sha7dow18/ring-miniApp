page{ background:linear-gradient(180deg,#f3ede2 0%,#ece2d3 100%); }
.page{ padding:24rpx; }
.card{ background:#f8f2e8; border-radius:20rpx; padding:20rpx; box-shadow:0 6rpx 16rpx rgba(45,56,49,.08); }
.title{ font-size:30rpx; font-weight:700; color:#1f2d28; margin-bottom:12rpx; }
.desc{ color:#6f7772; font-size:24rpx; line-height:1.7; }
.row{ display:flex; justify-content:space-between; gap:10rpx; padding:14rpx 0; border-bottom:1rpx solid #eaddcb; color:#405048; font-size:23rpx; }
.row:last-child{ border-bottom:none; }
.btn-row{ margin-top:16rpx; display:flex; flex-direction:column; gap:10rpx; }
.btn{ text-align:center; padding:18rpx 0; border-radius:999rpx; font-size:24rpx; background:#2f4a42; color:#f5eee3; }
.btn.danger{ background:#f1d9cd; color:#8b3f32; }
