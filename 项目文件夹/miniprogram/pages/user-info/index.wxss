page {
  background: #f6f7fb;
}

.user-info-page {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.avatar-card {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  overflow: hidden;
  margin-right: 14rpx;
  background: #e2e8f0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-size: 22rpx;
}

.hint {
  color: #64748b;
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #edf2f7;
  padding: 16rpx 0;
}

.row:last-child {
  border-bottom: none;
}

.row text {
  width: 150rpx;
  color: #475569;
  font-size: 24rpx;
}

.row input {
  flex: 1;
  height: 60rpx;
  font-size: 24rpx;
}

.textarea-row {
  align-items: flex-start;
}

.textarea-row textarea {
  flex: 1;
  min-height: 100rpx;
  font-size: 24rpx;
}

.save-btn {
  margin-top: 16rpx;
  text-align: center;
  background: #1d4ed8;
  color: #fff;
  border-radius: 14rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
}
