/* 统一商城与个人中心的底色 */
page {
  background-color: #F6F6F8;
}

.profile-container {
  padding: 30rpx;
  /* 绝对不能忘：防 TabBar 遮挡安全垫 */
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 1. 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 50rpx 30rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); /* 淡淡的高级阴影 */
}
.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}
.avatar {
  width: 100%;
  height: 100%;
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.user-sub {
  font-size: 24rpx;
  color: #999;
}

/* 基础卡片样式 */
.section-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.card-more {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
}

/* 2. 订单宫格 */
.order-grid {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #555;
  gap: 15rpx; /* 图标与文字的间距 */
}

/* 3. 更多服务列表 */
.service-list {
  display: flex;
  flex-direction: column;
}
.service-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #F0F0F0; /* 细分隔线 */
}
.service-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.service-left {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  gap: 20rpx;
}

/* 4. 悬浮客服气泡窗 */
.float-cs-bubble {
  position: fixed;
  right: 30rpx;
  /* 悬浮高度，避开底部 TabBar */
  bottom: calc(180rpx + env(safe-area-inset-bottom)); 
  width: 100rpx;
  height: 100rpx;
  background-color: #fff;
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1); /* 强烈阴影突出悬浮感 */
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 99; /* 保证浮在最上面 */
}
.bubble-text {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}