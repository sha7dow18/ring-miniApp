<view class="page" wx:if="{{pageData}}">
  <view class="nav-bar">
    <view class="nav-placeholder"></view>
    <view class="nav-title">{{pageData.headerTitle}}</view>
    <view class="nav-placeholder"></view>
  </view>

  <view class="hero">
    <view class="hero-text">
      <view class="hero-greeting">{{pageData.greeting}}</view>
      <view class="hero-user">{{pageData.userName}}</view>
    </view>

    <view class="ring-area">
      <view class="ring-soft-bg"></view>
      <view class="ring-light"></view>
      <image
        class="ring-image"
        src="../../assets/images/ring-home.png"
        mode="aspectFit"
      />
    </view>
  </view>

  <view class="month-switch">
    <text class="month-arrow">‹</text>
    <text class="month-text">{{pageData.monthText}}</text>
    <text class="month-arrow">›</text>
  </view>

  <scroll-view class="date-scroll" scroll-x="true" show-scrollbar="false">
    <view class="date-list">
      <view
        wx:for="{{pageData.dateList}}"
        wx:key="day"
        class="date-item {{item.active ? 'date-item-active' : ''}}"
      >
        <text class="date-day">{{item.day}}</text>
        <text class="date-week">{{item.week}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="main-card bp-card">
    <view class="bp-header">
      <text class="bp-title">{{pageData.bloodPressure.title}}</text>
      <view class="bp-period">{{pageData.bloodPressure.period}}</view>
    </view>

    <view class="chart-area">
      <view class="grid-line grid-line-1"></view>
      <view class="grid-line grid-line-2"></view>
      <view class="grid-line grid-line-3"></view>

      <view class="y-axis">
        <text>190</text>
        <text>160</text>
        <text>130</text>
        <text>100</text>
        <text>70</text>
        <text>40</text>
      </view>

      <view class="line high-line"></view>
      <view class="line low-line"></view>

      <view class="x-axis">
        <text wx:for="{{pageData.bloodPressure.timeList}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="legend-row">
      <view class="legend-item">
        <view class="legend-line high"></view>
        <text>舒张压</text>
      </view>
      <view class="legend-item">
        <view class="legend-line low"></view>
        <text>收缩压</text>
      </view>
    </view>
  </view>

  <view class="double-card-row">
    <view class="sub-card sport-card">
      <view class="sub-title">{{pageData.sport.title}}</view>

      <image
        class="sport-deco"
        src="../../assets/images/sport-deco.png"
        mode="aspectFit"
      />

      <view class="sport-row">
        <text class="big-number">{{pageData.sport.steps}}</text>
        <text class="sub-number">/{{pageData.sport.targetSteps}}步</text>
      </view>
      <view class="sport-row">
        <text class="small-strong">{{pageData.sport.calories}}</text>
        <text class="sub-number">/{{pageData.sport.targetCalories}}千卡</text>
      </view>
    </view>

    <view class="sub-card sleep-card">
      <view class="sub-title">{{pageData.sleep.title}}</view>

      <view class="sleep-visual">
        <image
          class="sleep-deco"
          src="../../assets/images/sleep-deco.png"
          mode="aspectFit"
        />
        <view class="sleep-center">
          <text class="sleep-score">{{pageData.sleep.score}}</text>
          <text class="sleep-level">{{pageData.sleep.level}}</text>
        </view>
      </view>

      <view class="sleep-duration">{{pageData.sleep.duration}}</view>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">其他数据</text>
    <view class="section-more">···</view>
  </view>

  <view class="metric-list">
    <view class="metric-item" wx:for="{{pageData.metrics}}" wx:key="name">
      <view class="metric-left">
        <view class="metric-icon">
          <image class="metric-icon-image" src="{{item.iconPath}}" mode="aspectFit" />
        </view>

        <view class="metric-info">
          <view class="metric-name">{{item.name}}</view>
          <view class="metric-value">
            <text class="metric-number">{{item.value}}</text>
            <text class="metric-unit">{{item.unit}}</text>
          </view>
        </view>
      </view>

      <view class="metric-right">
        <view class="metric-trend-box">
          <image
          wx:if="{{item.trendPath}}"
          class="metric-trend-image {{item.trendClass || ''}}"
          src="{{item.trendPath}}"
          mode="aspectFit"
          />
        </view>
        <view class="metric-arrow">›</view>
      </view>

    </view>
  </view>

  <view class="page-bottom-space"></view>
</view>
