<view class="service-container">
  
  <view class="device-hero">
    <view class="ring-mock-img">
      <van-icon name="aim" size="60px" color="#07c160" wx:if="{{isSearching}}" />
      <van-icon name="circle" size="60px" color="#ccc" wx:else />
    </view>
    <view class="status-text">{{isSearching ? '正在搜索附近指环...' : '暂未绑定设备'}}</view>
    <view class="status-sub">请确保手机蓝牙已开启，并保持指环电量充足</view>
    
    <view class="action-btn-wrap">
      <van-button type="primary" round block color="#07c160" bind:click="startSearch" loading="{{isSearching}}" loading-text="搜索中...">
        {{isSearching ? '' : '搜索并绑定设备'}}
      </van-button>
    </view>
  </view>

  <view class="device-list" wx:if="{{deviceList.length > 0}}">
    <view class="section-title">发现可用设备</view>
    <view class="device-item" wx:for="{{deviceList}}" wx:key="mac" bindtap="bindDevice" data-mac="{{item.mac}}">
      <view class="device-info">
        <text class="d-name">{{item.name}}</text>
        <text class="d-mac">MAC: {{item.mac}}</text>
      </view>
      <view class="d-signal">
        <van-icon name="signal" color="#07c160" size="20px" />
      </view>
    </view>
  </view>

  <view class="help-section">
    <view class="section-title">常见问题</view>
    <view class="help-item">
      <view class="h-title"><van-icon name="question-o" size="16px" color="#666" /> 搜不到指环怎么办？</view>
      <view class="h-desc">请将指环放入充电座并长按重置按键3秒，待指示灯闪烁后重新尝试搜索。</view>
    </view>
    <view class="help-item">
      <view class="h-title"><van-icon name="question-o" size="16px" color="#666" /> 如何解绑当前设备？</view>
      <view class="h-desc">请前往“我的” -> “个人主页” -> “我的指环”中进行解绑操作。</view>
    </view>
  </view>

</view>