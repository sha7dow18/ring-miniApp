page {
  background: #f6f3ed;
}

.service-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 72rpx 24rpx 260rpx;
  background: linear-gradient(180deg, #f6f3ed 0%, #ddc593 72%, #8c9973 100%);
}

.service-nav {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.service-nav-placeholder {
  width: 120rpx;
}

.service-nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #111111;
}

.service-hero {
  margin-bottom: 28rpx;
}

.service-title {
  font-size: 64rpx;
  line-height: 1;
  font-weight: 900;
  color: #111111;
  margin-bottom: 16rpx;
}

.service-subtitle {
  font-size: 28rpx;
  color: #5b5b5b;
}

.service-card {
  background: rgba(247, 240, 226, 0.96);
  border-radius: 36rpx;
  padding: 28rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.24);
}

.service-card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111111;
  margin-bottom: 14rpx;
}

.service-card-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #525252;
}
