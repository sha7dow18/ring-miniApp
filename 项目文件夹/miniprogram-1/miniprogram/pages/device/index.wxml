<view class="page">
  <view class="card">
    <view class="title">设备管理</view>
    <text class="subtitle">连接蓝牙智能戒指进行测量</text>
  </view>

  <view class="card" style="display:flex;align-items:center;gap:10px;">
    <text>当前状态：</text>
    <text>{{connected ? '已连接' : (scanning ? '扫描中...' : '未连接')}}</text>
    <button size="mini" bindtap="scan" disabled="{{scanning}}">扫描</button>
    <button size="mini" bindtap="disconnect" disabled="{{!connected}}">断开</button>
    
  </view>

  <view class="card" wx:if="{{devices.length}}">
    <view class="list-title">发现设备（点击绑定）</view>
    <block wx:for="{{devices}}" wx:key="deviceId">
      <view class="cell" bindtap="chooseDevice" data-id="{{item.deviceId}}" data-name="{{item.name}}">
        <view class="cell-left">
          <text class="cell-title">{{item.name || '未知设备'}}</text>
        </view>
        <view>
          <button size="mini" bindtap="connect" data-id="{{item.deviceId}}" data-name="{{item.name}}">绑定</button>
        </view>
      </view>
    </block>
  </view>

  <view class="card" wx:if="{{connected}}" style="display:flex;align-items:center;">
    <text class="connected-text">已连接设备：{{currentDeviceName}}</text>
  </view>
</view>