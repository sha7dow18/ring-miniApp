<view class="page">
  <view class="header">
    <text class="title">压力</text>
    <picker mode="date" value="{{selectedDate}}" start="1900-01-01" end="{{today}}" bindchange="onDateChange">
      <view class="date-btn">{{selectedDate}}</view>
    </picker>
  </view>
  <view class="summary">
    <view class="big-val">{{currentVal||'--'}}</view>
    <view class="stats-row">
      <view class="stat"><text class="stat-title">本日平均压力</text><text class="stat-val">{{avgVal||'--'}}</text></view>
      <view class="stat"><text class="stat-title">本日压力范围</text><text class="stat-val">{{minVal||'--'}}-{{maxVal||'--'}}</text></view>
    </view>
  </view>
  <view class="chart-card">
    <canvas class="chart" canvas-id="stress-chart"></canvas>
  </view>
  <view class="panel">
    <button class="primary" bindtap="startMeasure">手动检测</button>
    <button bindtap="viewHistory">查看历史</button>
  </view>
</view>