<view class="page">
  <view class="header">
    <text class="title">AI舌诊</text>
    <text class="subtitle">拍摄或上传舌象图片进行分析</text>
  </view>
  <view class="panel">
    <button class="primary" bindtap="pickImage">上传舌象</button>
    <button bindtap="analyze">调用AI分析</button>
  </view>
  <view class="result">分析结果占位</view>
</view>