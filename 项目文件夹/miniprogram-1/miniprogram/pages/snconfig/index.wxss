.page { padding: 16px; }
.card { background:#fff; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); padding:14px; margin-bottom:12px; }
.title { font-size:18px; font-weight:600; margin-bottom:8px; }
.input { border:1px solid #eee; border-radius:6px; padding:8px 12px; }
.btns { display:flex; gap:10px; margin-top:12px; }
.btn-primary { background:#1aad19; color:#fff; }
.tip { color:#888; font-size:12px; margin-top:4px; }
.log { font-size:12px; padding:4px 0; }