<view class="page">
  <view class="card">
    <view class="title">输入15位序列号</view>
    <input class="input" placeholder="如：F1H1F47100001G6" maxlength="15" value="{{sn}}" bindinput="onInput" />
    <view class="btns">
      <button class="btn-primary" bindtap="writeSn" disabled="{{!canWrite}}">写入SN</button>
      <button bindtap="goBack">返回调试</button>
    </view>
    <view class="tip">设备：{{deviceId}}</view>
    <view class="tip">写入服务：{{serviceId}}</view>
    <view class="tip">写入特征：{{writeCharId}}</view>
  </view>
  <view class="card">
    <view class="title">日志</view>
    <scroll-view scroll-y="true" style="max-height: 240px;">
      <block wx:for="{{logs}}" wx:key="id"><view class="log"><text>{{item}}</text></view></block>
    </scroll-view>
  </view>
</view>