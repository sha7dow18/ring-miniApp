Page { background: #FFFFFF; }
.page { padding: 16px; min-height: 100vh; background: linear-gradient(180deg, #6EE7F0 0%, #FFFFFF 100%); background-repeat: no-repeat; background-size: 100% 100%; }
.header { display:flex; justify-content:space-between; align-items:center; }
.header .title { font-size: 20px; font-weight: 700; color:#111827; }
.date-row { }
.date-btn { font-size:12px; color:#374151; background:#F3F4F6; padding:6px 10px; border-radius:16px; }
.cards { display:grid; grid-template-columns: repeat(2, 1fr); gap:12px; margin-top:12px; align-items:start; }
.grid > .card { align-self: start; }
.card { background:#fff; border-radius:14px; box-shadow:0 8px 24px rgba(41,93,187,0.12); border:1px solid rgba(91,141,239,0.18); padding:10px; height: 168px; box-sizing:border-box; transition: opacity .2s; width: 100%; display:flex; flex-direction:column; }
.page .card { opacity: 1; }
.page .card.measuring { opacity: .35; }
.card-top, .card-bottom { display:flex; justify-content:space-between; align-items:center; }
.card-top { height:22px; }
.card-title { line-height:22px; margin:0; }
.card-bottom { margin-top:auto; height:40px; }
.card-bottom { margin-top:auto; }
.card-title { font-size:14px; color:#111827; font-weight:600; }
.subtitle { color:#6B7280; font-size:12px; line-height:20px; }
.spark { width: 100%; height: 76px; border-radius:8px; background: #F8FAFF; margin:8px 0; display:block; }
.measure-btn { background:#06B6D4; color:#fff; margin:0; height:32px; line-height:32px; font-size:14px; min-width:80px; padding:0 12px; display:flex; align-items:center; justify-content:center; border-radius:16px; }
.card-bottom .subtitle { white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.measure-mask { position:fixed; left:0; right:0; top:0; bottom:0; background:rgba(0,0,0,0.35); display:flex; align-items:center; justify-content:center; z-index:999; }
.circle { width:160px; height:160px; border-radius:50%; border:10px solid #5B8DEF; display:flex; align-items:center; justify-content:center; flex-direction:column; background:#fff; }
.circle-text { font-size:22px; color:#111827; }
.circle-tip { font-size:12px; color:#6B7280; margin-top:6px; }
.circle-actions { margin-top:10px; }
.btn-cancel { background:#EF4444; color:#fff; }
.btn-ok { background:#1aad19; color:#fff; margin-left:8px; }