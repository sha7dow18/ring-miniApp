.page{display:flex;flex-direction:column;padding:16px;background:linear-gradient(180deg,#6EE7F0 0%,#FFFFFF 100%);min-height:100vh}
.header{margin-bottom:12px}
.title{font-size:20px;font-weight:600}
.conn-row{display:flex;align-items:center;gap:6px;margin-top:6px}
.conn-dot{width:10px;height:10px;border-radius:50%;margin-left:8px}
.conn-dot.green{background:#10B981}
.conn-dot.red{background:#EF4444}
.conn-text{margin-left:6px;font-size:12px;color:#374151}
.subtitle{font-size:16px;margin-bottom:8px}
.steps{display:flex;flex-direction:column;gap:12px}
.progress{background:#fff;border-radius:8px;padding:8px;box-shadow:0 2px 8px rgba(0,0,0,0.06)}
.panel{display:flex;flex-direction:column;gap:8px;background:#fff;border-radius:8px;padding:12px;box-shadow:0 8px 24px rgba(41,93,187,0.12);border:1px solid rgba(6,182,212,0.18)}
.row{display:flex;flex-direction:row;justify-content:space-between;align-items:center}
.metric{font-size:16px}
.metric{ text-align:left; }
.primary{background:#06B6D4;color:#fff}
.next,.prev{margin-top:8px}
.preview{width:100%;height:200px;background:#f5f5f5;border-radius:8px}
.result{margin-top:12px;display:flex;flex-direction:column;gap:6px}
.result-item{display:flex;flex-direction:row;gap:6px;flex-wrap:wrap}
.label{color:#666}
.report{margin-top:12px}
.report-bg{position:relative;border-radius:12px;overflow:hidden;min-height:200px}
.bg-img{position:absolute;inset:0;width:100%;height:100%}
.mask{position:absolute;inset:0;background:rgba(243, 236, 223, 0.75)}
.blocks{position:relative;padding:12px;display:flex;flex-direction:column;gap:12px}
.block{background:rgba(255,255,255,0.6);border-radius:12px;padding:12px;backdrop-filter:saturate(180%) blur(2px)}
.block{border:1px solid rgba(6,182,212,0.2);background:rgba(255,255,255,0.75)}
.radar{display:flex;flex-direction:column;align-items:center;justify-content:center}
.top{display:flex;flex-direction:row;gap:12px;align-items:center}
.face-photo{width:120px;height:120px;border-radius:8px;background:#eee}
.top-text{display:flex;flex-direction:column;gap:8px}
.title-cn{font-size:16px;font-weight:600;color:#3f3f3f}
.top-item{display:flex;flex-direction:row;gap:12px;align-items:center}
.top-name{font-size:18px;font-weight:700;color:#0e7490}
.top-percent{font-size:18px;font-weight:700;color:#0e7490}
.block-title{font-size:16px;font-weight:600;color:#3f3f3f;margin-bottom:6px}
.block-sub{font-size:14px;color:#8a5a1b;margin-bottom:6px}
.block-line{font-size:12px;color:#444;line-height:18px}
.bullet-list{display:flex;flex-direction:column;gap:6px;margin-top:6px}
.bullet-item{display:flex;flex-direction:row;gap:6px}
.bullet-dot{color:#0e7490;font-weight:700}
.bullet-text{color:#444;font-size:12px;line-height:18px;white-space:pre-wrap}
.feature-grid{display:grid;grid-template-columns:repeat(3, 1fr);gap:8px}
.feature-pill{background:rgba(255,255,255,0.8);border:1px solid rgba(138,90,27,0.2);border-radius:18px;padding:6px;display:flex;flex-direction:row;justify-content:space-between}
.debug-wrap{margin-top:12px}
.debug-header{display:flex;flex-direction:row;justify-content:space-between;align-items:center;margin-bottom:6px}
.debug-panel{background:#0a0a0a;color:#c7c7c7;border-radius:8px;padding:8px;font-family:monospace}
.debug-line{display:block;line-height:20px;word-break:break-all}
.debug-actions{display:flex;flex-direction:row;gap:8px;margin:6px 0}
.radar-wrap{display:flex;justify-content:center}
.clover-wrap{display:flex;justify-content:center}
.result-card{margin-top:12px}
.item{background:#fff;border-radius:12px;padding:12px;box-shadow:0 8px 24px rgba(41,93,187,0.12);border:1px solid rgba(6,182,212,0.18)}
.row{display:flex;flex-direction:row;justify-content:space-between;align-items:center}
.name{font-size:16px;color:#111827}
.time{font-size:12px;color:#0e7490}
.summary{font-size:12px;color:#374151;margin-top:6px}
.camera-modal{position:fixed;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:999}
.camera{position:absolute;inset:0}
.camera-mask{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:101%;height:auto;opacity:0.85}
.cv-actions{position:absolute;left:0;right:0;bottom:24px;display:flex;justify-content:center;gap:12px}
.cv-btn{background:#fff;color:#111827;padding:8px 16px;border-radius:12px}
.cv-btn.primary{background:#06B6D4;color:#fff}
.measure-mask{position:fixed;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,0.35);display:flex;align-items:center;justify-content:center;z-index:999}
.circle{width:160px;height:160px;border-radius:50%;border:10px solid #06B6D4;display:flex;align-items:center;justify-content:center;flex-direction:column;background:#fff}
.circle-text{font-size:22px;color:#111827}
.circle-tip{font-size:12px;color:#6B7280;margin-top:6px}
.btn-row{margin-top:10px;display:flex;justify-content:center}
.btn-cancel{background:#ef4444;color:#fff;padding:6px 12px;border-radius:12px}