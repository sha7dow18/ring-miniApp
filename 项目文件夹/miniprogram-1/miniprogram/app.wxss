/**app.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
} 

/* 统一按钮可视风格，让按钮更明显 */
button {
  background: #f5f5f5;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  padding: 8px 12px;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}


page {
  background: #f6f6f6;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

/* 全局通用样式 */
.page { padding: 16px; }
.card {
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  padding: 14px;
}
.card + .card { margin-top: 12px; }
.title { font-size: 20px; font-weight: 600; }
.subtitle { color: #8c8c8c; font-size: 12px; }
.primary { background: #06B6D4; color: #fff; border-radius: 8px; }

/* 强化按钮色系（按需使用） */
.btn-primary { background:#4f7cff; color:#fff; border-color:#4f7cff; }
.btn-secondary { background:#ece9ff; color:#4f3cff; border-color:#ddd; }
.btn-danger { background:#ffe8e6; color:#d93025; border-color:#ffd0cb; }
.btn-warning { background:#fff5d6; color:#b57500; border-color:#f5e3a8; }

/* 列表项 */
.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid #f0f0f0;
}
.cell:last-child { border-bottom: none; }
.cell-left { display: flex; align-items: center; gap: 10px; }
.cell-title { font-size: 16px; }
.cell-arrow { color: #c8c8c8; }

/* 栅格 */
.grid { display: flex; gap: 10px; flex-wrap: wrap; }
.grid-item { flex: 1 1 calc(50% - 10px); background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 12px; }
.grid-title { font-size: 14px; font-weight: 600; margin-top: 8px; }